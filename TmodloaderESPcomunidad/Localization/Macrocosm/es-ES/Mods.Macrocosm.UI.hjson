					Hover: Tienes que derrotar al jefe para poder volar sin peligro.
				}
			}

			Invasion: {
				NotMet: {
					Display: Invasión en curso
					Hover: Debes acabar con la invasión que está teniendo lugar para poder volar con seguridad.
				}
			}

			BloodMoon: {
				NotMet: {
					Display: La Luna de Sangre sigue en curso
					Hover: El vacío del espacio no es seguro cuando hay una luna de sangre
				}
			}

			Selected: {
				NotMet: {
					Display: Selecciona un destino
					Hover: por defecto
				}
			}

			DifferentTarget: {
				NotMet: {
