	TechniqueBlankScroll: {
		DisplayName: Pergamino en blanco para técnicas
		Tooltip:
			'''
			"Se utiliza para crear habilidades técnicas únicas"
			Tras activar una técnica, inflige daño rogue para recargar puntos de técnica
			Los puntos de técnica se pierden con el tiempo si no se inflige daño de forma continua
			Presiona la tecla '{$Keybinds.ThrowingTechnique.DisplayName}' para utilizar la habilidad de tu técnica activa
			'''
