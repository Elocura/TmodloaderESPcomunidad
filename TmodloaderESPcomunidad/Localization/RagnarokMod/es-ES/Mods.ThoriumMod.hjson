Buffs: {
	AssassinPotionBuff: {
		DisplayName: Asesino
		Description: Los ataques de rogue fuera de combate infligirán daño x4
	}

	DeepFreezeCoatingBuff: {
		DisplayName: Imbuición de arma Rogue : Congelación profunda
		Description: El daño infligido por la clase Rogue tiene una probabilidad de dificultar considerablemente el movimiento de los enemigos
	}

	ExplosiveCoatingBuff: {
		DisplayName: Imbuición de arma Rogue : Explosivo
		Description: El daño infligido por la clase Rogue  tiene la posibilidad de estallar, prendiendo fuego a los enemigos cercanos
	}

	GorgonCoatingBuff: {
		DisplayName: Imbuición de arma Rogue : Sangre de gorgona
		Description: El daño infligido por la clase Rogue tiene la posibilidad de petrificar a los enemigos
	}

	LichSetBuff: {
		DisplayName: Cosecha de almas
		Description: Tu velocidad de movimiento y la velocidad de ataque rogue se han incrementado considerablemente
	}

	MyceliumVeins: {
		DisplayName: Venas de micelio
		Description: La velocidad de ataque rogue aumenta un 10%
	}

	NinjaBuff: {
		DisplayName: Juego de manos
		Description: Se han aumentado la velocidad de las armas rogue, así como su rapidez y su probabilidad de golpe crítico
	}

	SporeCoatingBuff: {
		DisplayName: Imbuición de arma Rogue : Esporas
		Description: El daño infligido por la clase Rogue tiene la posibilidad de infectar a los enemigos con micelio
	}

	LastStandBuff: {
		DisplayName: Última batalla
		Description: La velocidad y el daño de las armas rogue aumentan un 30%, pero con un precio...
	}

	ThrowingSpeed: {
		DisplayName: Velocidad de pícaro
		Description: La velocidad de ataque rogue aumenta un 15%
	}

	ToxicCoatingBuff: {
		DisplayName:  Imbuición de arma Rogue : Tóxico
		Description: El daño infligido por la clase Rogue tiene la posibilidad de envenenar a los enemigos
	}

	TrueStrike: {
		DisplayName: Golpe certero
		Description: Tu ataque tiene un 100% de probabilidad de ser un golpe crítico
	}

	GoldenScaleBuff: {
		DisplayName: Pececito dorado
		Description: Tienes branquias y un sabor a galleta estupendo.\nPor desgracia, a los peces de colores no les gusta el Abismo
	}
}

