	Wreath: {
		DisplayName: Corona
		Tooltip:
			'''
			Aumenta un 10% la velocidad de ataque rogue
			Aumenta un 10% la velocidad de movimiento mientras se lleva un objeto rogue
			'''
	}

	DepthDiverHelmet: {
		DisplayName: Casco de buceo de profundidad
		Tooltip:
			'''
			"Conviértete en un protector desinteresado"
			La probabilidad de golpe crítico aumenta un 6%
			'''
		SetBonus:
			'''
			Tú y los aliados cercanos obtenéis un aumento del {0}% de daño y del {1}% en la velocidad de movimiento
			Tú y los aliados cercanos también podéis respirar bajo el agua cuando estáis fuera del Abismo
			En el Abismo, tú y tus aliados obtenéis, en su lugar, +10 fr defensa y un +20 % a la velocidad de movimiento
			Además, recuperarás algo de oxígeno de forma aleatoria mientras estés en el Abismo
			'''
	}

	NagaSkinMask: {
		DisplayName: Máscara de piel de Naga
		Tooltip:
			'''
			"Atuendo de los hechiceros acuáticos originales"
			El maná máximo aumenta en 60
			Te permite respirar bajo el agua
			No funciona en el Abismo
			'''
		SetBonus: Cada {0} de maná que gastes aumentará considerablemente tu daño mágico y tu velocidadde ataque mágico durante un breve periodo de tiempo
	}
}

Keybinds.ThrowingTechnique.DisplayName: Técnica rogue

ThrowerTechniques: {
	UseToEnable: Establece tu técnica activa al usarla | Inflige daño rogue para acumular puntos
	UseToDisable: Técnica activa | Vuelve a pulsar para desactivarla | Inflige daño rogue para acumular puntos

	LastStand: {
		DisplayName: Última batalla
		Description:
			'''
			Se activa automáticamente cuando recibes daño letal, lo que te otorga 8 segundos de invulnerabilidad
			Mientras seas invulnerable, obtienes un {1}% de velocidad y daño rogue, pero mueres al finalizar la duración
			'''
	}
}

