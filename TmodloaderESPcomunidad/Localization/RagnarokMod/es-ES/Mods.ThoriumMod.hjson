		DisplayName: Grebas de bronce
		Tooltip:
			'''
			Aumenta un 10% la velocidad de ataque de rogue
			Aumenta un 10% la velocidad de movimiento
			'''
	}

	BronzeHelmet: {
		DisplayName: Casco de bronce
		Tooltip:
			'''
			Aumenta la probabilidad de golpe crítico rogue en un 6%
			Aumenta un 10% la velocidad de ataque de rogue
			'''
	}

	DeepFreezeCoatingItem: {
		DisplayName: Revestimiento de Hielo profundo
		Tooltip: Los ataques de rogue tendrán una probabilidad de dificultar considerablemente el movimiento de los enemigos
	}

	ExplosiveCoatingItem: {
		DisplayName: Revestimiento explosivo
		Tooltip: Los ataques rogue tendrán una probabilidad de provocar un estallido, lo que hará que los enemigos cercanos se derritan
	}

	GorgonCoatingItem: {
		DisplayName: Revestimiento de gorgona
		Tooltip: Los ataques rogue tendrán una probabilidad de petrificar a los enemigos
	}

	SporeCoatingItem: {
		DisplayName: Revestimiento de esporas
		Tooltip: Los ataques rogue tendrán una probabilidad de infectar a los enemigos con micelio
	}

	ToxicCoatingItem: {
		DisplayName: Revestimiento tóxico
		Tooltip: Los ataques rogue tendrán una probabilidad de envenenar a los enemigos
	}

	PlagueLordFlask: {
		DisplayName: Frasco del señor de la peste
		Tooltip:
			'''
			Aumenta un 10% el daño rogue
			Aumenta un 10% la velocidad de ataque rogue
			Aumenta un 10% la rapidez de las armas rogue
			Al usar un objeto de rogue, hay un 20% de probabilidad de lanzar dos Dagas de la plaga
			Las Dagas de la plaga se dirigen hacia los enemigos y les contagian una enfermedad altamente contagiosa
			[c/FF0000:El daño causado por los proyectiles tiene un límite de 2000.]
			'''
	}

	ShinobiSigil: {
		DisplayName: Símbolo shinobi
		Tooltip:
			'''
			Aumenta la probabilidad de golpe crítico rogue en un 6%
			Si se asestan dos golpes críticos consecutivos con un ataque rogue, se descargará un rayo oscuro y 
			aumentará brevemente la velocidad de ataque rogue
			[c/FF0000::El daño causado por los proyectiles tiene un límite de 500.]
			'''
	}

	TideTurnerBreastplate: {
		DisplayName: Guardaprofundo del Volteador de mareas
		Tooltip:
			'''
			Aumenta un 15% el daño cuerpo a cuerpo y de rogue
			Aumenta un 10% la velocidad de ataque cuerpo a cuerpo y de rogue
			Aumenta un 16% la probabilidad de golpe crítico de las armas cuerpo a cuerpo y de rogue
			'''
	}

	TideTurnerGreaves: {
		DisplayName: Corona Profunda del Volteador de mareas
		Tooltip:
			'''
			Aumenta un 10% el daño cuerpo a cuerpo y de rogue
			Aumenta un 20% el empuje de las armas cuerpo a cuerpo y velocidad de ataque rogue
			Aumenta un 30% la velocidad de movmiento
			'''
	}

	TideTurnersGaze: {
		DisplayName: Caminaprofundo del Volteador de mareas
		Tooltip:
			'''
			"Desata la furia acuática sobre tus enemigos"
			Aumenta un 25% el daño rogue
			Hay un 50% de probabilidades de no consumir objetos rogue
			Aumenta tus puntos de técnica máximos en 2
			El daño infligido por la clase Rogue aumenta temporalmente el daño que recibe el enemigo en un 10%
			Genera un glóbulo flotante cada segundo
			Cada glóbulo hace que tu próximo ataque sea un minicrítico, siempre que no sea un crítico
			'''
	}

	LichCarapace: {
		DisplayName: Caparazón de Lich
		Tooltip:
			'''
			"Acepta la muerte..."
