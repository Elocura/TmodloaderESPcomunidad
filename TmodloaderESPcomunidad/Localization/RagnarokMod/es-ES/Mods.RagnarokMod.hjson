	AprilChaos: {
		DisplayName: Caos de Abril

		Headers: {
			AprilChaos: Caos de Abril
			RadiantMage: Mago radiante
			MeleeSummoner: Invocador y cuerpo a cuerpo
			RogueRanger: Rogue y a distancia
			ObnoxiousBard: El Bardo insoportable
		}

		MasterToggle: {
			Label: Botón alternador
			Tooltip: Desactiva/activa todas las opciones que aparecen a continuación
		}

		RadMage: {
			Label: Mago radiante
			Tooltip:
				'''
				El sanador parecía una mera extensión del mago.
				Así que lo hemos arreglado.
				Sustituyendo mago por sanador.
				Toda la magia es sanadora si crees con suficiente fuerza. 
				O si golpeas con suficiente fuerza.
				'''
		}

		MelSum: {
			Label: Invocador cuerpo a cuerpo
			Tooltip:
				'''
				Invocador tenía algunas carencias desafortunadas en su progresión.
                Así que lo hemos solucionado.
                Otorgándole a Invocador todas las habilidades de combate cuerpo a cuerpo.
                Ahora tus súbditos te respetan. 
                Tu espada, en cambio, no.
				'''
		}

		RogRan: {
			Label: Rogue y a distancia
			Tooltip:
				'''
				Rogue vuelve a sus raíces.
				Al absorber la clase a distancia.
				Siempre fueron la misma persona. 
				Solo que uno llevaba mejores zapatos.
				'''
		}

		ObBard: {
			Label: El bardo insoportable
			Tooltip: Hace que tus riffs... suenen menos a riffs
		}

