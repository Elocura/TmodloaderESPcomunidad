Buffs: {
	AntarcticCreativityBuff: {
		DisplayName: Creatividad antártica
		Description: El frío es una gran fuente de inspiración
		ItemTooltip: +15% de regeneración de inspiración y +10% de velocidad de interpretación sinfónica
	}

	AntarcticReinforcementBuff: {
		DisplayName: Refuerzo antártico
		Description: El frio te protege
		ItemTooltip: +8 de defensa y +2 de curación adicional
	}

	AntarcticExhaustionDebuff: {
		DisplayName: Agotamiento antártico
		Description: El frío te cala hasta los huesos
	}

	GuardianHealerBeamBuff: {
		DisplayName: Bendición del sanador guardián
		Description: Estás bajo una bendición profana
		ItemTooltip: +10% de reducción de daño y +5 hp/s de regeneración de vida
	}

	ElementalScytheCooldown: {
		DisplayName: Tiempo de enfriamiento del Segador elemental
		Description: ¡El Segador elemental está en enfriamiento!
	}

	ScytheAirBuff: {
		DisplayName: Bendición del aire
		Description: Siempre tienes el viento a favor
		ItemTooltip: +20% de velocidad de movimiento y tiempo de vuelo
	}

	ScytheBrimstoneBuff: {
		DisplayName: Bendición del azufre
		Description: Tus enemigos se convierten en llamas malditas
		ItemTooltip: Inglinge [cbuff:CalamityMod/BrimstoneFlames] con cada golpe
	}

	ScytheEarthBuff: {
		DisplayName: Bendición de la tierra
		Description: La Tierra te protege
		ItemTooltip: +10 de defensa
	}

	ScytheOasisBuff: {
		DisplayName: Bendición del oasis
		Description: Te sientes revitalizado gracias al oasis del desierto
		ItemTooltip: +15 hp/s de regeneración de vida
	}

	ScytheSandBuff: {
		DisplayName: Bendición de la arena
		Description: La arena te da fuerzas
		ItemTooltip: +5% de daño de ataqueack damage
	}

	ScytheWaterBuff: {
		DisplayName: Bendición del agua
		Description: El agua guía tu mano
		ItemTooltip: +5% de velocidad de ataque total
	}

	AuricSurge: {
		DisplayName: Oleada áurica
		Description: Te están castigando desde dentro.
	}

	KellyPetBuff: {
		DisplayName: Kelly!
		Description: Kelly te seguirá.
	}

	NightfallenDebuff: {
		DisplayName: Anochecer
		Description: La oscuridad lo devora todo.
		ItemTooltip:
			'''
			Sin tipo - 100 DPS
			+10% de daño recibido de todas las fuentes
			'''
	}

	LeviathanHeartBubble: {
		DisplayName: Burbuja de Leviatán
		Description: La Burbuja del Leviatán te otorga un +5% de reducción de daño
		ItemTooltip: +5% de reducción de daño
	}

	LeviathanHeartBubbleCorrupted: {
		DisplayName: Burbuja de Leviatán corrompida
		Description:
			'''
			La burbuja del Leviatán Corrupto te otorga un +10% de daño
			pero recibes un 5% más de daño
			'''
		ItemTooltip: +10% de daño de ataque y +5% de daño recibido de todas las fuentes
	}
}

Tooltips: {
	WhiteDwarfSetBonus:
		'''
		Los ataques de rogue tienen un 5% de probabilidad de desencadenar una llamarada de marfil procedente del cosmos 
		que inflige 1,75 veces más daño
		El daño de la llamarada se basa en el daño no crítico, pero la propia llamarada puede infligir daño crítico
		'''

	LeviathanHeart: {
		NormalTooltip:
			'''
			Los hechizos de curación curan un 25% más de puntos de vida
			Los hechizos de curación aplican [rbuff:RagnarokMod/LeviathanHeartBubble] a su objetivo
			'''
		CorruptTooltip:
			'''
			¡La burbuja del Leviatán reacciona a tu energía oscura!
			Todos los costes de salud se reducen en 1
			Al gastar salud, obtienes [rbuff:RagnarokMod/LeviathanHeartBubbleCorrupted]
			Aumenta un 10% la velocidad de ataque radiante
			'''
	}
}

Compat: {
	TechPoints: Aumenta tus puntos de técnica máximos en
	Recharge: y la recarga en
	BasicDamage: daño básico
	DupeDamage: del daño rogue se duplica
	DupeCap: El daño por duplicación tiene un límite máximo de
	NoGuideStack: El efecto no se acumula con otras Guías.
	Power: % de Poder
	Smited: fue castigado.
	Darkness: se sumió en la oscuridad.
	TurnedToAmmo: se convirtió en munición.
	Recoil: no pudo soportar el retroceso.
}

Items: {
	DrumStick: {
		DisplayName: Baqueta
		Tooltip: "'¡Tus enemigos son tus tambores!'"
	}

	AerospecBard: {
		DisplayName: Gorra con visera de aerospec
		Tooltip:
			'''
			Aumenta un 5% la velocidad de regeneración al tocar un instrumento y la de inspiración 
			+2 segundos de duración del potenciador
			'''
		SetBonus:
			'''
			Si recibes más de 25 puntos de daño de un solo golpe, caerán una lluvia de plumas autoguiadas
			Te permite caer más rápido y desactiva el daño por caída
			Aumenta el daño sinfónico en un 6%
			Aumenta la velocidad de movimiento en un 7%
			'''
	}

	AerospecHealer: {
		DisplayName: Capucha de a erospec
		Tooltip:
			'''
			10% menos de daño no radiante
            10% más de daño radiante
            +20 de maná máximo
			'''
		SetBonus:
			'''
			Se reduce un 10% del daño no radiante
			Aumenta un 10% del daño radiante
			Si recibes más de 25 de daño de un solo golpe, caerán una lluvia de plumas autoguiadas
			Te permite caer más rápido y desactiva el daño por caída
			Los hechizos de curación curan 2 puntos de vida adicionales
			Aumenta un 10% la velocidad de movimiento
			'''
	}

	AuricTeslaFrilledHelmet: {
		DisplayName: Gorra con visera de tesla áurica
		DisplayNameEclipse: Gorra con visera de tesla primordial
		Tooltip:
			'''
			Aumenta un 20% al daño sinfónico, la probabilidad de golpe crítico y a la velocidad de seguimiento de los proyectiles de los instrumentos de viento
			Aumento un 5% la velocidad de movimiento
			Aumenta un 30% la regeneración de inspiración
			+15 de inspiración máxima
			+2 rebotes de los proyectiles de los instrumentos de cuerda
			'''
		SetBonus:
			'''
			Aplica los efectos de las armaduras Llama de sangre, Matadioses y de Rapsoda
            Al pulsar la tecla '{$ThoriumMod.Keybinds.ArmorAbility.DisplayName}' se activarán las dos habilidades de la armadura de Rapsoda
			'''
		SetBonusHelheim: Efectos de las armaduras de Tarragón, Llama de sangre y Matadioses
	}

	AuricTeslaHealerHead: {
		DisplayName: Rostro radiante de tesla áurica
		DisplayNameEclipse: Rostro radiante de tesla primordial
		Tooltip:
			'''
			Corrompe tus poderes radiantes
			Aumenta el daño radiante un 100%, pero reduce el daño no radiante un 80%
			Aumenta la probabilidad de golpe crítico radiante un 25%
			Aumenta la velocidad de movimiento un 5%
			Reduce el consumo de maná un 25%
			Los hechizos de curación curan 10 puntos de vida adicionales
			+100 de maná máximo
			'''
		ToggleTooltip: "[c/aaaaaa:Pulsa Mayús + clic derecho sobre este objeto de tu inventario para activarlo o desactivarlo] [c/CC44FF:poderes radiantes corrompidos]"
		SetBonus:
			'''
			Posee los efectos de las armaduras de Llama de sangre, de Silva, y la de Tejedor de sueños
			Al pulsar la tecla '{$ThoriumMod.Keybinds.ArmorAbility.DisplayName}' se activarán las dos habilidades de la armadura de Tejedor de sueños
			Aumenta el daño radiante un 50%
			'''
		SetBonusHelheim:
			'''
			Efectos de las armaduras Tarragon, llama de sangre y de Silva
			Aumenta el daño radiante un 50%
			'''
	}

	BlazingDrumBeat: {
		DisplayName: Baqueta decorada
		Tooltip:
			'''
			Si aciertas con el timing de los golpes, el daño y el nivel de potenciación aumentarán progresivamente
			Si fallas el timing de los golpes, estas bonificaciones se reducirán considerablemente y te costarán 9 puntos de inspiración
			Estas bonificaciones se mantendrán entre cambios de arma, pero se irán desvaneciendo gradualmente mientras no sea tu arma activa
			Encadenar dos o más aciertos provocará un gran tajo llameante
			Los tajos llameantes infligen a todos los enemigos dentro del alcance [cbuff:CalamityMod/HolyFlames]
			'''
	}

	BloodflareHeadBard: {
		DisplayName: Casco con púas de llama de sangre
		Tooltip:
			'''
			Aumenta un 20% el daño sinfónico y aumenta un 12% la probabilidad de golpe crítico sinfónico
			Aumenta un 15% la regeneración de inspiración y obtienes +6 de la inspiración máxima
			Aumenta un 15% la probabilidad de que los enemigos suelten notas de inspiración
			'''
		SetBonus:
			'''
			Infligir daño sinfónico aplicará Sangre ardiente a los enemigos
			Acumularás sed de sangre: 2 puntos por cada enemigo al que golpees (solo puede ocurrir 3 veces por segundo)
			Al alcanzar los 100 puntos: auments un 20% el daño sinfónico y la probabilidad de golpe crítico, y un aumento del 25% de la velocidad de movimiento
			Las potenciaciones se prolongarán 3 segundos más y la regeneración de inspiración será un 10% más rápida
			Al pulsar la tecla de la "Habilidad de armadura", se consumirán 20 puntos para recuperar 10 de inspiración
			Perderás 25 puntos al recibir un golpe y perderás puntos rápidamente si no golpeas a los enemigos durante más de 5 segundos
			Tus puntos se reiniciarán cuando aparezca un jefe
			'''
	}

	BloodflareHeadHealer: {
		DisplayName: Rostro sombrío de llama de sangre
		Tooltip:
			'''
			Reduce un 20% el consumo de maná
			Reduce un 70% el daño no radiante y aumenta un 50% el daño radiante
			Aumenta un 20% la probabilidad de golpe crítico radiante
			Los hechizos de curación curarán 7 puntos de vida adicionales
			+60 de maná máximo
			'''
		SetBonus:
			'''
			Infligir daño radiante aplicará Sangre ardiente a los enemigos
			Acumularás sed de sangre: 2 puntos por cada enemigo al que golpees (solo puede ocurrir 3 veces por segundo)
			Al alcanzar los 100 puntos: aumenta un 20% el daño radiante y en la probabilidad de golpear, aumenta un 20% la velocidad de movimiento
			y tus hechizos de curación curarán 3 puntos de salud adicionales
			Además, recibirás una pequeña fracción del daño infligido en forma de curación
			Al pulsar la tecla de "Habilidad de armadura", consumirás 20 puntos para recuperar 25 puntos de vida + bonificación de curación
			Perderás 25 puntos al recibir un golpe y perderás puntos rápidamente si no golpeas a los enemigos durante más de 5 segundos
			Tus puntos se reiniciarán cuando aparezca un jefe
			'''
	}

	CalamityBell: {
		DisplayName: Campana de la catástrofe
		Tooltip: Lanza ráfagas de fuego de azufre autoguiadas que infligen [cbuff:CalamityMod/BrimstoneFlames] al impactar
	}

	CelestialManaCost: Reduce un 20% el coste de maná

	DaedalusHeadBard: {
		DisplayName: Tocado de dédalo
		Tooltip:
			'''
			Aumenta un 12% el daño sinfónico y aumenta un 5% la probabilidad de golpe crítico sinfónico
			+2 de inspiración máxima
			'''
		SetBonus:
			'''
			+10% de velocidad de regeneración de inspiración
			Al pulsar la tecla '{$ThoriumMod.Keybinds.ArmorAbility.DisplayName}', obtendrás [rbuff:RagnarokMod/AntarcticCreativityBuff] durante 15 segundos
			Cuesta 12 puntos de inspiración
			'''
	}

	DaedalusHeadHealer: {
		DisplayName: Rostro de dédalo
		Tooltip:
			'''
			10% menos de consumo de maná
			15% menos de daño no radiante
			+15% más de daño radiante y +7% de probabilidad de golpe crítico radiante
			+40 de maná máximo
			'''
		SetBonus:
			'''
			Los hechizos de curación curan 3 puntos de vida adicionales
			Al pulsar la tecla '{$ThoriumMod.Keybinds.ArmorAbility.DisplayName}', obtendrás un escudo de 50 puntos de vida y recibirás 
			[rbuff:RagnarokMod/AntarcticReinforcementBuff] durante 15 segundos.
			Cuesta 100 de maná
			'''
	}

	GodSlayerHeadBard: {
		DisplayName: Yelmo tricórnio del Matadioses
		Tooltip:
			'''
			Aumenta un 25% el daño sinfónico y aumenta ub 15% la probabilidad de golpe crítico sinfónico
			Aumenta un 15% la regeneración de inspiración
			+7 de inspiración máxima
			+15% de probabilidad de que los enemigos suelten notas de inspiración
			'''
		SetBonus: Mientras sostengas un instrumento, aplicarás potenciaciones aleatorias
	}

	SilvaHeadHealer: {
		DisplayName: Casco con guirnalda de Silva
		Tooltip:
			'''
			25% menos de consumo de maná
			Se reduce un 70% el daño no randiante y aumenta un 55% el daño radiante
			Aumenta un 20% la probablidad de crítico radiante
			Los hechizos de curación curarán 9 puntos de vida adicionales.
			+80 de maná máximo
			'''
		SetBonus:
			'''
			Tus hechizos de curación aumentarán la recuperación de vida y la velocidad de recuperación de vida de tus aliados
			Los aliados curados obtendrán 50 puntos más de salud máxima
			De vez en cuando recibirás bendiciones en forma de curaciones o escudos de vida
			Se activará con mayor frecuencia cuando tengas poca salud
			+3 PV/s de regeneración de vida.
			Aumenta un 5% la velocidad máxima al correr y al acelerar
			Si recibes daño letal, revivirás y serás invulnerable a todo daño durante 5 segundos
			Este efecto tiene un tiempo de enfriamiento de 5 minutos, que no se reduce si hay jefes o eventos activos
			'''
	}

	StormFeather: {
		DisplayName: Pluma tormentosa
		Tooltip:
			'''
			Se puede vender a muy buen precio a las tiendas
			"Una pequeña pluma caída del Gran Pájaro del trueno, que crepita con relámpagos"
			'''
	}

	StrangeAlienMotherBoard: {
		DisplayName: Placa base extraterrestre extraña
		Tooltip:
			'''
			La placa base del Explorador Estelar
			"Esta tecnología va más allá de tu conocimiento"
			'''
	}

	BelchingSaxophoneOverride: {
		DisplayName: "{$CalamityMod.Items.Weapons.Magic.BelchingSaxophone.DisplayName}"
		Tooltip: "{$CalamityMod.Items.Weapons.Magic.BelchingSaxophone.Tooltip}"
	}

	AnahitasArpeggioOverride: {
		DisplayName: "{$CalamityMod.Items.Weapons.Magic.AnahitasArpeggio.DisplayName}"
		Tooltip: Lanza claves de sol que se mueven lentamente y confunden a los enemigos
	}

	FaceMelterOverride: {
		DisplayName: "{$CalamityMod.Items.Weapons.Magic.FaceMelter.DisplayName}"
		Tooltip: "{$CalamityMod.Items.Weapons.Magic.FaceMelter.Tooltip}"
	}

	EmpoweredGranite: {
		DisplayName: Granito potenciado
		Tooltip:"'Bloque de granito cargado de energía procedente de la Tormenta de energía de ranito'"
	}

	EnchantedMarble: {
		DisplayName: Mármol encantado
		Tooltip: "'Un mármol especial, impregnado de antigua magia sagrada'"
	}

	StatigelHeadBard: {
		DisplayName: Gorro de statigel
		Tooltip:
			''
			Aumenta un 10% el daño sinfónico
			Aumenta un 7% la probabilidad de golpe crítico sinfónico
			'''
		SetBonus:
			'''
			Cuando recibes más de 100 de daño de un solo golpe, te vuelves inmune al daño durante un periodo prolongado
			Otorga un salto adicional y aumenta la altura del salto
			Aumenta la velocidad de salto en un 12%
			+10% de probabilidad de obtener notas de inspiración
			+5% de velocidad de regeneración de inspiración
			Los potenciadores sinfónicos duran 2 segundos más
			'''
	}

	StatigelHeadHealer: {
		DisplayName: Tocado de statigel
		Tooltip:
			'''
			Reduce un 10% el daño no radiante
			Aumenta un 10% el daño radiante
			Aumenta un 7% la probabilidad de golpe crítico radiante
			'''
		SetBonus:
			'''
			Cuando recibes más de 100 puntos de daño de un solo golpe, te vuelves inmune al daño durante un periodo prolongado
			Otorga un salto adicional y aumenta la altura del salto
			Aumenta la velocidad de salto en un 12%
			Los hechizos de curación curan 2 puntos de vida adicionales
			El maná máximo aumenta en 20
			Se reduce el consumo de maná en un 5%
			'''
	}

	StriderFang: {
		DisplayName: Colmillo de zancudo
		Tooltip: "'Un colmillo helado sacado directamente de la boca del Estrider boreal'"
	}

	TarragonCowl: {
		DisplayName: Capucha de estragón
		Tooltip:
			'''
			Aumenta un 5% la reducción de daño
			Reduce un 60% el daño no radiante
			Aumenta un 40% el daño radiante y aumenta un 15% la probabilidad de golpe crítico radiante
			Aumenta la curación adicional en 7
			Auments el maná máximo en 60
			Reduce el consumo de maná en un 20%
			'''
		SetBonus:
			'''
			Un sanador Guardián te ayudará a curar a tus aliados
			Cura a los aliados una cantidad de vida igual a tu bonificación de curación +5 de salud
			y les otorga [rbuff:RagnarokMod/GuardianHealerBeamBuff] durante 20 segundos
			{$CalamityMod.Items.Armor.PostMoonLord.TarragonBreastplate.CommonSetBonus}
			'''
	}

	TarragonShroud: {
		DisplayName: Sudario de estragón
		Tooltip:
			'''
			Aumenta un 5% la reducción de daño
			Aumenta un 20% el daño sinfónico y un 15% la probabilidad de golpe crítico sinfónico
			Aumenta un 15% la velocidad de interpretación
			Aumenta considerablemente la regeneración de inspiración
			+15% de probabilidad de que los enemigos suelten notas de inspiración
			+4 de inspiración máxima
			'''
		SetBonus:
			'''
			Los golpes críticos sinfónicos hacen que una potenciación activa aleatoria suba un nivel
			Tus potenciaciones duran un 50% más.
			{$CalamityMod.Items.Armor.PostMoonLord.TarragonBreastplate.CommonSetBonus}
			'''
	}

	VictideHeadHealer: {
		DisplayName: Capucha de esponja de victide
		Tooltip: Aumenta el daño radiante en un 5%, pero reduce el daño no radiante en un 5%
		SetBonus:
			'''
			Los enemigos serán menos propensos a atacarte
			Tendrás +3 de regeneración de vida y un aumento del 10% en el daño radiante, pero 
			se reducirá un 10% el daño no radiante mientras estés sumergido en un líquido
			'''
	}

	NightfallenHelmet: {
		DisplayName: Casco de la Noche caída
		Tooltip:
			'''
			Corrompe tus poderes radiantes
			Se reduce un 33%  del daño no radiante
			Aumenta un 33% el daño radiante
			Aumneta un 16% la probabilidad de golpe crítico radiante
			Se reduce un 25% el coste de maná
			Aumenta el maná máximo en 60
			'''
		SetBonus:
			'''
			Los hechizos de curación curarán 4 puntos de vida adicionales
			Todos los ataques infligen [rbuff:RagnarokMod/NightfallenDebuff]
			'''
	}

	NightfallenBreastplate: {
		DisplayName: Coraza de la Noche caída
		Tooltip:
			'''
			Se reduce un 25% el daño no radiante
			Aumneta un 25% el daño radiante
			Aumenta un 16% la probabilidad de golpe crítico radiante
			Se reduce un 20% el coste de maná
			'''
	}

	NightfallenGreaves: {
		DisplayName: Grebas de la Noche caída
		Tooltip:
			'''
			Se reduce un 20% el daño no radiante
			20% de aumento del daño radiante
			Aumenta un 12% la probabilidad de golpe crítico radiante
			Se reduce un 20% el coste de maná
			Aumenta un 20% la velocidad de movimiento
			'''
	}

	VictideHeadBard: {
		DisplayName: Sombrero de anémona de victide
		Tooltip: Aumento un 5% el daño sinfónico
		SetBonus:
			'''
			Los enemigos serán menos propensos a atacarte
            Tendrás +3 de regeneración de vida y un 10% más de daño sinfónico mientras estés sumergido en líquido
			'''
	}

	EquivalentExchange: {
		DisplayName: Intercambio equivalente
		Tooltip:
			'''
			Lanza un rayo que roba vida.
			Pulsa <right> para lanzar en su lugar rayos curativos de gran velocidad
			"Debes seguir la ley de intercambio equivalente".
			"Solo puedes obtener algo igual a lo que has aportado".
			'''
	}

	ProfanedScythe: {
		DisplayName: Guadaña profanada
		Tooltip:
			'''
			Una guadaña conocida por ser un auténtico infierno sagrado
			Pulsa <right> para lanzar la guadaña que describirá una trayectoria curva al volver
			La guadaña inflige un 20 % más de daño al lanzarla y arroja gotas de material fundido durante el vuelo
			'''
	}

	MarbleScythe: {
		DisplayName: Guadaña de mármol
		Tooltip: El mármol mágico confiere a la hoja de la guadaña un brillo adicional
	}

	ScoriaDualscythe: {
		DisplayName: Guadaña doble de escoria
		Tooltip:
			'''
			La escoria te permite hacer girar la guadaña mucho más rápido al expulsar vapor constantemente
			Pulsa <right>> para lanzar la guadaña, que describirá una trayectoria curva al volver
			La guadaña inflige un 20% más de daño cuando se lanza
			'''
	}

	InspirationEssence.DisplayName: Esencia de inspiración

	AstralRipper: {
		DisplayName: Destripador astral
		Tooltip:
			'''
			Al hacer girar esta guadaña, se crean estrellas que orbitan a tu alrededor
			Tras completar una vuelta completa, parpadean una vez antes de explotar
			Si mantienes pulsado <right>, la guadaña comenzará a cargarse
			Mientras se carga, las estrellas empezarán a caer rápidamente hacia tu cursor
			Suelta la carga para blandir la guadaña describiendo un arco enorme
			Al acertar el golpe, un gran grupo de estrellas se abatirá sobre el objetivo
			Todos los impactos de esta arma infligen [cbuff:CalamityMod/AstralInfectionDebuff]
			'''
	}

	RadioMic: {
		DisplayName: Micrófono inalámbrico
		Tooltip:
			'''
			Cantas una canción que genera una onda sonora de llamas sombrías que se van propagando
			La onda sonora central estará maldita
			El sonido maldito invocará un zarcillo que atacará al primer enemigo al que alcance
			"El micrófono de un demonio famoso"
			'''
	}

	CorrosiveFlux: {
		DisplayName: Fundente corrosivo
		Tooltip: Lanza 3 burbujas tóxicas
	}

	WindReaver: {
		DisplayName: Recuperador del viento
		Tooltip: Al girarlo, lanza de vez en cuando un rayo de viento
	}

	TrueSquirrelScarf: {
		DisplayName: Bufanda de ardilla auténtica
		Tooltip:
			'''
			La auténtica y original bufanda de ardilla
			Otorga +999 ranuras para centinelas
			'''
	}

	Prisma: {
		DisplayName: Prisma
		Tooltip: Lanza una estrella de mar de agua bendita que se hace añicos en 5 púas
	}

	VoidseerPearl: {
		DisplayName: Perla del Vidente del vacío
		Tooltip:
			'''
			Se puede vender a muy buen precio a las tiendas
			"Dicen que la belleza está en los ojos del que mira... No creo que lo dijeran en sentido literal"
			'''
	}

	QueenJelly: {
		DisplayName: Jalea real
		Tooltip:
			'''
			Restaura 100 puntos de vida
			Mejoras moderadas en todas las estadísticas
			"Una deliciosa gelatina de medusa,
			Se podría decir que con ella se hace el bocadillo más sabroso del mar"
			'''
	}

	Steampipes: {
		DisplayName: Tuberías de vapor
		Tooltip: ¡Gaitas impulsadas por vapor!
	}

	ElysianSong: {
		DisplayName: Canción elísea
		Tooltip: "'Tan cerca de la trompeta de un ángel, y sin embargo tan lejos...'"
	}

	ExecutionerMark05: {
		DisplayName: El verdugo: Mark 05
		Tooltip:
			'''
			Empieza despacio, pero va ganando velocidad progresivamente
			Una vez alcanzada la velocidad máxima, se lanzará contra el enemigo más cercano y explotará, provocando un efecto de gran alcance
			"El núcleo del XM-05 Thanatos reconvertido en una guadaña".
			'''
	}

	JellySlicer: {
		DisplayName: Cortador de gelatina
		Tooltip: Al balancearlo, lanza una ráfaga de proyectiles de slimes que rebotan
	}

	Splattercannon: {
		DisplayName: Cañón salpicador
		Tooltip:
			'''
			Pulsa <right> para cargar 8 balas en la recámara
			Puede contener un máximo de 64 balas en la recámara
			Pulsa <left> para disparar todas las balas a la vez
			Siempre tendrás 8 balas en la recámara
			Lanza orbes de sangre al golpear a los enemigos
			Recoger estos orbes de sangre reduce la duración de la [rbuff:PotionSickness]
			"LA SANGRE ES COMBUSTIBLE"
			'''
	}

	ProfanedBell: {
		DisplayName: Campana profanada
		Tooltip:
			'''
			Lanza ráfagas de llamas sagradas
			Los enemigos alcanzados quedan afectados por [cbuff:CalamityMod/HolyFlames] durante 3 segundos
			'''
	}

	AuricDamru: {
		DisplayName: Damru áurico
		Tooltip:
			'''
			Toca los bongos para infligir daño a todos los enemigos cercanos
			Pulsa <right> para lanzar una bomba de bengalas
			Las bombas de bengalas infligen a los enemigos el efecto [cbuff:CalamityMod/Dragonfire] durante 3 segundos
			'''
	}

	NewLichRequirement: {
		DisplayName: Nuevo requisito para el Lich
		Tooltip: Se supone que... eh... no deberías ver esto
	}

	EldritchShellFragment: {
		DisplayName: Fragmento de coraza sobrenatural
		Tooltip:
			'''
			Se vende por una auténtica fortuna en las tiendas
			"Un fragmento encantado procedente de la prisión de un dios antiguo"
			'''
	}

	SigilOfACruelWorld: {
		DisplayName: El símbolo de un mundo cruel
		Tooltip:
			'''
			Aumenta el daño sinfónico en un 15%
			Aumenta la velocidad de interpretación sinfónica en un 8%
			Aumenta la tasa de regeneración de inspiración en un 8%
			Aumenta la inspiración máxima en 3
			'''
	}

	UniversalHeadset: {
		DisplayName: Cascos universales
		Tooltip:
			'''
			Aumenta el daño sinfónico en un 20%
			Aumenta la probabilidad de golpe crítico sinfónico en un 7%
			Aumenta la velocidad de interpretación sinfónica en un 10%
			Aumenta la tasa de regeneración de inspiración en un 10 
			Aumenta la inspiración máxima en 5
			Cada potenciador único que tengas aumenta la velocidad de movimiento en un 2% y la velocidad de interpretación en un 1%
			'''
	}

	GoldenBatDroppings: {
		DisplayName: Excrementos de murciélago dorado
		Tooltip:
			'''
			+25% de monedas de los enemigos (Sube a un 50% al usar la Ira)
			Aumenta el daño en función de las monedas que lleves (solo en las ranuras de monedas)
			Esta bonificación aumenta un 50% al usar la Adrenalina
			Perderás el 25% de tus monedas de forma permanente al morir (que subirá a un 50% en el modo Muerte o Maestro)
			"¡No eres codicioso, es que estás completamente loco!"
			'''
	}

	VerdurantBloom: {
		DisplayName: Flor verdosa
		Tooltip: Lanza un ramillete de pétalos de flores de distintos tipos
	}

	CosmicInjector: {
		DisplayName: Inyector Cósmico
		Tooltip:
			'''
			Dispara rápidamente agujas que curan y causan daño
			Inflige [cbuff:CalamityMod/GodSlayerInferno] al impactar
			Utiliza jeringuillas como munición
			'''
	}

	Korobeiniki: {
		DisplayName: Korobeiniki
		Tooltip:
			'''
			Hace que los tetriminos caigan del cielo
			"Una consola de videojuegos cualquiera"
			'''
	}

	GraspofVoid: {
		DisplayName: Agarre del Vacío
		Tooltip: Lanza un fragmento de esencia del vacío que, al impactar, inflige [rbuff:ShadowFlame]
	}

	PhantasmalEdge: {
		DisplayName: Filo fantasmal
		Tooltip:
			'''
			Al hacer girar esta guadaña, se generan numerosas bolas de fuego en miniatura que te siguen mientras sigas girándola
			En cuanto dejes de girar la guadaña, las bolas de fuego se dirigen inmediatamente hacia el objetivo más cercano y explotan
			
			Pulsa <right> para lanzar la guadaña a modo de gancho y atraer a los enemigos hacia ti
			Sin embargo, ¡los enemigos más fuertes te atraerán hacia ellos en su lugar!
			'''
	}

	GodSlayersReap: {
		DisplayName: La cosecha del Asesino de Dioses
		Tooltip:
			'''
			Crea un pequeño holograma que se asemeja al Devorador de Dioses en el extremo de la guadaña al girarla.
			Este holograma irá aumentando su daño con el tiempo hasta un límite máximo e infligirá [cbuff:CalamityMod/GodSlayerInferno] al impactar
			Si dejas de usar la guadaña mientras el holograma está activo, este se liberará para atacar al enemigo más cercano
			El holograma liberado infligirá un daño mayor y aplicará [cbuff:CalamityMod/WhisperingDeath].
			'''
	}

	LucentGemini: {
		DisplayName: Lucent Gemini
		Tooltip:
			'''
			Al hacer girar esta guadaña, te envuelve un etéreo pulso de luz lunar.
			Los golpes generan [c/78C8FF:Esencia del alma] y tienen una probabilidad de generar [c/78C8FF:Estratos estelares]
			Pulsa <right> con 5 o más Estratos para invocar la constelación [c/A0DCFF:Gemini]
			Cada estrella dispara rayos penetrantes de luz lunar que infligen [cbuff:CalamityMod/Voidfrost]
			Vuelve a pulsar <right> para disipar la constelación
			'''
	}

	Arpeggiator: {
		DisplayName: Arpeggiator
		Tooltip: Dispara proyectiles en ráfagas siguiendo un patrón de arpegio
	}

	ElementalReaper: {
		DisplayName: Segador Elemental
		Tooltip:
			'''
			Al hacer girar esta guadaña, se crean proyectiles autoguiados que infligen [rbuff:CalamityMod/ElementalMix]
			Pulsa <right> para otorgarte a ti y a todos los aliados una de las siguientes bendiciones elementales durante 10 segundos:
			[rbuff:RagnarokMod/ScytheAirBuff]
			[rbuff:RagnarokMod/ScytheBrimstoneBuff]
			[rbuff:RagnarokMod/ScytheEarthBuff]
			[rbuff:RagnarokMod/ScytheOasisBuff]
			[rbuff:RagnarokMod/ScytheSandBuff]
			[rbuff:RagnarokMod/ScytheWaterBuff]
			'''
	}

	BrimScythe: {
		DisplayName: Guadañazufre
		Tooltip:
			'''
			Mientras giras el arma, te rodea un círculo de llamas de azufre que infligen daño constante
			Los enemigos alcanzados por el círculo también quedan afectados por [cbuff:CalamityMod/BrimstoneFlames] durante 5 segundos
			Si tienes menos del 25% de vida, matar a un enemigo con el círculo de fuego te curará 3 + el 5% de la vida máxima del enemigo
			'''
	}

	MaxEmpowermentTester: {
		DisplayName: Evaluador de empoderamiento máximo
		Tooltip: Otorga todas las habilitaciones al nivel especificado en el código del ítem :P
	}

