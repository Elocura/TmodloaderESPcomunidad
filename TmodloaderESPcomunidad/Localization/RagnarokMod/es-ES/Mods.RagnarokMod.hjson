			Pulsa <left> para tocar el ukelele
			Pulsa <right> para lanzar el ukelele
			"No es una buena forma de pedir perdón"
			'''
	}

	NightmareFreezer: {
		DisplayName: Congelador de pesadillas
		Tooltip:
			'''
			Al girar la guadaña periódicamente lanzas una lluvia de dardos helados
			"Encontrado en algún momento entre Halloween y Navidad... ¡Se podría hacer una película sobre eso!"
			'''
	}

	DragonForce: {
		DisplayName: Fuerza dracónica
		Tooltip:
			'''
			Consume inspiración rápidamente mientras canalizas un infierno hacia el cursor
			¡Pulsa <right> para reproducir el riff [c/FF4500:Rugido del Dragón de la jungla]!
			Mientras el riff está activo, el infierno que desata esta arma se amplifica
			'''
	}

	Lamentation: {
		DisplayName: Lamentación
		Tooltip: Dispara gigablasters de azufre autoguiados que infligen [cbuff:CalamityMod/BrimstoneFlames] al impactar
	}

	Virusprayer: {
		DisplayName: Pulverizador de virus
		Tooltip: Lanza una lluvia de burbujas de ácido
	}

	IntergelacticRobohelm: {
		DisplayName: Casco robótico intergaláctico
		Tooltip:
			'''
			Aumenta el daño sinfónico, la probabilidad de golpe crítico y la velocidad de interpretación sinfónica en un 20%
			Aumenta la regeneración de inspiración en un 15%
			Aumenta la inspiración máxima en 6
			Aumenta la duración del potenciamiento en 3 segundos
			Reduce el daño recibido en un 12%
			'''
	}

	IntergelacticRamhelm: {
		DisplayName: Casco con cuernos intergaláctico
		Tooltip:
			'''
			Reduce el daño no radiante en un 40%
			Aumenta el daño radiante en un 30%
			Aumenta la probabilidad de golpe crítico radiante y la velocidad de ataque en un 15%
			Reduce el consumo de maná en un 10%
			+60 de maná máximo
			Tus hechizos de curación curarán 5 puntos de vida adicionales
			'''
	}

	KellyPet: {
