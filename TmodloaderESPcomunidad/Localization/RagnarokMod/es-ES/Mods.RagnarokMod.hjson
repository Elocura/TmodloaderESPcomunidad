Configs: {
	BossProgressionConfig: {
		DisplayName: Configuración de la progresión de jefes
		Headers.BossProgressionChanges: Cambios en la progresión de los jefes

		GrandFlareGun: {
			Label: Cambio de receta para invocar al Gran Pájaro del Trueno
			Tooltip: Modifica la Gran Pistola de bengalas y la Bengala de tormenta para que requieran Mandíbulas de león de tormenta en lugar de Plumas de buitre.
		}

		DesertMedallion: {
			Label: Cambio de receta para invocar al Azote del desierto
			Tooltip: Cambia Medallón del desierto para que utilice lingotes de arenisca del Gran Pájaro del Trueno. 
		}

		DecapoditaSprout: {
			Label: Cambio de receta para invocar a Crabulón
			Tooltip: Modifica el Brotes de Decapodita para que utilice fragmentos de perla, plumas de tormenta y jalea real. 
		}

		MarbleGranite: {
			Label: Cambio de recetas para invocar al Tormensa de energía de granito y al El campeón enterrado 
			Tooltip: Modifica la Hoja ancestral y el Núcleo inestable para que requieran lingotes de Aerialita. 
		}

		OverloadedSludge: {
			Label: Cambio de receta para invocar al Dios Slime
			Tooltip: Modifica el Lodo sobrecargado para que utilice Mármol encantado y Granito potenciado.
		}

		StarCaller: {
			Label: Cambio de receta para invocar al Explorador Estelar
			Tooltip: Modifica el Llamador Estelar para que utilice lingotes de aerialita y el material de uno de los jefes malignos.
		}

		CryoKey: {
			Label: Cambio de receta para invocar a Criógeno
			Tooltip: Modica la Llave criónica para que use Colmillos de zancudo.
		}

		MechBosses: {
			Label: Cambios de recetas para invocar a los Jefes mecánicos
			Tooltip: Cambia Ojo mecánico, «Gusano» y Cráneo para que cada uno requiera una Placa base alienígena extraña
		}

		Lich: {
			Label: Cambio de receta para invocar al Lich
			Tooltip: Modifica el Filactorio Antiguo para que, en lugar de calabazas, requiera Esencia del Caos para invocar al Lich.
		}

		CharredIdol: {
			Label: Cambio de receta para invocar a la Elemental de azufre
			Tooltip: Modifica el Ídolo carbonizado para que requiera un Corazón del Vacío.
		}

		Seafood: {
			Label: Cambio de receta para invocar al Azote acuático
			Tooltip: Modidica el Marisco para que requiera Jalea real.
		}

		EyeOfDesolation: {
			Label: Cambio de receta para invocar al Clon de Calamitas
			Tooltip: Modifica Ojo de la desolación para que requiera la Perla del vidente del vacío
		}

		DeathWhistle: {
			Label: Cambio de receta para invocar al Devastador
			Tooltip: Modifica el Silbido de la muerte para que requiera Tela maldita.
		}

		DoomSayerCoin: {
			Label:  Cambio de receta para invocara los Primordiales
			Tooltip: Modifica Moneda del Augurador del Fin para que requiera Cenizas de la calamidad.
		}

		RuneOfKos: {
			Label: Cambios en la aparición de Providencia
			Tooltip: Modifica la receta de la Marca de la Providencia para que requiera Geodas divinas» y Esencias primordiales, y hace que ya no se obtenga como botín de Providencia.
		}
	}

	ClassBalancerConfig: {
		DisplayName: Configuración para el balance de clases

		Headers: {
			ClassBalanceChanges: Cambios en el equilibrio de las clases
			ClassMechanicChanges: Cambios en la mecánica de las clases
		}

		HealerDamageModifier: {
			Label: Modificador de daño de sanador
			Tooltip: Multiplicador del daño de sanador. El multiplicador se aplica una vez que se han aplicado todos los demás cambios.
		}

		BardDamageModifier: {
			Label: Modificador de daño de bardo
			Tooltip: Multiplicador del daño de Bardo. El multiplicador se aplica una vez que se han aplicado todos los demás cambios.
		}

		RogueDamageModifier: {
			Label: Modificador de daño de rogue
			Tooltip: Multiplicador del daño de rogue/arrojador. El multiplicador se aplica una vez que se han aplicado todos los demás cambios.
		}

		RangedDamageModifier: {
			Label: Modificador de daño a distancia
			Tooltip: Multiplicador del daño a distancia. El multiplicador se aplica una vez que se han aplicado todos los demás cambios.
		}

		MagicDamageModifier: {
			Label: Modificador de daño mágico
			Tooltip: Multiplicador del daño mágico. El multiplicador se aplica una vez que se han aplicado todos los demás cambios.
		}

		SummonDamageModifier: {
			Label: Modificador de daño de invocación
			Tooltip: Multiplicador del daño de Invocador. El multiplicador se aplica una vez que se han aplicado todos los demás cambios.
		}

		MeleeDamageModifier: {
			Label: Modificador de daño cuerpo a cuerpo
			Tooltip: Multiplicador del daño cuerpo a cuerpo. El multiplicador se aplica una vez que se han aplicado todos los demás cambios.
		}

		HealingBonusModifier: {
			Label: Modificador de bonificación de curación
			Tooltip:  Multiplicador de las bonificaciones de curación. El multiplicador se aplica una vez que se han aplicado todos los demás cambios.
		}

		RiffsRequireRiffInstrumentToBeHeld: {
			Label:  Para tocar riffs es necesario sujetar el instrumento con el que se toca
			Tooltip: Los rifs terminan automáticamente cuando se deja de empuñar el arma.
		}

		MistimedDamagePen: {
			Label: Penalización por daño inoportuno
			Tooltip:
				'''
				Penalización de daño de Thorium por ataques con instrumentos grandes mal sincronizados
				El valor predeterminado de Thorium es 0,75, lo que significa que los ataques mal sincronizados infligen un 75% menos de daño.
				El valor predeterminado de Ragnarok es 0,6, lo que significa que los ataques mal sincronizados infligen un 60% menos de daño.
				[c/7C0A02:Sin embargo, algunos mods pueden forzar este valor a otro distinto para mantener su propio balance.]
				'''
		}
	}

	ItemBalancerConfig: {
		DisplayName: Configuración para el balance de objetos
		Headers.ItemBalanceChanges: Encabezado de cambios de balance de objetos

		OmegaCore: {
			Label: Núcleo Omega
			Tooltip: Se reduce la bonificación de velocidad de movimiento del Núcleo Omega para que resulte más equilibrado a medida que avanza el juego.
		}

		genericweaponchanges: {
			Label: Ajustes generales de las armas
			Tooltip: Aplica ajustes generales al rebalance de las armas.
		}
	}

	UIConfig: {
		DisplayName: Configuración de la interfaz de usuario

		Headers: {
			UITweaks: Encabezado de ajustes de la interfaz de usuario
			Debug: Encabezado de depuración
		}

		BardEmpowermentBarOffsetX: {
			Label: Desplazamiento X de la barra de bardo
			Tooltip: Desplazamiento en X de la barra de potenciación del bardo. El valor por defecto ya debería solucionar la superposición con los tiempos de enfriamiento de los objetos de Calamity.
		}

		BardEmpowermentBarOffsetY: {
			Label: Desplazamiento Y de la barra de bardo
			Tooltip: Desplazamiento en Y de la barra de potenciación del bardo. El valor por defecto ya debería solucionar la superposición con los tiempos de enfriamiento de los objetos de Calamity.
		}
	}

	ModCompatConfig: {
		DisplayName: Configuración de compatibilidad con mods
		Headers.ModCompat: Compatibilidad de mods

		item_deduplication_mode: {
			Label: Eliminación de objetos duplicados de Bardo y Sanador de Calamity
			Tooltip: Selecciona qué recetas de objetos duplicados se cargan. La opción "Off" (Desactivado) habilita ambas versiones del mod.
		}
	}

