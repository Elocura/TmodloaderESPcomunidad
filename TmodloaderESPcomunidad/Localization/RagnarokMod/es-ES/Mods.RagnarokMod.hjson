		Tooltip: ""
	}

	SirenScale: {
		DisplayName: Escama de sirena
		Tooltip:
			'''
			La Sirena canta al compás de tu encantadora melodía
			Daño sinfónico aumenta en 15 %
			La celocidad de regeneración de inspiración aumenta un 20 %
			Anahita cantará al compás de tus instrumentos de cuerda, lanzando proyectiles de agua adicionales
			'''
	}

	ScourgesFrets: {
		DisplayName: Los trastes del Azote
		Tooltip:
			'''
			Emite ondas sonoras rebotantes que parecen estar hechas de arena
			¡Pulsa <right> para tocar el riff [c/34C9EB:Guardián de los Mares Antiguos]!
			Mientras el riff está activo, los ataques de esta guitarra son el doble de potentes e infligen un 25% más de daño
			Sincroniza tus ataques durante el riff para reducir el tiempo de enfriamiento
			'''
	}

	AuricGreatscythe: {
		DisplayName: Gran guadaña áurica
		Tooltip:
			'''
			Esta guadaña se carga cuanto más tiempo la haces girar,
            alcanzando velocidades increíbles.
            Pulsa <right> para lanzar un rayo
			'''
	}

	IrradiantInfinity: {
		DisplayName: Infinito radiante
		Tooltip:
			'''
			Pulsa <left> para lanzar un orbe [c/FF5555:Rojo radiante] con un enorme efecto de repulsión
			Pulsa <right> para invocar un orbe [c/55AAFF:Azul radiante] que sigue a tu curso
			El [c/55AAFF:Azul radiante] atrae a los enemigos cercanos y crece con cada impacto
			Una vez que alcance la masa crítica, golpéala con [c/FF5555:Rojo Irradiante] para desatar [c/CC44FF:Púrpura Irradiante]
			'''
	}

	PrimalTerror: {
		DisplayName: Terror primigenio
		Tooltip: Añádeme a favoritos ;P
		HasAwoken: ¡La Sierpe primordial ha despertado!
	}

	DevourerOfSines: {
		DisplayName: Devorador de ángulos senos
		Tooltip:
			'''
			Utiliza esta arma para generar una onda sinusoidal de gran magnitud.
			¡Pulsa <right> para reproducir el riff [c/501eb4:Colapso universal]!
			Mientras el riff esté activo, todos los jugadores que se encuentren dentro del radio de acción tendrán vuelo ilimitado.
			'''
	}

	Ectambourine: {
		DisplayName: Ectamburina
		Tooltip:
			'''
			Lanza una cantidad infinita de panderetas fantasmales
			Pulsa <right> para hacer sonar las panderetas lanzadas y causar daño a los enemigos cercanos
			'''
	}

	InfectedOcarina: {
		DisplayName: Ocarina infectada
		Tooltip:
			'''
			Emite una ráfaga de ruido maldito
			Tienes la posibilidad de lanzar saliva repugnante
			¡Pulsa <right> para reproducir el riff [c/50477e:Mente perversa]!
			Mientras el riff está activo, aparecen pústulas infectadas a tu alrededor
			Las pústulas infectadas escupirán fuego maldito al enemigo más cercano
			'''
	}

	Shredder: {
		DisplayName: Trituradora
		Tooltip:
			'''
			Lanza ondas de choque sangrientas
			¡Pulsa <right> para reproducir el riff [c/AA1111:Coagulante de sangre]!
			Mientras el riff está activo, todos los jugadores que se encuentren dentro del alcance obtienen robo de vida
			Sincroniza tus ataques durante el riff para reducir el tiempo de enfriamiento
			Si no sincronizas bien tus ataques durante el riff, no reducirás el tiempo de enfriamiento, pero tampoco se reducirá tu daño
			'''
	}

	SquirrelScarf: {
		DisplayName: Bufanda de ardilla
		Tooltip:
			'''
			Aumenta en 1 el número máximo de centinelas
			"Tan mullido como la cola de una ardilla"
			'''
	}

	RiffTester: {
		DisplayName: Probador de riffs
		Tooltip: Borra los tiempos de enfriamiento de los riffs. Úsalo con responsabilidad.
	}

	StellarRiff: {
		DisplayName: Riff estelar
		Tooltip:
			'''
			Lanza estrellas autoguiadas, que se dividen en fragmentos autoguiados
			Si lo haces bien, aumentará el número de fragmentos
			¡Pulsa <right> para tocar el riff [c/00FFC8:Pisotón interestelar]!
			Mientras el riff está activo, llueven estrellas desde arriba
			El número de fragmentos autoguiados se duplica mientras el riff esté activo
			Sincroniza tus ataques durante el riff para reducir el tiempo de enfriamiento
			'''
	}

	ToxicWaves: {
		DisplayName: Ondas tóxicas
		Tooltip:
			'''
			Lanza nubes tóxicas flotantes que infligen [cbuff:CalamityMod/SulphuricPoisoning] y [cbuff:CalamityMod/Irradiated] al impactar
			Las nubes atravesarán a los enemigos en función de los rebotes adicionales de tu instrumento de cuerda
			¡Pulsa <right> para tocar el riff [c/37C300:Sabiduría tóxica]!
			Mientras el riff está activo, un vórtice sulfuroso invoca tiburones ácidos desde arriba
			Sincroniza tus ataques durante el riff para reducir el tiempo de enfriamiento
			'''
	}

	FateoftheGods: {
		DisplayName: Destino de los dioses
		Tooltip:
			'''
			¡Gracias a todo el equipo, a todos los que nos han apoyado y a todos los que jugáis al mod y lo mantenéis vivo!
			El espacio de este cuadro no basta para dar cabida a todo el equipo
			[c/999999:Mantén pulsada la tecla Mayús izquierda para ver una lista de los desarrolladores anteriores y actuales]
			'''
		Donors: Donadores
		Artists: Artistas
		Programmers: Programadores
		OtherDevelopers: Otros desarrolladores
	}

	ProfanityFilter: {
		DisplayName: Filtro de palabrotas
		Tooltip:
			'''
			Las armas electrónicas tienen un 10% menos de daño, pero un 50% más de velocidad de innterpretación
			Aumenta un 15% el daño sinfónico para las armas que no sean electrónicas
			Aumenta un 10% la de probabilidad de crítico sinfónico
			Aumenta la inspiración máxima en 4.
			El daño sinfónico tiene un 10% de probabilidad de aumentar el nivel de uno de tus potenciadores activos
			Este efecto solo puede activarse una vez cada 2,5 segundos
			'''
	}

	RedglassMonocle: {
		DisplayName: Monóculo de cristal rojo
		Tooltip:
			'''
			Lo llevó en su día una famosa estrella underground
			Aumenta el daño sinfónico en un 25%
			La potenciación de Daño fijo es el doble de eficaz
			Mientras lo lleves puesto, el Micrófono inalámbrico obtiene las siguientes bonificaciones:
			El coste de inspiración se reduce en 2
			Aumenta el nivel de la potenciación de Daño en 1
			Inflige [rbuff:ThoriumMod/Charmed] durante 5 segundos
			'''
	}

	RelicOfConvergenceOverride: {
		Tooltip:
			'''
			Crea un cristal profanado en el cursor que canaliza un aura curativa antes de romperse
			Todos los jugadores dentro del área de efecto recuperan {0} + 4 veces la bonificación de curación en PV
			Los aliados obtienen un 50% de curación adicional
			Mantener el cristal en alto reduce la defensa y aumenta el daño recibido
			[c/FF8C00:Nunca había conocido la bondad. Ni mis compañeros ni mi familia sentían ni una pizca de compasión por mí.]
			[c/FF8C00:Anhelaba a alguien en quien poder confiar. Una presencia que me liberara de la ansiedad.]
			[c/FF8C00:Y cuando vi su radiante sonrisa al conocernos, supe que por fin lo había encontrado.]
			'''
		DisplayName: Reliquia de la convergencia
	}

	CorroslimeBass: {
		Tooltip:
			'''
			Lanza bolas de slime corrosivo que rebotan
			Pulsa <right> para dividir las bolas en {0} bolas más pequeñas
			Este proceso se puede repetir {1} veces
			'''
		DisplayName: Bajo de slime corrosivo
	}

	CrimslimeOboe: {
		DisplayName: Oboe de slime carmesí
		Tooltip:
			'''
			Dispara dardos pegajosos de slimes carmesís
			Dentro de {0} segundos, los dardos explotarán
			'''
	}

	StringsofOblivion: {
		DisplayName: Cuerdas del olvido
		Tooltip: ""
	}

	WulfrumGuitar: {
		Tooltip:
			'''
			Lanza ondas sonoras que rebotan
			Pulsa <right> para devolver las ondas
			Las ondas devueltas ignorarán los bloques
			'''
		DisplayName: Guitarra de wulfrum
