	BossConfig: {
		DisplayName: Configuración de jefes
		Headers.BossChanges: Cambios de jefes

		bird: {
			Label: IA del Gran Pájaro del trueno
			Tooltip: Selecciona qué reajuste de IA se debe utilizar. Desactivado para el comportamiento predeterminado
		}

		jelly: {
			Label: IA de la Reina medusa
			Tooltip: Selecciona qué reajuste de IA se debe utilizar. Desactivado para el comportamiento predeterminado
		}

		bossstatstweak: {
			Label: Ajustes en las estadísticas de los jefes
			Tooltip: Selecciona si los jefes de Thorium reciben ajustes en sus estadísticas (daño de ataque, salud, defensa, reducción de daño) para la escalabilidad de Calamity.
		}

		bossrush: {
			Label: Boss Rush de Thorium
			Tooltip: Selecciona qué modo boss rush quieres utilizar. Si lo desactivas, se desactiva el modo boss rush.
		}

		viscount: {
			Label: IA del Vizconde
			Tooltip: Selecciona qué versión mejorada de la IA se debe utilizar. Desactivada para el comportamiento predeterminado. La opción Auto utiliza la IA de Ragnarok si no se detecta ningún otro rework.
		}

		granite: {
			Label: IA de la Tormenta de energía de granito
			Tooltip: Selecciona qué versión mejorada de la IA se debe utilizar. Desactivada para el comportamiento predeterminado. La opción Auto utiliza la IA de Ragnarok si no se detecta ningún otro rework.
		}

		champion: {
			Label: IA del Campeón enterrado
			Tooltip: Selecciona qué versión mejorada de la IA se debe utilizar. Desactivada para el comportamiento predeterminado. La opción Auto utiliza la IA de Ragnarok si no se detecta ningún otro rework.
		}

		scouter: {
			Label: IA del Explorador estelar
			Tooltip: Selecciona qué versión mejorada de la IA se debe utilizar. Desactivada para el comportamiento predeterminado. La opción Auto utiliza la IA de Ragnarok si no se detecta ningún otro rework.
		}

		strider: {
			Label: IA del Estrider boreal
			Tooltip: Selecciona qué versión mejorada de la IA se debe utilizar. Desactivada para el comportamiento predeterminado. La opción Auto utiliza la IA de Ragnarok si no se detecta ningún otro rework.
		}

		beholder: {
			Label: IA del Observador caído
			Tooltip: Selecciona qué versión mejorada de la IA se debe utilizar. Desactivada para el comportamiento predeterminado. La opción Auto utiliza la IA de Ragnarok si no se detecta ningún otro rework.
		}
	}

