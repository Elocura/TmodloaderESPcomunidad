	ClientConfig: {
		DisplayName: Configuración del cliente

		Headers: {
			Audio: Audio
			UITweaks: Ajustes en la interfaz de usuario
			WelcomeText: Texto de bienvenida
			Visual: Elementos visuales
			VisFluxMeter: Cabecera del medidor de flujo de aire
		}

		BardEmpowermentBarOffsetX: {
			Label: Desplazamiento X de la barra de potenciación del bardo
			Tooltip: ""
		}

		BardEmpowermentBarOffsetY: {
			Label: Desplazamiento Y de la barra de potenciación del bardo
			Tooltip: ""
		}

		RiffMusicVolume: {
			Label: Volumen de la música del riff
			Tooltip:
				'''
				Ajusta el volumen de la música de los riffs.
				Si se establece en 0, se desactivará la música de los riffs y no se atenuará la música en reproducción al comenzar un riff
				'''
		}

		StartText: {
			Label: Inicio del texto
			Tooltip: Activa o desactiva el texto de bienvenida al entrar en el mundo
		}

		RiffScreenEffectIntensity: {
			Label: Intensidad del efecto de pantalla del riff
			Tooltip: Controla la intensidad de los efectos de pantalla del riff. Ajústalo a 0 para desactivarlos.
		}

		MissSoundPreset: {
			Label: Preajuste de sonido de fallo
			Tooltip: Elige un estilo de sonido predefinido para los avisos de tiempo agotado.
		}

		CustomMissSoundPath: {
			Label: Ruta de sonido personalizada de fallo
			Tooltip:
				'''
				Introduce la ruta de sonido del mod para el sonido personalizado de fallo que quieras utilizar.
				Por ejemplo, "RagnarokMod/Sounds/bonk".
				Debe haber un archivo .ogg correspondiente en la carpeta Sounds del mod; de lo contrario, podría provocar fallos en el juego o simplemente no funcionar.
				No tiene ningún efecto a menos que la opción Preajuste de sonido de fallo esté configurada en Personalizado.
				'''
		}

		MissSoundVolume: {
			Label: Volumen del sonido de fallo
			Tooltip: Ajusta el volumen del sonido de aviso de tiempo agotado.
		}

		MissSoundDuringRiff: {
			Label: Sonido de fallo durante el riff
			Tooltip: Determina si se reproducirá el sonido de falta de sincronización durante un riff activo.
		}

		PlaySoundDuringRiff: {
			Label: Reproducir sonido durante el riff
			Tooltip:
				'''
				Determina si se reproduce el sonido del instrumento durante los riffs.
				Establece el valor en 1 para que el sonido se reproduzca siempre durante los riffs, y en -1 para que nunca se reproduzca.
				El valor 0 hará que el sonido solo se reproduzca durante los riffs en los objetos específicos previstos, como las Castañuelas fúngicas.
				'''
		}

		MeterOffsetX: {
			Label: Desplazamiento del medidor X
			Tooltip: ""
		}

		MeterOffsetY: {
			Label: Desplazamiento del medidor Y
			Tooltip: ""
		}

		RiffsOverrideEventMusic: {
			Label: Los riffs tienen prioridad sobre la música de los eventos
			Tooltip: Activa o desactiva la opción de que la música de Riff sustituya a la música de los eventos.
		}

		RiffsOverrideBossMusic: {
			Label: Los riffs se imponen a la música de los jefes
			Tooltip: Activa o desactiva la opción de que la música de los riffs sustituya a la de los jefes.
		}
	}

