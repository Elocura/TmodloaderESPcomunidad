	MenuMusicBox: {
		DisplayName: Caja de música (Título de Ragnarok)
		Tooltip: Reproduce "Menu Theme", de CrafterDaemon
	}

	InspirationSingularity.DisplayName: Inspiración de singularidad

	Asterion: {
		DisplayName: Asterión
		Tooltip:
			'''
			Crea un fractal ramificado de luz estelar a tu alrededor
			Esta luz estelar te otorga ocasionalmente Estrellas fugaces al acertar a los enemigos.
			Pulsa <right> cuando tengas suficientes Estrellas fugaces para crear a Asterión
			Asterion consume Estrellas fugaces rápidamente, pero libera pulsos estelares constantes
			Estos pulsos te curan a ti y a tus aliados que estén dentro del alcance, e infligen [cbuff:CalamityMod/Voidfrost] a los enemigos
			"Tan leal como un sabueso"
			'''
	}

	FungalCastanets: {
		DisplayName: Castañuelas fúngicas
		Tooltip:
			'''
			Los chasquidos alternos de las castañuelas esparcen esporas fúngicas que permanecen en el aire
			¡Pulsa <right> para reproducir el riff [c/00FFFF:1NF3S+@+!0N]!
			Durante el riff, tus castañuelas se convierten en las pinzas de Crabulon mientras llueven esporas desde arriba
			"¡Suena como pinzas de cangrejo!"
			'''
	}

	CantStopWontStop: {
		DisplayName: No puedo parar, no voy a parar
		Tooltip: ¡Esta es la canción que nunca acaba...!
	}

	GlacialHarvester: {
		DisplayName: Cosechadora glacial
		Tooltip:
			'''
			Mantén pulsado <left> para hacer girar la guadaña
			Pulsa <right> para asestar un golpe con la guadaña y lanzar una enorme ola de hielo
			Inflige [rbuff:Frostburn]
			'''
