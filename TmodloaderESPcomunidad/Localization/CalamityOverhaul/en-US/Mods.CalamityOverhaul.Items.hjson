	InfiniteToiletItem: {
		OnlyZenithCondition: Only in Zenith World
		DisplayName: Infinite Toilet Item
		Tooltip: ""
	}
}

StormGoddessSpear: {
	DisplayName: Storm Goddess Spear
	Tooltip:
		'''
		A Spear capable of sending out Fierce Lightning Kisses that bounces off enemies.
		When held, summons the lingering spirit of the Storm Goddess to assist in combat.
		[legend]
		'''
	Legend:
		'''
		Alina was once Terra’s sharpest warrior, wielding a blade of thunder to cleave through darkness, 
		her faith unwavering and absolute. But faith could not shield her from the indifference of the gods.  
		When the Supreme Deity passed judgment, her comrades, kin, oaths, and glory were reduced to ashes. 
		She witnessed firsthand how so-called justice trampled everything into dust, how order was merely a veil for the cruelest of destructions.  
		She no longer sought the light but reforged herself in the abyss. An ancient, 
		forbidden power consumed her soul, granting her strength beyond mortal comprehension.  
		Her armor became wreckage forged in the depths, her eyes burned with the remnants of thunder and darkness entwined. 
		She was no longer Terra’s guardian, but the storm itself—a vengeance that could not be stopped.  
		Her fury swept the battlefield like a howling tempest, her thunder tore through thrones and temples. 
		She fought not for justice, not for Terra, not for the gods.  
		She fought for vengeance, for annihilation—to make those who deemed themselves righteous understand the true meaning of fear.
		'''
}

DragonsScaleGreatsword: {
	DisplayName: Dragon Kelp Greatblade
	Tooltip:
		'''
		Swings follow a three-hit combo, the third unleashing a mightier draconic finisher
		Swings release spiraling kelp blade beams that burst into toxic algae clouds on hit
		True melee strikes create many toxic algae clouds
		Right-click to summon a verdant dragon soul that hunts toward the cursor, scattering toxic algae clouds along its path
		'''
}

CosmicCalamity: {
	DisplayName: Galactic Disaster
	Tooltip: Attack generates crescent-shaped shock waves.
}

SpearOfLonginus: {
	DisplayName: Spear of Longinus
	Tooltip:
		'''
		While held, a holy cross forms beneath you and steadily fills with divine energy.
		Each time the bar is filled, the Spear gains one charge, up to a maximum of six fields of holy power.
		Marks the nearest enemy with the cross of fate while held.
		Striking a marked enemy with a charged throw unleashes the Pilgrim's Fury.
		[legend]
		'''
	Legend:
		'''

		O shattered god, permit me to atone for my sins. 
		The war has sprawled across centuries, and I, a fugitive fleeing the grand civilization,
		eke out a meager existence on this desolate planet at the edge of the universe.
		Thousands of light-years away, the colossal war machines of conflict grind stars to dust.
		Savage and dreadful assaults erase light-years of stellar expanse in the blink of an eye, transforming it into a domain of silence.
		For countless centuries, this war has raged on. Now, the mighty civilization to which I belong teeters on the brink,
		and I shall become a cosmic sinner, the most disrespectful blasphemer.
		My flesh has decayed, my bones mirroring the wrinkles of passing ages. 
		I am on the verge of becoming one of the feeble machines I created. 
		Before that fate befalls me, may the gods grant me forgiveness and pardon my disrespect towards this supreme being. 
		Let me descend into the abyss of purgatory, enduring endless torment as my soul falls.
		Yet, for the sake of my civilization, for victory in this war spanning centuries, I must harness the fragmented power of this godly entity.
		To guide its mysterious force, I have no choice but to infuse its shattered divine form with the cold embrace of machinery.
		This is an inevitable sacrilege. For the continuity of civilization, for the triumph of war, 
		I must become the most devout follower of this supreme entity, the most disrespectful blasphemer in history.
		'''
}

BloodAltar: {
	DisplayName: Blood Altar
	Tooltip:
		'''
		Right click on the Altar to summon the Blood Moon
		Automatically collects dropped blood orbs from around the world and stores them in the nearest storage bin.
		"Let the world be wreathed by Crimson."
		'''
}

BarrenBow: {
	DisplayName: Barren Bow
	Tooltip: The arrows fired will burst out a barren current when they hit the enemy
}

ElementMuzzleBrake: {
	DisplayName: Element Muzzle Brake
	Tooltip:
		'''
		Increases ranged damage by 12%
		Increases ranged critical strike chance by 15%
		Increases ranged firing speed by 12%
		Enemies have a harder time detecting you
		'''
}

EyeOfSingularity: {
	DisplayName: Eye of Singularity
	Tooltip:
		'''
		Increases ranged damage by 100%
		Increases ranged critical strike chance by 100%
		Increases ranged firing speed by 100% and prevents ammo consumption
		Sets the critical damage multiplier for all ranged weapons to 500%
		Your ranged projectiles tear through space, creating miniature black holes on impact that drag in and crush enemies
		While standing still, you enter the 'Event Horizon' state:
		  - Grants invisibility and immunity to all contact damage
		  - Attacks release additional Gamma Ray Bursts that track enemies
		Grants the ability to Quantum Leap; press [KEY] to teleport to the cursor, erasing enemy projectiles along the path
		Right-click to activate 'Collapse Protocol':
		  - Consumes all mana to make all ranged attacks ignore immunity frames and force critical hits for 10 seconds
		  - 60 second cooldown
		If you receive fatal damage, you become a Supernova, dealing extreme area damage, and reform at a safe location after 3 seconds
		This effect has a 60 second cooldown
		[c/33ff33:"The slumbering Dragon God jacks into your nerves, deconstructing the Machine Spirit's basal logic"]
		[c/ffaa00:"A ravenous constellation devours your muzzle flash, draining the final warmth of dying stars"]
		[c/00ffff:"The formless Reaper becomes your shadow, harvesting the equal, inevitable doom of all sentient life"]
		'''
}

ArcaneThroneOfEternity: {
	DisplayName: Arcane Throne of Eternity
	Tooltip:
		'''
		Increases magic damage by 100%
		Increases magic critical strike chance by 100%
		Increases magic attack speed by 100%
		Increases maximum mana by 1000; mana regeneration is greatly boosted and never interrupted
		All magic projectiles gain infinite piercing
		Your magic attacks tear through the veil of reality, opening continuously erupting Arcane Rifts on impact
		All magic attacks inflict a random forbidden curse:
		  Void Erosion, Temporal Stasis, Soul Burning, Gravitational Collapse, or Hyper Disintegration
		While above 90% mana, you enter the 'Omniscience' state:
		  All magic projectiles automatically home in on enemies, and critical damage multiplier rises to 1000%
		Grants the ability of Truth Leap; press [KEY] to tear open space and enter a higher dimension:
		  Become immune to all damage and move freely for a short time, unleashing a devastating Reality Tremor upon leaving
		  30 second cooldown
		Right-click to activate 'Root Calculation':
		  For the next 10 seconds, every magic attack simultaneously releases 5 mirrored spells
		  60 second cooldown
		If you receive fatal damage, time rewinds to your state from 5 seconds ago, restoring your life, mana and position
		This effect has a 60 second cooldown
		Enemies are more likely to target you
		[c/b84dff:"A nameless sage peels open your skull, inscribing forgotten truths beyond the stars"]
		[c/ffdd66:"The Lord of Flux plucks the warp and weft of fate, treating reality as an unfinished draft"]
		[c/66ffff:"The corpse upon the golden throne gazes at you, having long forgotten what death is"]
		'''
}

