	Tooltip:
		'''
		Requires electrical energy to operate
		Right-click after placing on the ground to switch between attack mode and guard mode
		In attack mode, it emits electric arcs to nearby enemies
		In guard mode, it inflicts an electrified debuff on all enemies within range; if a player is within range
		and holding a chargeable item, the electromagnetic tower will emit electric arcs to remotely charge the player
		"Engineers, stay away"
		'''
}

EmblemOfDread: {
	DisplayName: Emblem of Dread
	Tooltip:
		'''
		Increases melee damage by 100%
		Increases melee critical strike chance by 100%
		Increases melee speed by 100%
		Increases defense by 100, ignoring all defense damage and reduction
		Reduces incoming damage by 75% and reflects 100x damage back to the attacker
		All melee attacks inflict the 'Void Erosion' debuff
		True melee attacks have a chance to instantly erase enemies with less than 250,000 HP
		Moving at high speeds leaves warp points in your path, dealing extreme damage to enemies
		Grants the ability to use Gravity Dash; press [KEY] to dash a long distance and release massive gravitational rays
		If you receive fatal damage, you immediately regain full HP and gain a Gravity Shield (60 second cooldown)
		Enemies are more likely to target you
		[c/d94fff:"A sanctified angel veils your gaze, whispering eternal, saccharine lies"]
		[c/ff4d4d:"A blood-soaked butcher raises your twin blades, declaring that only slaughter brings glory"]
		[c/4da6ff:"An azure dove pecks through your brow, mocking your insignificant struggle"]
		'''
}

ElectricMinRocket: {
