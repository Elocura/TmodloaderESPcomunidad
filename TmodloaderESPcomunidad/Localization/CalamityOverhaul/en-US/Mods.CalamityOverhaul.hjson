# For Language Pack Creators:
# The keys here were previously in Items. Since EcTypeItem has been removed, all localization keys similar to "ItemNameEcType" have been moved here.
# The corresponding format is "ItemNameEcType" → "RItemName" or "ItemNameOverride".
# Apart from the class name change, the DisplayName and Tooltip remain the same as in the previous version.
# So if you need to migrate your language pack to the new version, simply copy and paste the entries here and update the class names accordingly.

Arcanes: {
	Items: {
		ArcaneTransformer: {
			DisplayName: Arcane Transformer
			Tooltip: ""
		}
	}
}

Resurrections: {
	ResurrectionDeath: {
		DeathText: "{0} died from Abyssal Resurrection"
		WarningCombatText: The Abyss is consuming you...
		DeathNoticeText: You were consumed by the Abyss...
		MarkRemainText: The mark of the Abyss still entwines you...
		RetainValueFormat: Resurrection Value: {0}%
	}
}

QuickHack: {
	SynapseBurn: {
		DisplayName: Synapse Burnout
		Description: Overloads the target's neural synapses, dealing continuous thermal damage.
	}

	ShortCircuit: {
		DisplayName: Short Circuit
		Description: Releases an EMP causing instant damage and brief paralysis.
	}

	Cyberpsychosis: {
		DisplayName: Cyberpsychosis
		Description: Drives the target into a frenzy, attacking all nearby units.
	}

	SystemReset: {
		DisplayName: System Reset
		Description: Forces a system reboot on the target, completely paralyzing them.
	}

	OpticOverload: {
		DisplayName: Optic Overload
		Description: Blinds the target, making them unable to perceive their surroundings.
	}

	MemoryWipe: {
		DisplayName: Memory Wipe
		Description: Clears the target's hostility data, resetting their aggro list.
	}

	Contagion: {
		DisplayName: Contagion
		Description: Implants a self-replicating malware that spreads to nearby targets.
	}

	TileDetonate: {
		DisplayName: Tile Detonation
		Description: Compromises structural integrity, triggering a localized explosion.
	}

	TilePhase: {
		DisplayName: Phasing Protocol
		Description: Alters the physical properties of a tile, making it intangible for a duration.
	}

	TileMagPull: {
		DisplayName: Magnetic Pull
		Description: Generates a magnetic field, pulling nearby dropped items towards you.
	}

	MachineShortCircuit: {
		DisplayName: Machine Short Circuit
		Description: Drains the target machine's energy, releasing electric arcs that damage nearby entities.
	}

	TurretHijack: {
		DisplayName: Turret Hijack
		Description: Tampers with the IFF recognition module, temporarily flipping the turret's friend-or-foe identification.
	}

	FalseMemory: {
		DisplayName: False Memory
		Description: Implants false memories, causing a brief interruption in pursuit or suppressing their killing pattern.
	}

	SelfDismember: {
		DisplayName: Self-Dismemberment
		Description: Forces the paranormal entity to dismember itself.
	}

	SystemHalt: {
		DisplayName: System Halt
		Description: Causes the target to briefly fall silent and cease all activities.
	}

	TurretCircuitOverload: {
		DisplayName: Circuit Overload
		Description: Injects reverse current into the turret's power circuit, completely disabling it for a long duration.
	}

	TurretShortCircuit: {
		DisplayName: Turret Short Circuit
		Description: Instantly discharges the turret's energy to briefly stall it, immediately coming back online after recovery.
	}

	VirusBroadcast: {
		DisplayName: Virus Broadcast
		Description: Injects worm code into the signal tower, causing it to emit cyber EMP waves that short-circuit all turrets within broadcast range for a long duration.
	}
}

