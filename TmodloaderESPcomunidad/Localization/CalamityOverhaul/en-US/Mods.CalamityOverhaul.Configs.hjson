CWRServerConfig: {
	DisplayName: Content Config

	WeaponOverhaul: {
		Label: Weapon Overhaul
		Tooltip:
			'''
			Enabling it will modify most weapons.
			[c/FF0000: If you want the best Calamity Overhaul experience, please enable it!]
			'''
	}

	ScreenVibration: {
		Label: Weapon Screen Vibration
		Tooltip: If turned on, the screen will vibrate during some attacks, which may make the hit feel more intense
	}

	MurasamaSpaceFragmentationBool: {
		Label: Murasama Finisher Screen-Shatter Effect
		Tooltip:
			'''
			Enabled by default. When Murasama performs its finisher, it creates a screen-shatter effect to enhance the impact.
			If disabled, these effects are turned off.
			'''
	}

	DomainConciseDisplay: {
		Label: Domain Minimal Display
		Tooltip: Off by default. When enabled, most visual effects within the domain will be hidden.
	}

	Headers: {
		CWRSystem: System Configs
		CWRWeapon: Weapon Configs
		CWRUI: UI Configs
		CWRWorldGen: World Gen Configs
	}

	LensEasing: {
		Label: Lens Easing
		Tooltip: When enabled, long distance rapid displacement will slow the lens, which avoids the feeling of being moved too fast
	}

	BiologyOverhaul: {
		Label: Biology Overhaul [c/06e33f:(Experimental)]
		Tooltip:
			'''
			[c/c20909:Unfinished]
			Enabled by default, this will modify the AI behavior of certain creatures, such as Boss AI in Death Mode.
			This might significantly increase the game's difficulty, so you can choose to disable it based on your personal preference.
			'''
	}

	MuraUIStyleType: {
		Label: Mura UI Style Selection
		Tooltip:
			'''
			Style 1: Refined - Floating Above The Head
			Style 2: Refined - Compact
			Style 3: Classic - Floating Above The Head
			Style 4: Classic - Compact
			Style 5: Hidden
			'''
	}

	MuraPosStyleType: {
		Label: Mura UI Position Selection
		Tooltip:
			'''
			Preset 1: Bottom Right
			Preset 2: Bottom Left
			Preset 3: Top Center
			'''
	}

	QuestLog: {
		Label: Quest Log Guidance
		Tooltip:
			'''
			When enabled, the quest log will guide you through game progression
			You can access the quest interface via the Quest Book item, inventory UI, or a hotkey to view current quests
			Enabled by default. Disabling this removes all quest guidance
			'''
	}

	DialogueBox_Scale_Value: {
		Label: Dialogue Box Scale
		Tooltip: Adjusts the overall size of the dialogue box
	}

	GenWindGrivenGenerator: {
		Label: Generate Wind-Driven Generator
		Tooltip: Places wind-powered generator structures throughout the world.
	}

	GenWGGCollector: {
		Label: Generate Scavenger Outposts
		Tooltip: Randomly spawns hostile scavenger structures throughout the world. This setting only takes effect in Legendary worlds.
	}

	GenJunkmanBase: {
		Label: Generate Junkman's Base
		Tooltip: Spawns a scavenger stronghold base in wastelands or underground.
	}

	GenRocketHut: {
		Label: Generate Rocket Hut
		Tooltip: Generates a mysterious shack containing rocket components or technological relics.
	}

	GenSylvanOutpost: {
		Label: Generate Sylvan Outpost
		Tooltip: Spawns wooden elven or forest guardian outposts deep within the forest.
	}

	ConfigChangePrefix: User
	ConfigChangeSuffix: modified the server configuration
}
