	TextPanelIntroTitle: Commission Instructions
	TextRightClickLabel: Right-click a commission entry
	TextRightClickAction: " →  Track Commission"
	TextRightClickDesc: "     The tracker window on the left will continuously display quest progress"
	TextMiddleClickLabel: Middle-click a commission entry
	TextMiddleClickAction: " →  Suspend Commission"
	TextMiddleClickDesc: "     Temporarily hides the commission, removing it from the tracker window"
	TextStyleButtonTitle: Style Button Hint
	TextStyleButtonLabel: Left-click the small button at the top
	TextStyleButtonAction: " →  Toggle UI Style"
	TextStyleButtonDesc: "     Cycles between Desert, Draedon, and Forest UI styles"
	TextConfirmBtn: Understood
	TextTrackPromptTitle: Track Commissions of Interest
	TextTrackPromptHintLabel: Right-click a commission
	TextTrackPromptHintAction: " →  Set to Tracked"
	TextTrackPromptDesc: "     Tracked commissions will be pinned to the tracker on the left side of the screen for easy progress monitoring"
	TextTrackPromptNextBtn: Next
	TextTrackerIntroTitle: Commission Tracker
	TextTrackerIntroLine1: The tracker on the left side of the screen persistently displays all tracked commissions
	TextTrackerIntroLine2: Hold Left-click to drag and adjust its vertical position
	TextTrackerIntroLine3: The tracker automatically collapses when the Commission Manager is open to prevent obstructing your view
	TextTrackerIntroNextBtn: Next
	TextSuspendIntroTitle: Suspend Unwanted Commissions
	TextSuspendIntroHintLabel: Middle-click a commission
	TextSuspendIntroHintAction: " →  Suspend Commission"
	TextSuspendIntroDesc1: "     Suspended commissions will not appear in the tracker on the left, perfect for shelving them temporarily"
	TextSuspendIntroDesc2: "     You can find them in the Suspended tab to restore tracking"
}

AbandonedPortalStrings: {
	Title: Abandoned Portal Console
	BrokenSubtitle: Structure Fractured · Core Offline
	RepairingSubtitle: Auto-Repair Sequence Running
	RepairedSubtitle: Channel Stable · Void Coordinates Available
	BrokenBody: Faint subspace echoes still linger within the broken door frame. Once auto-repair is initiated, the portal will rebuild its positioning ring within minutes.
	RepairingBody: Nano-welds are reconstructing the rift restrainer. Please keep the surrounding area stable and wait for calibration to complete.
	RepairedBody: The portal has completed its auto-repair. The teleportation sequence will initiate a rift event before sending you into the Void.
	StartRepair: ▷ Initiate Auto-Repair
	Teleport: ▷ Initiate Teleport
	Close: ✕ Close
	ProgressFormat: Repair Progress {0}%
	StatusBroken: STATUS  ▌ OFFLINE
	StatusRepairing: STATUS  ▌ CALIBRATING
	StatusRepaired: STATUS  ▌ ONLINE
	DiagnosticHeader: "[DIAG]"
	DiagnosticBroken: ERR-0xC4: Positioning Ring Fractured / Main Power Loop Disconnected
