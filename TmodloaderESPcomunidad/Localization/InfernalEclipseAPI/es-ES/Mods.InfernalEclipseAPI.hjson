	AngelDyeItem: {
		DisplayName: Tinte angelical
		Tooltip: ""
	}

	ArkangelDyeItem: {
		DisplayName: Tinte de Arcangel
		Tooltip: ""
	}

	The454CasullandTheJackal: {
		DisplayName: .454 Casull y El Chacal
		Tooltip:
			'''
			Al disparar cualquiera de las dos armas, se intercambiarán los dos primeros tipos de munición de tus ranuras de munición
			Pulsa <left> para disparar con El Chacal, una pistola de baja cadencia de tiro diseñada para infligir daño a un único objetivo
			El Chacal convertirá las balas de mosquete en balas de alta velocidad
			Pulsa <right> para disparar con la .454 Casull, una pistola de alta cadencia de disparo diseñada para enfrentarse a grupos de enemigos
			La .454 Casull convertirá las balas de mosquete en disparos meteóricos
			Las balas infligen [cbuff:CalamityMod/Laceration] y arrancan orbes de sangre de los objetivos al impactar
			Recoger estos orbes de sangre reduce la duración de [cbuff:PotionSickness]
			[c/7C0A02:«Incluso Jesús lloró...»]
			[c/aaaaaa:Pulsa Mayús + <right> sobre este objeto en tu inventario para activar el] [i:EndlessMusketPouch] [c/aaaaaa:cambio de munición]
			'''
	}

	RuinousPlasmaInjection: {
		DisplayName: Inyección de plasma devastadora
		Tooltip:
			'''
			Aumenta de forma permanente el nivel máximo de vacío en 10 y la velocidad de regeneración del vacío en un 1%
			Se puede usar 5 veces
			'''
	}

	FinalFractalMusicBox: {
		DisplayName:  Caja de música (Espada Terra)
		Tooltip: Reproduce "FINAL FRACTAL" de ENNWAY
	}

	CragmawMireRelic: {
		DisplayName: Reliquia infernal de las Fauces Agrietadas
		Tooltip: "{0}"
	}

	IllusionistRelic: {
		DisplayName: Reliquia infernal del Ilusionista
		Tooltip: "{0}"
	}

	Catlight: {
		DisplayName: Luz de gato
		Tooltip:
			'''
			'¿Te parecen demasiado difíciles los jefes? ¡Pues cómprate la Luz de gato de Catlight Industries!'
			[c/7C0A02:Compra nuestro producto ahora]
			'''
	}

	AlloyofEden: {
		DisplayName: Aleación del Edén
		Tooltip: Una aleación compuesta por los materiales más resistentes de múltiples universos
	}

	SolynsSpellbook: {
		DisplayName: El libro de hechizos de Solyn
		Tooltip:
			'''
			Un libro que apareció en la antigua tienda de Solyn tras la derrota de la Deidad Sin Nombre y la finalización de su estantería
			Las páginas del libro están repletas de diagramas muy detallados de numerosos artefactos mágicos
			Si recoges este objeto o lo guardas en tu inventario, desbloquearás nuevas recetas de forma permanente
			'''
	}

	TheChickenWing: {
		DisplayName: La alita de pollo
		Tooltip:
			'''
			Inflige [cbuff:Oiled] a los enemigos
			Cuanto mejor te alimentes, más fuerza tendrás
			Derrotar a los enemigos otorga temporalmente [cbuff:HeartyMeal]
			"No es la parte que estás pensando."
			'''
	}

	WulfrumMothershipRelic: {
		DisplayName: Reliquia infernal de la Nave nodriza de wulfrum
		Tooltip: "{0}"
	}

	SoulDrivenHeadphonesEclipse: {
		DisplayName: Cascos "Soul-Driven" (Edición Eclipse)
		Tooltip:
			'''
			Te permite elegir y reproducir música personalizada de Infernal Eclipse of Ragnarok, así como otros temas únicos
			Al sostenerlos, sientes vagamente una presencia de otro mundo
			También puedes oír los sonidos de instrumentos que tocan con pasión
			'''
	}

	SplitFirebrand: {
		DisplayName: División incendiaria
		Tooltip: ""

		Progression: {
			Skeletron:
				'''
				Este látigo llameante que has creado quema tanto el hierro como a los enemigos
				Sin embargo, fue el potencial de arder con más intensidad y vencer la maldición de la mazmorra lo que avivó el fuego
				'''
			WoF:
				'''
				Una chispa se ha hecho más grande, volviéndose incontrolable
				Queda mucho más por incendiar... Derriba la puerta del inframundo para avivar el fuego
				'''
			Mechs:
				'''
				Cuando el fuego se vuelve más voraz, no se calma de repente; aún queda mucho por alcanzar y mucho más por convertir en cenizas
				Derrite a los supervisores de metal para avivar el fuego.
				'''
			Plantera:
				'''
				¿Lo sientes? Tus manos arden, el sudor se convierte en vapor... Pero tiene que arder aún más
				Derrota al Depredador de la Selva para avivar el fuego.
				'''
			Golem:
				'''
				Incluso cuando te mueves, puedes sentir cómo el fuego baila sobre tu piel, una danza mortal, pero no por ello menos hermosa
				Derrota al guardián del Templo Lizhard
				'''
			MoonLord:
				'''
				Ataca una y otra vez, no pares nunca hasta que las llamas alcancen las estrellas
				Golpea al heraldo de la luna para avivar el fuego
				'''
			Full:
				'''
				Se ha desbloqueado un nuevo potencial, algo que estaba realmente oculto para la mayoría, pero que tú has logrado descubrir
				Su evolución ha concluido, pero la tuya no; sigue adelante, aunque tengas que descartarlo
				'''
		}

		TagDebuff: {
			Skeletron:
				'''
				2 de daño de la etiqueta de invocación
				Cada tercer golpe hará que el látigo se extienda hacia fuera, infligiendo 1,5 veces más daño.
				Inflige [iebuff:InfernalEclipseAPI/SoulBurn] para incinerar a los enemigos
				'''
			WoF:
				'''
				4 de daño de la etiqueta de invocación
				Cada tercer golpe hará que el látigo se extienda hacia fuera, infligiendo 1,5 veces más daño.
				Inflige [iebuff:InfernalEclipseAPI/SoulBurn] para incinerar a los enemigos
				'''
			Mechs:
				'''
				5 de daño de la etiqueta de invocación
				Cada tercer golpe hará que el látigo se extienda hacia fuera, infligiendo 1,5 veces más daño.
				Inflige [iebuff:InfernalEclipseAPI/SoulBurn] para incinerar a los enemigos
				¡Los súbditos que toquen el látigo arderán en llamas!
				Los súbditos en llamas infligen 1,05 veces más daño y causan [iebuff:OnFire3]
				'''
			Plantera:
				'''
				7 de daño de la etiqueta de invocación
				Cada tercer golpe hará que el látigo se extienda hacia fuera, infligiendo 1,5 veces más daño.
				Inflige [iebuff:InfernalEclipseAPI/SoulBurn] para incinerar a los enemigos
				¡Los súbditos que toquen el látigo arderán en llamas!
				Los súbditos en llamas infligen 1,05 veces más daño y causan [iebuff:OnFire3]
				Pulsa {0} para lanzar una oleada de fuego con un tiempo de enfriamiento de 1 minuto
				'''
			Golem:
				'''
				10 de daño de la etiqueta de invocación
				Cada tercer golpe hará que el látigo se extienda hacia fuera, infligiendo 1,5 veces más daño.
				Inflige [iebuff:InfernalEclipseAPI/SoulBurn] para incinerar a los enemigos
				¡Los súbditos que toquen el látigo arderán en llamas!
				Los súbditos en llamas infligen 1,15 veces más daño y causan [iebuff:OnFire3]
				Pulsa {0} para lanzar una oleada de fuego con un tiempo de enfriamiento de 1 minuto
				Cada golpe que acierte al primer enemigo otorgará al usuario una acumulación de [iebuff:InfernalEclipseAPI/HotHands]
				'''
			MoonLord:
				'''
				12 de daño de la etiqueta de invocación
				Cada tercer golpe hará que el látigo se extienda hacia fuera, infligiendo 1,5 veces más daño.
				Inflige [iebuff:InfernalEclipseAPI/SoulBurn] para incinerar a los enemigos
				¡Los súbditos que toquen el látigo arderán en llamas!
				Los súbditos en llamas infligen 1,3 veces más daño y causan [iebuff:OnFire3]
				Pulsa {0} para lanzar una oleada de fuego con un tiempo de enfriamiento de 1 minuto
				Cada golpe que acierte al primer enemigo otorgará al usuario una acumulación de [iebuff:InfernalEclipseAPI/HotHands2]
				'''
			Full:
				'''
				20 de daño de la etiqueta de invocación
				Cada tercer golpe hará que el látigo se extienda hacia fuera, infligiendo 1,5 veces más daño.
				Inflige [iebuff:InfernalEclipseAPI/SoulBurn] para incinerar a los enemigos
				¡Los súbditos que toquen el látigo arderán en llamas!
				Los súbditos en llamas infligen 1,35 veces más daño y causan [iebuff:OnFire3]
				Pulsa {0} para lanzar una oleada de fuego con un tiempo de enfriamiento de 1 minuto
				Cada golpe que acierte al primer enemigo otorgará al usuario una acumulación de [iebuff:InfernalEclipseAPI/HotHands2]
				'''
		}

		Lore:
			'''
			'Cuando Dylan llegó por primera vez, parecía que se había traído algunas armas de su mundo natal'
			'Fueron utilizados por quienes se oponían al gobierno tiránico de aquellos cuyo poder era comparable al de Dios.'
			'Ahora que has conseguido hacer una de estas manualidades, quizá acabe convirtiéndose en algo maravilloso.'
			'''
	}

	//Localization Team: do not change [ieconstruct:ChaosConstruct], as it is replaced with a colored version using the Name perameter below.
	ChaosLure: {
		DisplayName: Cebo del caos
		Tooltip:
			'''
			Un señuelo electromagnético sobrecargado de energía caótica
			Atrae a un [IELuxTag:ChaosConstruct]
			No se consume
			'''
		Name: Construcción del caos
	}
}

