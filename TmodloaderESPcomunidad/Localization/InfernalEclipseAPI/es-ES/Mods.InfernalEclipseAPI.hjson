DiaryTooltip:
	'''
	[c/E3AF40:Un misterioso diario que no lleva firma...]
	[c/BEBEBE:Pulsa "Shift izquierdo" para abrir el diario]
	'''
BullyingTooltip:
	'''
	Aumenta el daño de la mayoría de los ataques que no son de invocación en un 2% por cada ranura de súbdito sin usar
	Reduce el daño de invocación en un 10% por cada ranura de súbdito utilizada.
	Los látigos ahora se ajustan a tus bonificaciones de combate cuerpo a cuerpo en lugar de a las bonificaciones de invocador
	Aumenta el daño de los látigos en un 25% y su alcance en un 50%
	[c/E3AF40:Una nota de papel con un microchip incorporado, diseñado por Dylan]
	[c/BEBEBE: Pulsa "Shift izquierdo" para leer lo que pone en el reverso de la nota]
	'''

Configs: {
	InfernalConfig: {
		WrathoftheGodsBossesInBossRush: {
			Tooltip: Añade a XG-07 Mars, el Avatar del Vacío, y a la Deidad Sin Nombre al Boss Rush.
			Label:Ira de los Dioses en el Boss Rush
		}

		BetsyInBossRush: {
			Tooltip: Añade a Betsy al Boss Rush - ACTUALMENTE CON ERRORES
			Label: Betsy en el BossRush
		}

		DreadnautillusInBossRush: {
			Tooltip: Añade al Nautilus del terror al Boss Rush
			Label: Nautilus del terror en el Boss Rush
		}

		Headers: {
			BossRushChanges: Opciones del Boss Rush
			BalanceChanges: Cambios en el equilibrio
			Miscellaneous: Miscelaneos
			MultiplayerAdjustments: Ajustes y utilidades para Multijugador
			Main: Main
			Secret: Ajustes experimentales y configuraciones secretas
			Music: Opciones de música
			CompatibilityChanges: Cambios en la compatibilidad
		}

		ThoriumBalanceChangess: {
			Tooltip:
				'''
				Modifica Thorium y varios objetos complementarios relacionados con Thorium para que se ajusten al equilibrio de Calamity.
				[c/FFFF00:El paquete de mods de The Infernal Eclipse of Ragnarok está pensado para mantener esta opción ACTIVADA]
				'''
			Label: Cambios en el balance de Thorium
		}

		CalamityRecipeTweaks: {
			Tooltip: Modifica algunas recetas de Calamity y elimina la mayoría de las recetas de vanilla relacionadas con la calidad de vida
			Label: Ajustes en las recetas de Calamity
		}

		CalamityBalanceChanges: {
			Tooltip:
				'''
				Modifica Calamity y varios objetos complementarios de Calamity que están infravalorados o sobrevalorados.
				Además, ajusta algunas recetas de mods cruzados para mantener el balance.
				[c/FFFF00:El paquete de mods de The Infernal Eclipse of Ragnarok está pensado para mantener esta opción ACTIVADA]
				'''
			Label: Calamity Balance Changes
		}

		BossKillCheckOnOres: {
			Tooltip:
				'''
				Realiza cambios en ciertos objetos para que no se puedan obtener hasta alcanzar el nivel previsto
				Impide que se extraigan ciertos minerales y casillas hasta que derrotes a ciertos jefes
				[c/FFFF00:El paquete de mods de The Infernal Eclipse of Ragnarok está pensado para mantener esta opción ACTIVADA]
				'''
			Label: Mantener la progresión de Calamity
		}

		VanillaBalanceChanges: {
			Tooltip:
				'''
				Modifica algunos objetos de vanilla para que estén balanceados con Calamity
				[c/FFFF00:El paquete de mods de The Infernal Eclipse of Ragnarok está pensado para mantener esta opción ACTIVADA]
				'''
			Label: Cambios en el balance de Vanilla
		}

		DisplayName: Main Config

		TerraBladeBossInBossRush: {
			Tooltip: Añade al jefe Espada Terra al Boss Rush
			Label: Espada Terra en el Boss Rush
		}

		InfernumModeForced: {
			Tooltip:
				'''
				Bloquea el control de dificultad de Calamity, incluso fuera de los combates contra jefes
				Asegúrate de establecer la dificultad antes de activar esta configuración
				Resulta útil para servidores en los que no se desea que se modifique la dificultad
				'''
			Label: Bloquear control de dificultad
		}

		SOTSBalanceChanges: {
			Tooltip:
				'''
				Modifica los objetos de Secrets of the Shadows para que estén balanceados con Calamity
				[c/FFFF00:El paquete de mods de The Infernal Eclipse of Ragnarok está pensado para mantener esta opción ACTIVADA]
				'''
			Label: Cambios en el balance de SOTS
		}

		ConsolariaBalanceChanges: {
			Tooltip:
				'''
				Modifica los objetos de Consolaria para que para que estén balanceados con Calamity
				[c/FFFF00:El paquete de mods de The Infernal Eclipse of Ragnarok está pensado para mantener esta opción ACTIVADA]
				'''
			Label:  Cambios en el balance de Consolaria
		}

		InfernumRecipeTweaks: {
			Tooltip:
				'''
				Modifica algunas recetas de Infernum.
				[c/FFFF00:El paquete de mods de The Infernal Eclipse of Ragnarok está pensado para mantener esta opción ACTIVADA]
				'''
			Label: Ajustes en las recetas de Infernum
		}

		ForceFullXerocDialogue: {
			Label: Forzar diálogo completo de Xeroc
			Tooltip: Obliga al juego a mostrar el diálogo completo de Xeroc al iniciar el Boss Rush y al superarlo. Resulta útil para los servidores.
		}

		SOTSThrowerToRogue: {
			Tooltip: Convierte los objetos de vacío + arrojador de SOTS Bard, Thrower, and Healer en objetos vacío + rogue
			Label: Fusiona las clases Arrojador + Vacio y Rogue
		}

		DisableBloodOrbPotions: {
			Tooltip: Desactiva las recetas de elaboración de pociones que utilizan orbes de sangre
			Label: Desactivar las pociones de orbes de sangre
		}

		PreventBossCheese: {
			Tooltip: Añade algunas mecánicas al juego que impiden que se utilicen ciertas estrategias para derrotar fácilmente a ciertos jefes.
			Label: Evitar los exploits contra los jefes
		}

		DisableUnfinisedContent: {
			Label: Desactivar contenido sin terminar
			Tooltip: Desactiva cualquier contenido sin terminar de los mods para mantener una experiencia de juego coherente.
		}

		DisableDuplicateContent: {
			Label: Desactivar el contenido duplicado
			Tooltip: Desactiva cualquier contenido duplicado que puedan añadir dos mods.
		}

		AdditonalVanillaBossAdjustments: {
			Label: Ajustes adicionales para los jefe de Vanilla
			Tooltip:
				'''
				Ajusta ligeramente las estadísticas de algunos jefes del juego base para que supongan un mayor desafío.
				Esta configuración no elimina ningún cambio en la IA exclusivo del modo Ragnarok que se haya añadido a los jefes del juego base.
				[c/FFFF00:El paquete de mods de The Infernal Eclipse of Ragnarok está pensado para mantener esta opción ACTIVADA]
				'''
		}

		MergeCraftingTrees: {
			Label: Fusionar árboles de creación
			Tooltip:
				'''
				Combina los árboles de fabricación de objetos similares de varios mods y añade materiales de fabricación de otros mods a determinados objetos.
				[c/FFFF00:El paquete de mods de The Infernal Eclipse of Ragnarok está pensado para mantener esta opción ACTIVADA]
				'''
		}

		BloodOrbPotionDuplication: {
			Label: Duplicación de la poción de orbe de sangre
			Tooltip: Sustituye las recetas de pociones del Orbe de Sangre por recetas de duplicación.
		}

		ChanageWeaponClasses: {
			Label: Cambiar las armas de clase
			Tooltip: Cambia la clase de algunas armas para aportar más variedad o para que tenga más sentido dentro contexto de la arma.
		}

		DisplayWorldEntryMessages: {
			Label: Mostrar mensajes al entrar a un mundo
			Tooltip: Activa/desactiva los mensajes al entrar en un mundo.
		}

		EnableInterlude4: {
			Label: Interludio 4
			Tooltip:
				'''
				Activa el tema del 4.º interludio. 
				Este interludio sonará una vez que se haya derrotado tanto a los Exo Mechas como a Calamitas Suprema.
				Esta canción sustituirá a "Their Fabricator" y "Acceptance" cuando se reproduzca.
				'''
		}

		AdjustAdvisorSpawnConditions: {
			Label: Ajustar las condiciones de aparición del Consejero
			Tooltip:
				'''
				Ajusta las condiciones de aparición del Consejero para que no esté siempre activo en el mundo.
				Resulta útil si utilizas la barra de jefes de Infernum y no quieres que esté siempre activa debido a que el Consejero permanece vivo en todo momento.
				Se sabe que esto causa problemas en el modo multijugador, así que desactívalo si tienes pensado jugar en ese modo.
				'''
		}

		MultiplayerBossRespawnTimer: {
			Label: Temporizador de reaparición de jefes en multijugador
			Tooltip:
				'''
				Determina cuánto tiempo tarda en reaparecer durante una batalla contra un jefe
				[c/FFFF00:El paquete de mods "The Infernal Eclipse of Ragnarok" está balanzeado en 60.]
				'''
		}

		MinimumDifficultyToPreventRespawns: {
			Label: Dificultad mínima para evitar reapariciones
			Tooltip: La dificultad mínima para aplicar el sistema de prevención de reaparición
		}

		MultiplayerRespawnsAllowed: {
			Label: Permitir las reapariciones en multijugador
			Tooltip:
				'''
				El número de reapariciones permitidas durante los combates contra jefes.
				[c/FFFF00: El paquete de mods "The Infernal Eclipse of Ragnarok" está balanceado en 1.]
				'''
		}

		NerfThoriumMulticlass: {
			Label: Nerfeo a las multiclases de Thorium
			Tooltip:
				'''
				Añade algunos sistemas para evitar que los bardos y los sanadores puedan elegir varias clases y se vuelvan demasiado poderosos.
				[c/FFFF00:El paquete de mods de The Infernal Eclipse of Ragnarok está pensado para mantener esta opción ACTIVADA]
				'''
		}

		ColoredRelics: {
			Label: Reliquias de coloreadas
			Tooltip: Activa o desactiva las reliquias de colores de este mod.
		}

		ForceMenu: {
			Label: Aplicar tema al menú
			Tooltip: Obliga a seleccionar el tema del menú "Infernal Eclipse of Ragnarok" al cargar el mod.
		}

		AutomatedConfigSetup: {
			Label: Configuración automática
			Tooltip: Configura automáticamente los ajustes de otros mods para que se adapten a "Infernal Eclipse of Ragnarok".
		}

		MoveDeerclopsChecklistEntry: {
			Label: Desplaazar la entrada del Ciervíclope del BossCheckList
			Tooltip: Mueve al Ciervíclope para que aparezca antes que ESqueletrón, para que coincida con la clasificación de Calamity e Infernum.
		}

		DontEnableThis: {
			Label: No actives esta opción
			Tooltip:
				'''
				No actives esta opción. Probablemente te dé una idea equivocada y provoque una jugabilidad desequilibrada y defectuosa.
				[c/7C0A02:TEl paquete de mods de The Infernal Eclipse of Ragnarok está pensado para mantener esta opción DESACTIVADA.]
				'''
		}

		CalamityExpertAccessories: {
			Label: Accesorios del modo experto de Calamity
			Tooltip: Activa o desactiva que ciertos botines de los jefes de Calamity sean de rareza experto.
		}

		ThereIsNoReasonDisableThis: {
			Label: No hay motivo para desactivar esto
			Tooltip:
				'''
				No hay motivo para desactivar esta opción, ya que desactiva los niveles de dificultad que presentan errores y están desequilibrados al combinarse con Infernum.
				Desactiva esta configuración solo si conoces las consecuencias, y no informes de errores con esta configuración desactivada.
				[c/FFFF00:El paquete de mods de The Infernal Eclipse of Ragnarok está pensado para mantener esta opción ACTIVADA]
				'''
		}

		DeveloperMode: {
			Label: Modo de desarrollador
			Tooltip: Activa o desactiva la disponibilidad de herramientas útiles para el desarrollo.
		}

		ForceRagnarokInfernumModeInSubworlds: {
			Label: Forzar los modos Ragnarok e Infernum en los submundos
			Tooltip:
				'''
				Activa automáticamente el modo Infernum o el modo Ragnarok en función de la dificultad predeterminada de tu mundo al entrar en un submundo.
				El modo Experto lo establece en Infernum; el modo Maestro, en Ragnarok.
				'''
		}

