	Lycanroc: {
		DisplayName: Lycanroc
		Tooltip: ""

		Progression: {
			WoF:
				'''
				Derrota al guardián del Infierno para conseguir más poder...
				No se ha obtenido ningún poder adicional...
				'''
			Mechs:
				'''
				Tras derrotar al Muro de Carne, las balas disparadas con esta arma infligen  [cbuff:CalamityMod/Crumbling]
				Derrota a las bestias mecánicas para obtener más poder...
				'''
			Plantera:
				'''
				Tras la derrota de las máquinas de Draedon, esta arma convierte las balas normales en balas de alta velocidad
				Derrota al guardián de la selva para obtener más poder...
				'''
			Golem:
				'''
				Tras la derrota de Plantera, tu ira hace que esta arma dispare a una velocidad increíble
				Derrota al constructo del Templo Lizhard para obtener más poder...
				'''
			Cultist:
				'''
				Tras derrotar a Golem, la adrenalina te garantizará golpes críticos
				Derrota al líder del antiguo culto para ganar más poder...
				'''
			MoonLord:
				'''
				Tras derrotar al cultista lunático, esta arma tiene ahora la posibilidad de infligir un supercrítico
				Derrota al cadáver sobrenatural para obtener más poder...
				'''
			Full:  ¡El Lycanroc se ha despertado por completo y ha desatado todo su poder!
		}

		Lore: "'¿Qué vas a hacer? ¿Matarme?'"
	}

	CelestialIllumination: {
		DisplayName: Iluminación celestial
		Tooltip: ""

		Progression: {
			Deus:
				'''
				Derrota al horror sobrenatural para ganar más poder...
				No se ha ganado ningún poder adicional...
				'''
			MoonLord:
				'''
				Tras la derrota del Señor de la Luna, tus estrellas se mueven más rápido
				Derrota a los guardianes de la llama profanada para obtener más poder...
				'''
			Providence:
				'''
				Tras derrotar a Providencia, tus ataques infligen [cbuff:CalamityMod/HolyFlames]
				Derrota a los centinelas del azote para obtener más poder...
				'''
			Polterghast:
				'''
				Tras derrotar a Polterghast, podrás lanzar un rayo celestial
				Derrota al Devorador de Dioses para obtener más poder...
				'''
			DoG:
				'''
				Tras la derrota del Devorador de Dioses, tu hogar estelar regresan al atacar
				Derrota al resplandeciente fénix para obtener más poder...
				'''
			Full: ¡La Iluminación celestial se ha despertado por completo y su verdadero poder ha salido a la luz!
			ProfanedGuardians:
				'''
				Tras derrotar a los Guardianes Profanados, podrás disparar un rayo celestial.
				Derrota a la Diosa del fuego para obtener más poder...
				'''
			Sentinels:
				'''
				Tras la derrota de los Centinelas, el rayo celestial dura más tiempo
				Derrota al Devorador de Dioses para obtener más poder...
				'''
		}

		Lore: El libro definitivo forjado por aquel que lleva la marca de Astra...
	}

