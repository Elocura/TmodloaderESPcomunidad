	PutridRelic:
		'''
		Aunque tu primer intento pueda llegar más lejos que el siguiente, lo que te llevó hasta ahí fue solo una reacción instintiva
		Elabora una estrategia, planifica tus movimientos, y el enemigo caerá ante tu destreza, no ante la suerte
		'''
	TurkorRelic:
		'''
		Subestimar a tu rival podría ser un error fatal
		Ojalá aprendas de ello durante el resto de tu viaje
		'''
	PyrogenRelic:
		'''
		La familiaridad es una herramienta útil
		No es raro que algunas batallas incluyan aspectos similares a los de otras
		Sigue adelante, es probable que vuelvas a utilizar estas habilidades
		'''
	SubspaceRelic:
		'''
		Has visto el círculo tal y como es: predecible, finito, estancado
		Cuando reconozcas su flujo, ten presente cada giro; 
		memoriza el patrón que ves ante ti
		Lo único que hace falta para escapar del círculo es desviar la línea en la dirección correcta
		Avanza y ábrete paso hacia el infinito.
		'''

	AstrageldonRelic: {
		Line1: Has has elegido un gran sufrimiento para ti mismo
		Line2: Aunque esta elección ha sido dolorosa y difícil en ocasiones,
		Line3: Las adversidades que superes darán frutos que merecerán la pena
	}

	PrimordialsRelic:
		'''
		Lo has hecho muy bien al derrotar Thorium. Solo quedan diez
		Recuerda que no debes obligarte a seguir adelante
		Tómate descansos cuando lo necesites; eso marcará una gran diferencia
		'''
	AvatarRelic:
		'''
		Lo has hecho muy bien.
		Ahora, busca el Terminus. Tu prueba final está a punto de comenzar
		'''
	GoozmaRelic:
		'''
		Es curioso, ¿verdad?
		Aunque hayas ganado al juego del infierno, sigues desafiando a seres superiores... 
		Algún día se te acabará la suerte
		'''
	NamelessRelic: Has pasado la prueba.
	NoxusRelic: ¿Te has saltado este objeto o es que de verdad tienes instalado mi mod tan poco conocido que ya no está en el Workshop? Sea como sea, supongo que enhorabuena
	DeviRelic:
		'''
		La más joven de los tres hermanos.
		Es bastante caótica, sobre todo a estas alturas del juego; sin embargo, la has vencido con confianza
		Disfruta de las mejoras de botín y del aumento de poder mientras puedas...
		'''
	AbomRelic:
		'''
		El segundo de los tres hermanos.
		Hace ya un tiempo que te enfrentaste a su hermana, pero esta batalla supone un salto cualitativo respecto a aquella
		¿Eres lo suficientemente valiente como para enfrentarte al hermano mayor?
		'''
	MutantRelic:
		'''
		El mayor de los tres hermanos, y también el más fuerte.
		Has derrotado a uno de los jefesde mods más difíciles que se conocen y, con toda la eternidad en tus manos, seguro que ahora nada te detendrá.
		¿Qué vas a buscar ahora?
		'''
	EridanusRelic:
		'''
		Ya casi has llegado a la meta.
		El ejército del Buscador de Dioses es lo único que se interpone entre tú y la eternidad
		Aprovecha al máximo tu nueva estación de creación...
		'''
	AstralCommunicatorInfernum1: Invoca a Astrageldon en la Infección astral
	AstralCommunicatorInfernum2: El slime interdimensional sigue teniendo hambre...
}

Lore: {
	DylanSoltan:
		'''
		Quienquiera que lea esta nota, ten en cuenta lo siguiente:
		Preveo que en el futuro aparecerá una persona llamada Soltan.
		Muchos pensarán que es un pesado, así que he diseñado este chipnote para que te sea útil
		Para contrarrestar su carácter molesto, el microchip adjunto a esta nota convertirá todo
		el poder de invocación local en energía para otras fuentes.
		Además, te da permiso total para molestar a Soltan.
		Solo he fabricado dos de estos y se los he entregado a los dos seres más poderosos que he podido encontrar.
		Si eres una de esas personas, o cualquier otra, utiliza este dispositivo con prudencia...
		'''
	MysteriousDiary:
		'''
		Al pasar a la primera página, no ves nada más que unas pocas palabras.

		"¿Quién demonios soy yo para seguir viviendo?"

		El resto de las páginas están en blanco...

		[c/E3AF40: El libro parece de otro mundo... quizá haya algo más grande que Yharim o incluso que la deidad misma ahí fuera.]

		–¡No te pierdas las novedades sobre el futuro de "Infernal Eclipse of Ragnarok"!–
		'''
}

LegendaryTooltip.Base: Esta arma puede ganar potencia a medida que derrotes a enemigos difíciles

Items: {
	SandstonePortalDevice: {
		DisplayName: Dispositivo de portal de arenisca
		Tooltip: ""
	}

	ChromaticMassInABottle: {
		Tooltip: "'Aunque KrogNar tramaba algo, Aaron no podía ignorar la presencia de esa energía.'"
		DisplayName: Masa cromática en una botella
	}

	Swordofthe14thGlitch: {
		DisplayName: La espada del Cenit
		Tooltip:
			'''
			Haz clic con derecho para lanzarte hacia el cursor y, al final, realizar un ataque giratorio que genera múltiples rayos de espada teledirigidos
			La decimocuarta forma del Cristal glicheado, empuñada por Zane Guritchi
			'''
	}

	BossRushTier6MusicBox: {
		Tooltip: Reproduce "Descent Of Divinities", de psykomatic
		DisplayName:  Caja de música (Boss Rush - Nivel 6)
	}

	NovaBomb: {
		DisplayName: Bomba Nova
		Tooltip:
			'''
			Canaliza algunas de las fuerzas más misteriosas del Viajero y desátalas en un ataque explosivo de gran área de efecto
			Haz clic derecho para cerrar el agujero negro antes de tiempo
			"No te preocupes, Willow, puedo con ello yo solo".
			'''
	}

	BossRushTierNamelessMusicBox: {
		Tooltip: Reproduce "TWISTED GARDEN [Remix]" de Kuudray
		DisplayName: Caja de música (Boss Rush - Nivel ???)
	}

	BossRushEncoreMusicBox: {
		Tooltip: Reproduce "Ensemble of Fools (Encore Mix)" de CDMusic
		DisplayName: Caja de música (Boss Rush - Bis)
	}

	StellarSabre: {
		DisplayName: Sable estelar
		Tooltip: ""

		Progression: {
			WoF:
				'''
				Derrota al guardián del Infierno para conseguir más poder...
				No se ha conseguido ningún poder adicional...
				'''
			Mechs:
				'''
				Tras derrotar al Muro carnoso, esta espada ahora lanza estrellas adicionales
				Derrota a las bestias mecánicas para ganar más poder...
				'''
			Plantera:
				'''
				Tras la derrota de las máquinas de Draedon, ahora inflige [cbuff:CalamityMod/AstralInfectionDebuff]
				Derrota al guardián de la selva para obtener más poder...
				'''
			Golem:
				'''
				Tras la derrota de Plantera, Las estrellas ahora dividen con un golpe
				Derrota al constructo del Templo Lizhard para ganar más poder...
				'''
			Cultist:
				'''
				Tras derrotar a Golem, las estrellas se lanzan contra los enemigos
				Ahora, las estrellas se dividirán al cabo de un tiempo.
				Derrota al líder del antiguo culto para obtener más poder...
				'''
			MoonLord:
				'''
				Tras derrotar al Cultista lunático, las estrellas explotan al cabo de un rato
				Derrota al cadáver sobrenatural para ganar más poder...
				'''
			Full:
				'''
				El Sable estelar se ha despertado por completo y todas sus habilidades se han potenciado aún más
                ¡Se ha desatado toda la potencia de este arma!
				'''
		}

		Lore: "'A pesar de todo lo ocurrido, todavía había una persona a la que Xander se negaba a atacar...'"
	}

	ExoSights: {
		DisplayName: Exo-visión
		Tooltip: ""
		SOTSBardHealerTooltip:
			'''
			Aumenta la probabilidad de golpe crítico en un 15%; no se acumula con las penalizaciones
			Los golpes críticos infligen hasta 40 puntos de daño adicionales y pueden hacer que los enemigos exploten, infligiendo el 100% del daño
			La bonificación de daño comienza en 15 y varía inversamente con la velocidad de uso del objeto
			Tu bonificación actual es {0}
			Los golpes críticos roban vida, regeneran el vacío, recuperan maná y devuelven inspiración.
			Al pulsar la tecla '{$ThoriumMod.Keybinds.AccessoryAbility.DisplayName}', obtendrás golpes críticos garantizados durante 10 segundos
			Durante el minuto siguiente, infligirás un 10% menos de daño
			Inmunidad a los efectos negativos de hemorragia y envenenamiento, y otorga visión nocturna
			'''
		ThoriumTooltip:
			'''
			Aumenta la probabilidad de golpe crítico en un 15%; no se acumula con las penalizaciones
			Los golpes críticos infligen hasta 40 puntos de daño adicionales, roban vida, regeneran el vacío, recuperan maná y pueden hacer detonar a los enemigos infligiendo un 100% de daño
			La bonificación de daño comienza en 15 y varía inversamente con la velocidad de uso del objeto
			Tu bonificación actual es {0}
			Al pulsar la tecla '{$ThoriumMod.Keybinds.AccessoryAbility.DisplayName}', obtendrás golpes críticos garantizados durante 10 segundos
			Durante el minuto siguiente, infligirás un 10% menos de daño
			Inmunidad a los efectos negativos de hemorragia y envenenamiento, y otorga visión nocturna
			'''
		DefaultTooltip:
			'''
			Aumenta la probabilidad de golpe crítico en un 1 %; no se acumula con las penalizaciones
			Los golpes críticos infligen hasta 40 puntos de daño adicionales y pueden hacer que los enemigos exploten, infligiendo un 100% de daño
			La bonificación de daño comienza en 15 y varía inversamente con la velocidad de uso del objeto
			Tu bonificación actual es {0}
			Los golpes críticos roban vida, regeneran el vacío y recuperan maná
			Inmunidad a los efectos negativos de hemorragia y envenenamiento, y otorga visión nocturna
			'''
		Lore: Después de que Erelian le quitara el Exo prisma a Draedon, por fin disponía de todo lo necesario para perfeccionar la IA espiritual de su traje, y ahora el tirano estaba por fin a su alcance.
	}

	Lore: {
		MysteriousDiary.DisplayName: Diario misterioso

		LorePolaris: {
			DisplayName: Polaris
			Tooltip: ""
			Lore:
				'''
				Cada vez que Draedon inventaba una nueva tecnología, la aplicaba a su pasión: fabricar máquinas de guerra letales.
				Esta fue una de sus primeras creaciones tras llegar a este planeta y ponerse a mi servicio, justo después de haber logrado la levitación estable para dotar de esa capacidad a sus máquinas.
				Aunque en aquel momento era una novedad, pronto se reveló como poco práctica para cualquier uso real en el campo de batalla.
				Por ello, ordené a Permafrost que se deshiciera de ella. Al parecer, en lugar de destruirla, la encerró en una prisión de hielo para toda la eternidad.
				Irónico, ¿verdad? El destino que imponemos a los demás a menudo se convierte en el nuestro.
				'''
		}

		LoreAdvisor: {
			DisplayName: El Consejero
			Tooltip: ""
			Lore:
				'''
				Durante sus primeros experimentos, en los que intentaba interactuar con los espíritus de la naturaleza que habitan estas tierras, contenerlos y aprovecharlos, 
				Draedon obtuvo pronto buenos resultados con los espíritus que deambulaban por la atmósfera superior de nuestro planeta.
				Los denominó espíritus de otro mundo en homenaje a sus orígenes y se propuso alcanzar metas más altas, creando un cuerpo más poderoso en el que un espíritu pudiera habitar, 
				pero el experimento salió mal y, al no tener otra opción, hizo que varias de sus otras creaciones lo mantuvieran cautivo y le drenaran constantemente su poder. 
				'''
		}

		LoreGlowmoth: {
			DisplayName: Polilla luminosa
			Tooltip: ""
			Lore:
				'''
				No es de extrañar que te encuentres a una de estas criaturas aquí.
				Las setas proporcionan energía a la polilla, y la polilla ayuda a propagarlas; todo en equilibrio, tal y como debe ser en la naturaleza...
				Aunque parece que hay cierta energía latente del vacío rodeando a la criatura.
				Qué... curioso.
				'''
		}

		LoreLux: {
			DisplayName: Lux
			Tooltip: ""
			Lore:
				'''
				Aunque el Sagrado cuenta con muchos defensores, los espíritus del caos no tienen rival.
				Ninguno de ellos se había debilitado lo suficiente como para poder utilizarlos de forma inteligente
				y Draedon acabó introduciéndolos en constructos con el único fin de contenerlos
				Teniendo esto en cuenta, resulta extraño que el Coleccionista volviera una vez más a absorber lo que quedaba de su energía tras su derrota.
				Qué curioso.
				'''
		}

		LorePharaoh: {
			DisplayName: Maldición del Faraón
			Tooltip: ""
			Lore:
				'''
				Cuando su hermana mayor —Otonilou, la diosa de la electricidad— encontró la muerte a manos de Calamitas,
				su hermano menor se vio obligado a gobernar Ilmeris por su cuenta.
				A diferencia de su hermana, que mató a un dragón para hacerse con su poder, su corazón era puro, aunque aún así tuvo un destino triste.
				Con su pueblo rodeado por todos lados por reinos liderados por cazadores de dragones con poderes robados, en su desesperación recurrió a esa magia del vacío.
				La intromisión de ese vacío le persigue incluso después de la muerte; él y su pueblo quedan atados a su tumba.
				Esto marca el comienzo de la verdadera caída de Ilmeris, en la que yo desempeñé un papel importante.
				'''
		}

		LorePutrid: {
			DisplayName: Pinky pútrido
			Tooltip: ""
			Lore:
				'''
				Uno de los experimentos de Draedon. 
				Esta criatura es uno de sus intentos por comprender la divinidad inherente que está presente en todos los slimes, 
				por minúscula que sea.
				Consiguió extraer con éxito la energía latente, pero, de alguna manera, durante el proceso, 
				le provocó a la criatura un hambre insaciable precisamente por los manís, lo que desencadenó un crecimiento rápido e incontrolable.
				Rápidamente se escapó de su recinto, y ya sabes cómo acabó todo.
				'''
		}

		LoreSerpent: {
			DisplayName: Serpiente del subespacio
			Tooltip: ""
			Lore:
				'''
				Existen leyendas sobre misteriosos seres con forma de serpiente que deambulan por el espacio entre dimensiones.
				Muchos dicen que son demasiado peligrosos como para enfrentarse a ellos en solitario,
				y que podrían matar a cualquiera en un instante con la energía del vacío que poseen.
				Este, sin embargo... es claramente un ejemplar joven.
				'''
		}

		LoreProvi: {
			DisplayName: El Radiante
			Tooltip: ""
			Lore:
				'''
				Una vez soñé con la paz. No sé por qué pasó.
				Desde que me enteré de que había algo más allá de este mundo,
				he sentido la presencia de esa mujer en nuestro mundo de vez en cuando.
				¿Qué quería Thorne de ella? Quién sabe.
				Pero ahora todo el poder está en tus manos, terrariano.
				'''
		}

		LoreMirror: {
			DisplayName: El Espejo
			Tooltip: ""
			Lore:
				'''
				Me quedé mirándolo fijamente durante un buen rato, pero, como en cualquier otro espejo, solo me veía a mí mismo.
				Sin embargo, incluso entonces, sentí que algo era… diferente. Me parecía que algo no estaba bien, era casi… retorcido.
				No le di importancia. Pero incluso ahora puedo sentir la mirada penetrante de mi reflejo… atravesándome directamente el cráneo.
				Una vez que has llegado tan lejos, lo más difícil del viaje es enfrentarte a ti mismo.
				'''
		}

		LoreDylan: {
			DisplayName: Dylan
			Tooltip: ""
			Lore:
				'''
				Mmm... Me sorprende que conozcas a esa persona.
				La primera vez que lo encontramos pensamos que era un dios... sin embargo, al final resultó que en realidad no tenía un alma áurica.
				Lo acogimos y nos enseñó a fabricar poderosas armas y bombas imbuidas de elementos que no eran solo de acero.
				Sus ideas habían contribuido a aumentar considerablemente el poder de mi ejército, pero él nunca luchó personalmente.
				
				Un día, cuando fui a su habitación, no había nada allí salvo una nota
				No pudimos descifrar su escritura, pero por las imágenes parecía tratarse de algún tipo de anillo
				y uno de los ingredientes clave parecía ser un "Anillo del Sol Oscuro".
				Quizás esa "Guía" te ayude a descifrar mejor esta nota.
				En cualquier caso, estoy seguro de que descubrirás cómo fabricarlo.

				–¡No te pierdas las próximas novedades de "Infernal Eclipse of Ragnarok"!–
				'''
		}

		LoreMjolnir: {
			DisplayName: Mjolnir
			Tooltip: ""
			Lore:
				'''
				Thor fue uno de los muchos dioses que habían logrado escapar de mi cruzada,
				pero nunca olvidará lo que le hice a él y a su familia.
				Asgard no era más que una tierra de pecadores, así que simplemente hice lo que ellos habían hecho a tantos otros.
				Thor se me había escapado y creía que seguía gobernando Asgard hasta el día de hoy,
				pero con su martillo en tus manos, quizá ya no sea así.
				'''
		}

		LorePrimordials: {
			DisplayName: Los Primordiales
			Tooltip: ""
			Lore:
				'''
				Antes de que se creara el mundo, solo existían los Primordiales.
				Cada uno de ellos representa un aspecto de este mundo y lo protege del Ragnarok.
				Durante mi guerra, quise acabar con ellos pensando que no eran más que pecadores como los demás dioses,
				pero, por mucho que lo intentara, no conseguía llamar su atención.
				¿Acaso no era digno de su atención a pesar de todo lo que le había hecho al mundo?
				No me digas que piensan que soy una mota de polvo en la historia de este mundo en comparación contigo...
				'''
		}

		LoreThunderBird: {
			DisplayName: El Gran Pájaro del trueno
			Tooltip: ""
			Lore:
				'''
				Avistadas por primera vez hacia el final de la era dracónica, se supuso que estas aves,
				al igual que muchas otras criaturas que se descubrieron por entonces, tenían sangre dracónica;
				un hecho difícil de refutar, dada la forma en que absorbían la luz pura del sol de Zeratros 
				y convertían esa energía en rayos.
				En aquella época, probablemente eran las criaturas no divinas más poderosas del planeta.
				Por desgracia… la combinación de la ausencia de depredadores y el hecho de que el Traidor todopoderoso tomara el control del sol 
				ha convertido a esta especie, antaño magnífica, en una sombra de lo que fue.
				'''
		}

		LoreRagnarok: {
			DisplayName: Ragnarok
			Tooltip: ""
			Lore:
				'''
				Qué curioso.
				El Ragnarok, el legendario fin de los días, era un ser más que un acontecimiento.
				Había buscado por todo el mundo la forma de desencadenarlo, para poder destruir Asgard,
				pero al final no había encontrado nada.
				Las historias sobre serpientes y fuego estaban muy lejos de la verdad,
				pero ahora el Ragnarok yace en ruinas, igual que el propio Asgard.
				Ahora se te considera el héroe de esta tierra, 
				y ojalá encuentres la paz en la nueva era que has creado.
				Sin embargo, ten cuidado, pues cada fin trae consigo un nuevo comienzo...
				[c/7C0A02:No tientes más a la suerte, Terrariano.]
				'''
		}

		LoreMegalomaniac: {
			DisplayName: El Megalómano
			Tooltip: ""
			Lore:
				'''
				El Devorador, el Dragón y la Bruja. Todos cayeron víctimas de tu ambición. De tu motivo. De tu empuje.
				Yo tenía una ambición similar. Pero nunca se me consideró un héroe.
				Liberé a este mundo de la tiranía y, sin embargo, se me conoce como un tirano.
				Ahora, alguien con una determinación como la mía llega empeñado en mi destrucción.
				Correré la misma suerte que el opresor al que derroté.
				Destinado a ser eliminado por alguien con aspiraciones similares a las suyas.
				Debería haberlo sabido, darme cuenta antes. Siempre estuvo escrito que fuera así.
				'''
		}

		LoreAnniversaryOne: {
			DisplayName: Infernal Eclipse of Ragnarok
			Tooltip: Aumenta considerablemente la suerte pasiva mientras lo llevas en el inventario
			Lore:
				'''
				Lo que empezó como un pequeño proyecto que monté solo para mí y unos cuantos amigos se ha ido convirtiendo poco a poco en algo mucho más grande de lo que jamás hubiera imaginado. 
				"Infernal Eclipse of Ragnarok" comenzó como una forma de conseguir que una mezcla caótica de mods se pudiera jugar juntos,
				simplemente ajustando cosas aquí y allá para que mi partida de entonces resultara más fluida y divertida. 
				Pero con el tiempo, esos pequeños ajustes se convirtieron en sistemas completos, luego en rediseños y, finalmente, en un marco completo que definía cómo debía sentirse el juego. 
				Me di cuenta de que no solo estaba parcheando cosas, sino diseñando: replanteándome la progresión, equilibrando las clases entre múltiples mods 
				y construyendo algo que se sintiera cohesionado en lugar de un simple mosaico de piezas. 
				Ha sido un largo proceso de pruebas, frustraciones e iteraciones, sobre todo a la hora de aprender a hacer que todo funcionara en el modo multijugador 
				y en tantos mods diferentes, pero también ha sido increíblemente gratificante. 
				Lo que en su día fue solo un proyecto personal se ha convertido en un esfuerzo de desarrollo a gran escala con identidad propia y, sinceramente, 
				ver cómo ha crecido hasta convertirse en algo que otros pueden disfrutar ha sido una de las partes más gratificantes de este viaje.

				Gracias a todos los que habéis apoyado el mod, habéis aportado comentarios y habéis formado parte de esta comunidad.
				¡Por muchas más actualizaciones, funciones y momentos caóticos en el mundo de Infernal Eclipse of Ragnarok!
				'''
		}

		LoreAbominationn: {
			DisplayName: Abominación
			Tooltip: ""
			Lore:
				'''
				El hijo mediano de los hermanos eternos y uno de los seres más perezosos que he visto nunca.
				Aunque la Abominación tiene la capacidad de controlar por completo el clima y repeler a los invasores, 
				es realmente muy perezoso, hasta el punto de fusionar sus armas con sus manos.
				Esgrime un arma capaz de dividir el alma misma, además de poder utilizar todos los fenómenos sobrenaturales. 
				Por suerte para ti, decidió no utilizar ningún ataque celestial por respeto al mutante; de lo contrario, quizá tu victoria no hubiera sido posible.
				'''
		}

		LoreDeviantt: {
			DisplayName: Deviantt
			Tooltip: ""
			Lore:
				'''
				La más joven de los hermanos eternos, y también la más débil.
				A lo largo de su viaje ha reunido un montón de objetos de monstruos raros y, cuando se siente generosa, se los vende a los demás.
				Sin embargo, cuando no se siente generosa, da rienda suelta a su sadismo enamorado.
				La Deviantt tiene la capacidad de lanzar hechizos utilizando tanto la luz primordial como el amor puro, todo ello mientras empuña un hacha viviente hecha de maldad.
				Aunque la hayas vencido en combate, parece que no le da miedo la muerte, y esta es la primera vez que la veo darlo todo en una pelea.
				'''
		}

		LoreMutant: {
			DisplayName: Mutante
			Tooltip: ""
			Lore:
				'''
				El mayor y más poderoso de los hermanos eternos.
				Aunque el resto de hermanos se refieren al Mutante como su hermano, él se niega personalmente a confirmar su género.
				Es el guardián de la eternidad, la encarnación del poder supremo, y se cree que procede de otro mundo más allá de esa grieta dimensional.
				Aparte de ti, es el ser más poderoso que jamás haya pisado la tierra de Terraria, con dominio absoluto sobre todos los aspectos del combate.
				A pesar de todo este poder, siempre le interesó más observar otras batallas en el mundo que participar en ellas él mismo. Siempre le decía a la gente que estaba buscando a 
				alguien fuerte y parece que ha encontrado a la persona que buscaba.
				'''
		}

		LoreLepus: {
			DisplayName: Lepus
			Tooltip: ""
			Lore:
				'''
				Los conejitos de este mundo tienen una capacidad de adaptación asombrosa. Pueden adoptar muchas formas y absorber todo tipo de energía.
				Este en concreto parece haber sido la mascota de un dios menor de la fiesta y la celebración antes de que mi ejército lo matara.
				'''
		}

		LoreTurkor: {
			DisplayName: Turkor, el desagradecido
			Tooltip: ""
			Lore:
				'''
				Las almas vengativas son seres curiosos.
				Para que un alma permanezca en esta vida tras la muerte sin ayuda de magia externa, se requiere o bien una voluntad extraordinariamente fuerte, o bien una ira ardiente en su interior.
				No sé quién era esta persona en vida, ni cómo pereció.
				Aunque los espíritus pueden ejercer fuerza por sí mismos, solo cuando se apoderan de un huésped adquieren verdadero poder.
				Esta alma no es una excepción: su poder se ha visto amplificado por el asesinato injusto de este pavo, que en su día estaba destinado a un banquete real, 
				con manjares que la mayoría de los plebeyos nunca tendrían la oportunidad de probar.
				Desconfía de las almas iracundas, pues cuando eres el blanco de su ira, su poder puede rivalizar con el de los dioses o incluso superarlo.
				'''
		}

		LoreOcram: {
			DisplayName: Ocram
			Tooltip: ""
			Lore:
				'''
				Antes de que los dioses se hicieran con el control definitivo del Inframundo y Azafure se consolidara por completo,
				hubo una época en la que muchas facciones rivalizaban por el dominio de esa legendaria grieta de magma.
				La más destacada era la de un poderoso archidemonio que convertía a los demonios en un clan de devastadores que arrasaban con cualquier civilización.
				Cuando los dioses finalmente fijaron su mirada en el Inframundo, su banda fue aplastada y sus miembros masacrados uno a uno.
				Sin embargo, el archidemonio sobrevivió a pesar de los ataques de los dioses, para gran disgusto de estos,
				por lo que se conformaron con mutilarlo de forma tortuosa hasta llevarlo a la locura, y luego lo desecharon.
				Su nombre cayó en el olvido hace mucho tiempo, hasta el punto de que nunca lo había oído mencionar en toda mi vida.
				Sin embargo, al ver a ese demonio, estoy seguro de que Ocram era aquel archidemonio caído de una época anterior a la mía.
				Si hubiera sabido de su existencia durante mis días de gloria, habría intentado hacer lo que los dioses no pudieron —o no quisieron— hacer.
				'''
		}
	}

