	GlitterGutter: {
		DisplayName: Miseria brillante
		Tooltip:
			'''
			10% de probabilidad de crítico de etiqueta de invocador
			Los enemigos alcanzados por este látigo hacen que el siguiente ataque de un súbdito lance 
			fragmentos de cristal que siguen al objetivo.
			'''
	}

	DestructionChain: {
		DisplayName: Cadena de destrucción
		Tooltip:
			'''
			Los enemigos alcanzados por este látigo provocan que el siguiente ataque de súbdito desencadene una explosión
			Los enemigos muertos por esta explosión desencadenan otra explosión, que puede continuar encadenándose
			'''
	}

	GloamshardConduit: {
		DisplayName: Conducto de fragmento crepuscular
		Tooltip:
			'''
			Multiplica un 1,1 el daño de etiqueta de invocador
			Hay una probabilidad del 10% de hacer un daño crítico de etiqueta de invocador

			  Los enemigos alcanzados por este látigo reciben 1,25 veces más daño del siguiente ataque de súbdito y explotan
			'''
	}

	Satellite: {
		DisplayName: Satélite
		Tooltip: "   Los enemigos alcanzados por este látigo reciben un golpe crítico garantizado de un súbdito."
	}

	ResonantVoid: {
		DisplayName: Vacío resonante
		Tooltip:
			'''
			Multiplica un 1,12 el daño de etiqueta de invocador
			Hay una probabilidad del 12% de hacer un daño crítico de etiqueta de invocador

			Los enemigos alcanzados por este látigo Reciben 1,25 veces más daño del siguiente ataque de súbdito y explota

			Ignora parte de la armadura de los enemigos
			'''
	}

	SkybreakerCoil: {
		DisplayName: Bobina quebrantanubes
		Tooltip:
			'''
			Los enemigos alcanzados por este látigo reciben 1,30 veces más daño del siguiente ataque de súbdito y desata una descarga eléctrica
			La explosión inflige daño rápido a los enemigos cercanos durante un breve periodo de tiempo y penetra la armadura
			'''
	}

	Milkyway: {
		DisplayName: Vía láctea
		Tooltip:
			'''
			+10 de daño de etiqueta de invocación por acumulación
			Los enemigos alcanzados por este látigo reciben un golpe crítico garantizado de un súbdito que inflige 4 veces más de daño
			Las acumulaciones de este látigo se suman entre sí
			Un número de cometas igual al de acumulaciones orbita alrededor del enemigo
			'''
	}

	Loadout: {
		DisplayName: Carga
		Tooltip:
			'''
			Multiplica un 1,07 el daño de etiqueta de invocador
			Hay una probabilidad del 7% de hacer un daño crítico de etiqueta de invocador
			Los enemigos alcanzados por este látigo son alcanzados por un láser cuando los súbditos los golpea
			Ignora parte de la armadura de los enemigos
			'''
	}

	AncientBonds: {
		DisplayName: Lazos ancestrales
		Tooltip:
			'''
			Los enemigos alcanzados por este látigo son empalados por una espada espectral cuando los súbditos los golpean
			La espada espectral inflige el 20% del daño del súbdito tres veces seguidas
			El daño por empalamiento tiene 5 de penetración de armadura
			'''
	}

	PrimalBonds: {
		DisplayName: Lazos primarios
		Tooltip:
			'''
			Los enemigos alcanzados por este látigo son empalados por una espada espectral cuando los súbditos los golpean
			La espada espectral inflige el 20% del daño del súbdito cinco veces seguidas
			El daño por empalamiento tiene 10 de penetración de armadura
			'''
	}

	ExistenceBonds: {
		DisplayName: Lazos existenciales
		Tooltip:
			'''
			Los enemigos alcanzados por este látigo son empalados por una espada espectral cuando los súbditos los golpean
			La espada espectral inflige el 20% del daño del súbdito seis veces seguidas
			El daño por empalamiento tiene 15 de penetración de armadura
			'''
	}

	MermaidsTear: {
		DisplayName: Lágrimas de sirenas
		Tooltip:
			'''
			Los enemigos alcanzados por este látigo son empalados por una espada espectral cuando los súbditos los golpean
			La espada espectral inflige el 25% del daño del súbdito ocho veces seguidas
			El daño por empalamiento tiene 50 de penetración de armadura
			'''
	}

	MandibleLash: {
		DisplayName: Látigo mandibular
		Tooltip:
			'''
			1 daño de etiqueta de invocador
			Los enemigos alcanzados por este látigo hacen que el siguiente ataque del súbdito lance una esfera de arena
			La esfera de arena se mueve por la fuerza de la gravedad e inflige el 40% del daño del súbdito
			La esfera de arena explota al chocar contra un bloque, causando daño a los enemigos cercanos
			'''
	}

	DarkMandibleLash: {
		DisplayName: Látigo mandibular oscuro
		Tooltip:
			'''
			2 daño de etiqueta de invocador
			Los enemigos alcanzados por este látigo hacen que el siguiente ataque del súbdito lance una esfera de arena
			La esfera de arena se mueve por la fuerza de la gravedad e inflige el 40% del daño del súbdito
			La esfera de arena explota al chocar contra un bloque, causando daño a los enemigos cercanos
			'''
	}

	ShieldConduit: {
		DisplayName: Conducto blindado
		Tooltip:
			'''
			2 daño de etiqueta de invocador
			Cambia automáticamente entre dos modos.
			'''
		HoldShiftTooltip:
			'''
			-----------------------------
			Modo Defensa:
			Al golpear a un enemigo con el látigo,
			los ataques de los súbditos liberan fragmentos de escudo azul
			durante un breve periodo de tiempo.
			Al recoger los fragmentos, se acumula cargas de escudo.
			Con 50 cargas, se obtiene un escudo de 50 puntos de vida
			-----------------------------
			Modo Ataque:
			Al golpear a un enemigo con el látigo,
			los ataques de los súbditoss liberan fragmentos de escudo rojos durante un breve periodo de tiempo.
			Los fragmentos rojos se dirigen hacia los enemigos,
			infligiendo un 10% del daño de los súbditos +3 de daño fijo
			-----------------------------
			La liberación de fragmentos de escudo tiene un tiempo de enfriamiento muy corto.
			Cuando el escudo recibe daño, entra en un enfriamiento
			que dura entre 5 y 50 segundos, dependiendo del escudo restante.
			Si el escudo se rompe por completo,
			el tiempo de recarga pasa a ser de 60 segundos.
			Durante el tiempo de recarga, cambia al modo de ataque.
			Cuando finaliza el tiempo de recarga, cambia al modo de defensa.
			Si queda algo de escudo, al recoger fragmentos
			se restaurará la durabilidad del escudo
			'''
	}

	ShieldConduitMkII: {
		DisplayName: Conducto blindado Mk-II
		Tooltip:
			'''
			4 daño de etiqueta de invocador
			Cambia automáticamente entre dos modos.
