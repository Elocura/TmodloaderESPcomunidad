	GoldRush: {
		DisplayName: Fiebre del oro
		Tooltip:
			'''
			20 de daño de etiqueta de invocación
			Al golpear a los enemigos, se invoca rápidamente un arsenal que inflige el 120% del daño de los súbditos
			'''
	}

	GildedReliquary: {
		DisplayName: Reliquario dorado
		Tooltip:
			'''
			20 de daño de etiqueta de invocación
			Al golpear a los enemigos, se invoca rápidamente un arsenal que inflige el 120% del daño de los súbditos
			'''
	}

	AurelianSanctum: {
		DisplayName: Santuario Aureliano
		Tooltip:
			'''
			80 de daño de etiqueta de invocación
			Al golpear a los enemigos, se desata una lluvia implacable de proyectiles que infligen el 200% del daño de los súbditos
			'''
	}

	LeatherGrip: {
		DisplayName: Empuñadura de cuero
		Tooltip:
			'''
			Aumenta el alcance de los látigos en un 10%
			Multiplica un 1,05 el daño de etiqueta de invocador
			Solo se puede equipar una empuñadura a la vez
			'''
	}

	SilkGrip: {
		DisplayName: Silk Grip
		Tooltip:
			'''
			Aumenta el alcance del látigo en un 10%
			Hay una probabilidad del 5% de hacer un daño crítico de etiqueta de invocador
			Solo se puede equipar una empuñadura a la vez
			'''
	}

	RubberGrip: {
		DisplayName: Empuñadura de goma
		Tooltip:
			'''
			Aumenta el alcance de los látigos en un 15%
			Multiplica un 1,03 el daño de etiqueta de invocador 
			y hay una probabilidad del 3% de hacer un daño crítico de etiqueta de invocador
			Solo se puede equipar una empuñadura a la vez
			'''
	}

	NecromanticGrip: {
		DisplayName: Empuñadura de necromántico
		Tooltip:
			'''
			Aumenta el número máximo de súbditos en 1
			Aumenta el alcance de los látigos en un 15%
			Multiplica un 1,05 el daño de etiqueta de invocador
			y hay una probabilidad del 5% de hacer un daño crítico de etiqueta de invocador
			Permite a los látigos golpear a los enemigos a través de bloques
			Solo se puede equipar una empuñadura a la vez
			'''
	}

	EmperorsGrip: {
		DisplayName: Empuñadura de emperador
		Tooltip:
			'''
			Aumenta el número máximo de súbditos en 2
			Aumenta el alcance de los látigos en un 30%
			Multiplica un 1,07 el daño de etiqueta de invocador
			y hay una probabilidad del 7% de hacer un daño crítico de etiqueta de invocador
			Permite a los látigos golpear a los enemigos a través de bloques
			Solo se puede equipar una empuñadura a la vez
			'''
	}

	LightSpiritGrip: {
		DisplayName: Empuñadura de espíritu de la luz
		Tooltip:
			'''
			Permite a los látigos golpear a los enemigos a través de bloques
			Solo se puede equipar una empuñadura a la vez
			'''
	}

	AirflowGrip: {
		DisplayName: Empuñadura de flujo de aire
		Tooltip:
			'''
			Disminuye el alcance de los látigos en un 15%
			Permite a los látigos golpear a los enemigos a través de bloques
			Solo se puede equipar una empuñadura a la vez
			'''
	}

	CommanderGrip: {
		DisplayName: Empuñadura de comandante
		Tooltip:
			'''
			Los proyectiles de tus súbditos se dirigirán hacia los enemigos golpeados por tu látigo durante un breve periodo de tiempo
			Solo se puede equipar una empuñadura a la vez
			'''
	}

	MagneticGrip: {
		DisplayName: Empuñadura magnética
		Tooltip:
			'''
			Disminuye el alcance de los látigos en un 15%
			Los proyectiles de tus súbditos se dirigirán hacia los enemigos
			golpeados por tu látigo durante un breve periodo de tiempo
			'''
	}

	BuddyEmblem: {
		DisplayName: Emblema del panita
		Tooltip:
			'''
			Aumenta significativamente el daño cuando solo hay un súbdito presente
			El daño del súbdito aumenta en función del número de espacios de súbdito sin usar
			Cuanto más se potencie a ese súbdito, más grande se volverá
			Algunos súbditos no pueden beneficiarse de este efecto
			Se reducirán algunos efectos de etiqueta de látigo
			'¡Te elijo a ti!'
			'''
	}

	StrikerEmblem: {
		DisplayName: Emblema del atacante
		Tooltip:
			'''
			Ya no puedes invocar súbditos ni centinelas
			Los latigos golpean a los enemigos tres veces más, infligiendo un 33% de daño adicional
			Estos golpes se benefician de los efectos de la etiqueta de invocación
			Aumenta el alcance del latigo en un 10%
			Aumenta el daño de invocación en un 1% por cada ranura de súbdito sin usar
			'¡Muere, monstruo!'
			'''
	}
}
