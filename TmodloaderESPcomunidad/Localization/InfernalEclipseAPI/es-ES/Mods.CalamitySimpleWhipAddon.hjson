	LayeredPain: {
		DisplayName: Dolor por capas
		Tooltip:
			'''
			+1 de daño de etiqueta de invocación por acumulación
			El daño de marca de este látigo se acumula consigo mismo. Las acumulaciones más antiguas se eliminan primero
			'''
	}

