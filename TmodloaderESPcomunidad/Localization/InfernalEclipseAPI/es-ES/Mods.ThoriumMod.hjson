			Aumenta el daño radiante en un 15%
			Se reduce el coste de maná en un 15%
			Los hechizos de curación curarán 1 punto de vida adicional
			'''
	}

	DreamWeaversHelmet: {
		DisplayName: Casco del Tejedor de sueños
		Tooltip:
			'''
			"Ata a los enemigos de tu futuro en una agonía temporal"
			Corrompe tus poderes radiantes
			Reduce un 45% el daño no radiante
			Aumenta el daño radiante en un 45%
			Aumenta la probabilidad de golpe crítico radiante en un 36%
			Aumenta el maná máximo en 20
			'''
	}

	DreamWeaversHood: {
		DisplayName: Capucha del Tejedor de sueños
		Tooltip:
			'''
			"Haz realidad tus sueños más preciados con la ayuda de tus aliados"
			Reduce un 25% el daño no radiante
			Aumenta el daño radiante en un 30%
			Aumenta la probabilidad de golpe crítico radiante en un 16%
			Se reduce el coste de maná en un 35%
			Aumenta considerablemente la regeneración de maná
			Aumenta el maná máximo en 60
			Los hechizos de curación curarán 6 puntos de vida adicionales
			'''
	}

	DreamWeaversTabard: {
		DisplayName: Tabardo del Tejedor de sueños
		Tooltip:
			'''
			Reduce un 25% el daño no radiante
			Aumenta el daño radiante en un 25%
			Aumenta la probabilidad de golpe crítico radiante en un 14%
			Se reduce el coste de maná en un 20%
			Aumenta considerablemente la regeneración de maná
			Los hechizos de curación curarán 2 puntos de vida adicionales
			'''
	}

	TideTurnersGaze: {
		DisplayName: Corona de las profundidades de la marea
		Tooltip:
			'''
			"Desata la furia acuática sobre tus enemigos"
			Aumenta el daño de arrojador en un 35%
			Hay un 50% de probabilidad de no consumir los objetos arrojables
			Aumenta tus puntos de técnica máximos en 2
			El daño de arrojador aumenta temporalmente el daño que recibe el enemigo en un 10%
			Genera una glóbulo flotante cada segundo
			Cada glóbulo hace que tu próximo ataque sea un minicrítico, en el caso de que no sea un crítico
			'''
	}

	TideTurnerBreastplate: {
		DisplayName: Guarda de las profunidades de la marea
		Tooltip:
			'''
			Aumenta un 15% el daño cuerpo a cuerpo y de arrojador
			Aumenta un 10% la velocidad de ataque cuerpo a cuerpo
			Aumenta un 16% la probabilidad de golpe crítico cuerpo a cuerpo y de arrojador
			'''
	}

	TideTurnerGreaves: {
		DisplayName: Caminadores de las profundidades de la marea
		Tooltip:
			'''
			Aumenta un 10% el daño cuerpo a cuerpo y de arrojador
			Aumenta un 20% la velocidad de ataque cuerpo a cuerpo
			 Aumenta un 30% la velocidad de movimiento
			'''
	}

	MagmaSeersMask.Tooltip:
		'''
		"Dirige un ejército reforzado con magma"
		Aumenta un 50% el daño de invocación
		Aumenta en 2 el número máximo de súbditos y centinelas
		Aumenta el empuje de los súbditos
		'''
	CursedFlailCore.Tooltip:
		'''
		Las armas de mayal lanzan una bola de púas malditas al primer impacto
		Los impactos posteriores tienen la posibilidad de lanzar más bolas de púas malditas
		Las bolas infligen llamas malditas a los enemigos a los que causan daño
		'''
	VileFlailCore.Tooltip:
		'''
		Las armas de mayal lanzan una bola de púas maligns al primer impacto
		Los impactos posteriores tienen la posibilidad de lanzar más bolas de púas malignas.
		Las bolas aplican icor a los enemigos dañados
		'''
	IronFlailCore.Tooltip:
		'''
		Las armas de mayal lanzan una bola con púas rodante al primer impacto
		Los impactos posteriores tienen la posibilidad de lanzar más bolas con púas rodantes
		'''
	BloomingShield.Tooltip:
		'''
		Generas constantemente un escudo de 20 puntos de vida
		Los hechizos de curación te curarán 1 punto de vida adicional, o 2 si el escudo está al máximo
		Fuera de combate, tu recuperación de vida aumentará hasta 5 puntos con el paso del tiempo
		'''
	AstroBeetleHusk.Tooltip:
		'''
		El daño recibido se reduce en un 5%
		Generas constantemente un escudo de 50 puntos de vida
		'''
}

ThrowerTechniques: {
	Decoy: {
		DisplayName: Carnada
		Description:
			'''
			Invoca un señuelo al enemigo para obtener una mayor velocidad de ataque durante un segundo
			El señuelo intentará atraer la atención de los enemigos cercanos
			'''
	}

	BloodLotus: {
		DisplayName: Loto sangriento
		Description:
			'''
			Quédate quieto para lanzar una lluvia de cuchillos contra el enemigo más cercano
			Cada cuchillo te cura hasta un 10% del daño infligido
			La lluvia otorga al jugador 100 de defensa, pero desaparece al recibir daño
			'''
	}

	SmokeBomb: {
		DisplayName: Bomba de humo
		Description:
			'''
			Lanza una bomba de humo
			Las bombas de humo te otorgan inmunidad al daño y una mayor velocidad de ataque durante 2 segundos
			'''
	}
}
