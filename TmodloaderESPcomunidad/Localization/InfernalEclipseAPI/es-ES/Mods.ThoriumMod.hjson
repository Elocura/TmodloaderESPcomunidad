Buffs: {
	NinjaBuff.Description: La velocidad de ataque de arrojador by 20%,aumenta un 20% y la probabilidad de golpe crítico de arrojador aumenta un 10%.
	BloodRush.Description: Aumenta un 15% en la velocidad de minado
}

Items: {
	CapeoftheSurvivor: {
		DisplayName: Cabo del superviviente
		Tooltip:
			'''
			"El propio tejido de esta capa ha sido diseñado para ayudarte a superar los días más difíciles"
			Con el tiempo, obtienes rápidamente hasta un 15% de reducción de daño
			Si recibes un golpe, esta bonificación se reduce temporalmente a un -10% 
			Mientras esta bonificación sea superior al 0%, recuperas hasta 2 puntos de vida
			'''
	}

	/*
	ScryingGlass: {
	DisplayName: Cristal adivinatorio
	Tooltip: Al pulsar la tecla'{$Keybinds.AccessoryAbility.DisplayName}' activará o desactivará un mayor campo de visión
	}
	*/
	
	ShootingStarHat.SetBonus:
		'''
		Las potenciaciones sinfónicas duran 6 segundos más
		Cada potenciación única que tengas aumenta tu daño sinfónico en un 2,5%
		Cada potenciación única que tengas aumenta tu regeneración de inspiración en un 2%
		'''

	SoulofPlight: {
		DisplayName: Alma de rencor
		Tooltip: "'La esencia de las criaturas malditas'"
	}

	SoulofPlightinaBottle: {
		DisplayName: Alma de rencor en una botella
		Tooltip: ""
	}

	KeyofPlight: {
		DisplayName: Llave del rencor
		Tooltip: "'Cargado con la esencia de muchas almas'"
	}

	MasterMarksmansScouter.Tooltip:
		'''
		"La pólvora acabará con los débiles"
		Se detectará al enemigo más cercano, y recibirá un 10% más de daño de todas las fuentes
		Tu daño a distancia aplica llamas malditas a los enemigos
		'''
	AssassinsGuard.Tooltip:
		'''
		Aumenta un 16% el daño a distancia
		Aumenta un 15% la probabilidad de golpe crítico a distancia
		Se reduce en un 25% la probabilidad de gastar munición
		'''

	Kinetoscythe: {
		DisplayName: Guadaña cinética
		Tooltip:
			'''
			Hace girar rápidamente una guadaña de alta tecnología a tu alrededor
			Presiona <right> para generar una guadaña de energía giratoria estacionaria
			El arma gira mientras la guadaña de energía esté activa para que impacte en los enemigos. 
			'''
	}

	BlackMIDI: {
		DisplayName: MIDI negro
		Tooltip:
			'''
			Lanza rápidamente una oleada de ruido hacia el cursor
			El ruido amarillo cura al usuario un 0,5% del daño infligido
			'''
	}

	DreamCatcher: {
		DisplayName: Atrapasueños
		Tooltip:
			'''
			Invoca un atrapasueños en la ubicación del cursor
			Si permaneces dentro del atrapasueños, recuperarás el 20% de tu vida máxima si recibes daño letal
			Los jugadores revividos verán reducidas temporalmente sus estadísticas y no podrán revivir de nuevo durante 2 minutos
			"Para atrapar y acunar las esperanzas del mundo..."
			'''
	}

	HereticBreaker: {
		DisplayName: Rompeherejes
		Tooltip: Roba 3 puntos de vida
	}

	CrystalHoney: {
		DisplayName: Miel cristalina
		Tooltip:
			'''
			Aumenta la vida máxima en 20
			Aumenta el daño radiante en un 5%
			Aumenta la probabilidad de golpe crítico radiante en un 5%
			'''
	}

	DarkGlaze: {
		DisplayName: Glaseado oscuro
		Tooltip:
			'''
			"Endiabladamente dulce"
			Potencia ciertos ataques radiantes con energía oscura
			Aumenta la vida máxima en 20
			Aumenta el daño radiante en un 10%
			Aumenta la probabilidad de golpe crítico radiante en un 5%
			'''
	}

	DemonTongue: {
		DisplayName: Lengua de demonio
		Tooltip:
			'''
			Potencia ciertos ataques radiantes con energía oscura
			Aumenta el daño radiante en un 10%
			Reduce a la mitad el coste de vida radiante, pero no su efecto de transferencia de vida
			'''
	}

	ArchDemonCurse: {
		DisplayName: Maldición del archidemonio
		Tooltip:
			'''
			Potencia ciertos ataques radiantes con energía oscura
			Aumenta la vida máxima en 20
			Aumenta la velocidad de ataque radiante en un 10% 
			Aumenta el daño radiante en un 10%
			Aumenta la probabilidad de golpe crítico radiante en un 5%
			'''
	}

	FlightMask.Tooltip:
		'''
		Aumenta el daño de arrojador en un 10%
		Aumenta la probabilidad de golpe crítico de arrojador en un 5%
		"El cielo es tu campo de juego"
		'''
