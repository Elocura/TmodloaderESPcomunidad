Mods: {
	CalCooldownRenderFix: {
		Configs: {
			CFUConfig: {
				DisplayName: Config

				Headers: {
					CooldownBar: Cooldown Bar
					RageAdrenalineBar: Rage/Adrenaline Bar
					CustomBossTitlesIntros: Boss Intro Titles
					Misc: Miscellaneous
				}

				CooldownBarShader: {
					Label: "[i:963] Enable"
					Tooltip:
						'''
						Uses the new shader for [c/aaff33:Cooldown] bar.
						[c/444444:Works only if Cooldown Rack Display Mode is set to Full.]
						'''
				}

				CooldownStyle: {
					Label: "[i:1967] Style"
					Tooltip: Changes the style.
				}

				CooldownPixelation: {
					Label: "[i:3753] Pixelation Level"
					Tooltip:
						'''
						[c/ff3333:EXPERIMENTAL OPTION]
						Pixelates the cooldown bars by set level.
						The higher, the stronger is the effect.
						[c/444444:Disabled by default.]
						'''
				}

				CooldownFablesSupport: {
					Label: "[i:174] Fables Cooldowns Compatibility"
					Tooltip:
						'''
						Adds support for [c/ffff00:Calamity Fables] cooldowns to 
						be placed next to [c/bb4444:Calamity Mod] counterpart.
						'''
				}

				RageAdreBarShader: {
					Label: "[i:CalamityMod/HeartofDarkness] Enable"
					Tooltip: Overhauls the look of [c/ff4411:Rage]/[c/00bbff:Adrenaline] bars.
				}

				RageAdreStyle: {
					Label: "[i:1967] Style"
					Tooltip: Changes the style.
				}

				DraedonHeartForce: {
					Label: "[i:CalamityMod/DraedonsHeart] Draedon's Heart overrides the style"
					Tooltip:
						'''
						If [c/00ff00:enabled]:
						  it will replace the mod's [c/00bbff:Adrenaline] bar with vanilla
						  counterpart as long as [c/887799:Draedon's Heart] is equipped.
						'''
				}

				CustomBossTitlesIntros: {
					Label: "[i:4798] Enable"
					Tooltip:
						'''
						Changes the boss name titles to stylized variants.
						Supports [c/ffff00:Calamity Fables] and [c/ff77bb:Calamity Infernum Mode].
						'''
				}

				CustomBossTitlesNoInfernumIntros: {
					Label: "[i:1332] No-Infernum Mode"
					Tooltip:
						'''
						If [c/00ff00:enabled]:
						  the mod will handle the [c/ff77bb:Infernum] style intros itself.
						If [c/ff77bb:Calamity Mod Infernum Mode] is on:
						  this setting bypasses the [c/ffff66:Infernum Mode] requirement for intros to appear.
						'''
				}

				CustomBossTitlesIntroSize: {
					Label: "[i:486] Size"
					Tooltip: Scale multiplier for the text.
				}

				CustomBossTitlesSmoothFablesIntroText: {
					Label: "[i:3481] Smooth Fables Text Rendering"
					Tooltip: Makes the font render smoother in [c/ffff00:Calamity Fables] boss intros.
				}

				RelicBossTitles: {
					Label: "[i:4927] Enable Boss Titles for Relics"
					Tooltip: Causes the relic names to render with unique rarity associated to its boss.
				}

				BossBarBossTitles: {
					Label: "[i:5120] Enable Boss Titles on Boss Bar"
					Tooltip:
						'''
						[c/bb4444:Calamity] Boss Bar draws boss title with associated style. 
						Also applies the effect to the bar itself.
						Supports [c/ff77bb:Calamity Infernum Mode] Boss Bar Style.
						'''
				}

				BossBarCustomFont: {
					Label: "[i:449] Use Fancy Font on Boss Bar"
					Tooltip:
						'''
						Replaces the font for [c/bb4444:Calamity] Boss Bar health progress with the fancy one.
						Supports [c/ff77bb:Calamity Infernum Mode] Boss Bar Style.
						'''
				}
			}

			CooldownStyles: {
				Tooltip: ""

				Calamity: {
					Label: Calamity-like
					Tooltip: ""
				}

				Modern: {
					Label: Modern
					Tooltip: ""
				}

				Gradient: {
					Label: Gradient
					Tooltip: ""
				}

				RoundedModern: {
					Label: Rounded Modern
					Tooltip: ""
				}
			}

			RipperBarStyles: {
				Tooltip: ""

				Retro: {
					Label: Retro
					Tooltip: ""
				}

				Modern: {
					Label: Modern
					Tooltip: ""
				}
			}

			FablesCooldownSupport: {
				Tooltip: ""

				None: {
					Label: None
					Tooltip: "[c/ffff00:Fables] cooldowns are separate from [c/bb4444:Calamity] cooldowns, they overlay each other"
				}

				BeforeCalamity: {
					Label: Fables and Calamity
					Tooltip: "[c/ffff00:Fables] and [c/bb4444:Calamity] cooldowns are sorted together"
				}

				Custom: {
					Label: Fables and Calamity+
					Tooltip:
						'''
						[c/ffff00:Fables] and [c/bb4444:Calamity] cooldowns are sorted together
						+ Compact style is replaced with the new Cooldown bar shader
						'''
				}
			}
		}

