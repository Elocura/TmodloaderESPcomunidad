Items: {
	HemocombShard: {
	DisplayName: Fragmento de hemopanal
	Tooltip:
		'''
		Aumenta un 30% la probabilidad de fortalecer a las abejas aliadas
		Las abejas fortalecidas pueden explotar en trozos de carne curativos
		Solo puedes tener equipado un fragmento de panal a la vez

		'''
    }

	HemocombShardChunk1: {
	DisplayName: Trozo de carne
	Tooltip: No deberías estar viendo esto...
}

	HemocombShardChunk2: {
		DisplayName: Trozo de carne
		Tooltip: No deberías estar viendo esto...
	}

	HemocombShardChunk3: {
		DisplayName: Trozo de carne
		Tooltip: No deberías estar viendo esto...
	}

	CursedHoneycomb: {
		Tooltip:
			'''
			Mantén <izquierda> para controlar un panal maldito
			El panal maldito escupe dientes y ojos malditos
			Los dientes se adhieren a los enemigos e infligen daño continuo acumulable, mientras que los ojos persiguen a los enemigos
			Genera abejas malditas al impactar
			'''
		DisplayName: Panal maldito
	}

	EaterOfHoneycombs: {
		Tooltip:
			'''
			Dispara abejas corruptas y minidevoradores antes de lanzarse y buscar objetivos
			«¿Parece... estar vivo?»
			'''
		DisplayName: Devorador de panales
	}

	BrainyHoneycomb: {
		Tooltip:
			'''
			Dispara abejas genio que infligen Confusión y acumulaciones de Desorientación cerebral
			Cada acumulación de Desorientación cerebral hace que el objetivo inflija un 5% menos de daño y reciba 5 de daño continuo, hasta un máximo de 5 acumulaciones
			«El coeficiente intelectual de este panal está por las nubes»
			'''
		DisplayName: Panal cerebral
	}

	CystComb: {
		DisplayName: Cistopanal
		Tooltip:
			'''
			Lanza un panal retornante infestado de tumores
			Golpear enemigos provoca una explosión de icor
			«Un panal invadido por quistes... qué asco»
			'''
	}

	ManaInfusedHoneycomb: {
		Tooltip:
			'''
			Mantén <izquierda> para cargar una ráfaga de abejas imbuidas de maná
			Las abejas de maná generan estrellas de maná perseguidoras al impactar
			'''
		DisplayName: Panal imbuido de maná
	}

	Skelecomb: {
		Tooltip:
			'''
			Invoca abejas esqueléticas que acuchillan a los enemigos
			Pulsa <derecha> para disparar un cráneo maldito que hace que los enemigos reciban un 15% más de daño de todas las fuentes
			'''
		DisplayName: Esquelepanal
	}

	SkeletalBeeChestplate: {
		Tooltip:
			'''
			Reduce el daño recibido un 10%
			Aumenta en 2 las abejas leales
			'''
		DisplayName: Peto de abeja esquelética
	}

	SkeletalBeeHelmet: {
		Tooltip:
			'''
			Probabilidad de golpe crítico del apicultor aumentada un 10%
			Aumenta la miel máxima en 50
			'''
		DisplayName: Casco de abeja esquelética
	}

	SkeletalBeeLeggings: {
		Tooltip: Daño del apicultor aumentado un 10%
		DisplayName: Grebas de abeja esquelética
	}

	SpectralBeeTome: {
		Tooltip: "«Las almas de abejas olvidadas buscan venganza»"
		DisplayName: Tomo de la abeja espectral
	}

	HymenoptraFlasks: {
		Tooltip:
			'''
			Lanza una variedad de frascos relacionados con las abejas
			«Quizá deberías ponerte unas gafas»
			'''
		DisplayName: Frascos de himenópteros
	}

	BeeFinTuna: {
		DisplayName: Atún aleta de abeja
		Tooltip:
			'''
			Escupe una dispersión de burbujas de miel que estallan en abejas
			«Se dice que su carne es increíblemente dulce y tierna»
			'''
	}

	CopperBeeIdol: {
		Tooltip:
			'''
			Probabilidad de no consumir miel aumentada un 10%
			«Está claro que las civilizaciones antiguas no sabían qué aspecto tenían las abejas»
			'''
		DisplayName: Ídolo de abeja de cobre
	}

	TinBeeIdol: {
	Tooltip:
		'''
		Aumenta un 4% el daño y la probabilidad de golpe crítico del apicultor
		«Está claro que las civilizaciones antiguas no sabían qué aspecto tenían las abejas»
		'''
	DisplayName: Ídolo de abeja de estaño
}

	BeekeepersPants: {
		Tooltip: Probabilidad de golpe crítico del apicultor aumentada un 5%
		DisplayName: Pantalones de apicultor
	}

	BeekeepersRobe: {
		DisplayName: Túnica de apicultor
		Tooltip:
			'''
			Daño del apicultor aumentado un 5%
			Aumenta en 1 el máximo de abejas leales
			'''
	}

	BeekeepersVeil: {
		DisplayName: Velo de apicultor
		Tooltip:
			'''
			Probabilidad de golpe crítico del apicultor aumentada un 5%
			Aumenta la miel máxima en 25
			'''
	}

	Beemerang: {
		Tooltip:
			'''
			Mantén <izquierda> para cargar un abejarang retornante
			Según la carga, el abejarang obtiene más retroceso, velocidad, daño y genera más abejas al impactar
			'''
		DisplayName: Abejarang
	}

	BeenadeLauncher: {
		Tooltip:
			'''
			Dispara bombabejas rebotantes llenas de abejas
			«Oh, van a tener que pegarte de nuevo»
			«¡EN EL INFIERNO!»
			'''
		DisplayName: Lanzabejadas
	}

	BeeInyGun: {
		Tooltip: "«Cuesta cuatrocientas mil botellas de miel disparar esta arma... durante doce segundos»"
		DisplayName: Abejetralladora
	}

	BeeSniperArmor: {
		Tooltip:
			'''
			Probabilidad de no consumir miel aumentada un 25%
			Aumenta en 3 el máximo de abejas leales
			'''
		DisplayName: Armadura de francotirador apícola
	}

	BeeSniperGoggles: {
		Tooltip:
			'''
			Probabilidad de golpe crítico del apicultor aumentada un 15%
