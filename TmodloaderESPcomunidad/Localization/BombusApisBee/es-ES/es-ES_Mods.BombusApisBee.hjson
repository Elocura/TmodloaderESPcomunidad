			'''
			«Parece tener una conexión profunda con la colmena»
			Aumenta en 3 el máximo de abejas leales
			'''
	}

	HoneyphyteChestpiece: {
		Tooltip:
			'''
			Probabilidad de no consumir miel aumentada un 30%
			Aumenta en 5 el máximo de abejas leales
			'''
		DisplayName: Peto de mielofita
	}

	HoneyphyteGreaves: {
		DisplayName: Grebas del acaparador de miel
