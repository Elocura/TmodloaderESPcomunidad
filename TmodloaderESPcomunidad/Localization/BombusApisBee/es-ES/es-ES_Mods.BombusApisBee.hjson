	}

	BeeSniperLeggings: {
		Tooltip: Daño del apicultor aumentado un 10%
		DisplayName: Grebas de francotirador apícola
	}

	BeeZooka: {
		Tooltip:
			'''
			Dispara una ráfaga de cohetes abeja perseguidores que explotan en minimisiles
			Los minimisiles apuntan al enemigo más cercano al cursor y explotan en metralla
			«¡Si Dios hubiera querido que vivieras, no me habría creado!»
			'''
		DisplayName: Abejazuca
	}

	GelatinousHoneycomb: {
		Tooltip:
			'''
			Dispara abejas reales que hacen llover bolas de gelatina rebotantes
			Dispara un rubí volátil cada pocos disparos
			«Un panal digno de un rey»
			'''
		DisplayName: Panal gelatinoso
	}

	GlassOfHoney: {
		Tooltip:
			'''
			Daño del apicultor aumentado un 10%
			Aumenta la miel máxima en 10
			Aumenta considerablemente la regeneración de vida
			'''
