	}

	HymenoptrianNecklace: {
	Tooltip:
		'''
		Aumenta la penetración de armadura en 5
		Cubre los ataques del apicultor con néctar dulce, otorgándoles robo de vida con golpes críticos
		Aumenta la vida máxima en 20
		Libera abejas y cthulabejas, aumenta el daño del apicultor y la velocidad de movimiento, y cubre al usuario de miel al recibir daño
		'''
	DisplayName: Collar himenóptero
}

	LivingFlowerChestplate: {
		DisplayName: Peto de flor viviente
		Tooltip: Daño del apicultor aumentado un 4%
	}

	LivingFlowerCrown: {
