			'''
	}

	LivingFlowerLeggings: {
		Tooltip: Probabilidad de golpe crítico del apicultor aumentada un 3%
		DisplayName: Grebas de flor viviente
	}

	Nectarlace: {
		DisplayName: Nectacollar
		Tooltip:
			'''
			Aumenta la penetración de armadura en 5
			Libera abejas y cubre al usuario de miel al recibir daño
			Cubre los ataques del apicultor con néctar dulce, otorgándoles robo de vida con golpes críticos
			Aumenta la vida máxima en 20
			'''
	}

	NectarSlasher: {
		DisplayName: Cortanéctar
		Tooltip:
			'''
			Realiza un combo de tres movimientos con golpes rápidos y lanzamientos
			Atraviesa a los enemigos al impactar
			Restaura vida al impactar
			'''
	}

	Nectarthrower: {
		Tooltip:
			'''
			Dispara néctar fundido que recubre a los enemigos con un glaseado de néctar
			Los enemigos glaseados liberan proyectiles curativos al ser golpeados
			'''
		DisplayName: Lanzanéctar
	}

	ThePeeperPoker: {
		Tooltip:
			'''
			Hace girar rápidamente una jabalina infestada de ojos alrededor del jugador
			Suelta el botón del ratón para lanzar la jabalina
			Cuanto más tiempo la hagas girar, más rápido viajará, más daño infligirá y más enemigos atravesará
			Genera cthulabejas mientras gira y mientras viaja
			'''
		DisplayName: El pinchaojos
	}

	StoneHoneycomb: {
		DisplayName: Panal petrificado
		Tooltip:
			'''
			Lanza un pesado panal petrificado
			El panal siempre asesta golpes críticos cuando cae con suficiente velocidad
			«Rocas... abejas... ¿qué podría salir mal?»
			'''
	}

	PollenItem: {
		DisplayName: Polen
		Tooltip: "«Ten cuidado si eres alérgico»"
	}

	TheQueensLarvae: {
		Tooltip:
			'''
			Consume tu miel al usarlo
			Reserva un 65% de tu miel mientras esté con vida
			«Antes una reina real, ahora tu guardia real»
			'''
		DisplayName: Larva de la reina
	}

	RetinaReleaser: {
		DisplayName: Liberador de retinas
		Tooltip:
			'''
			«Creo que te están mirando»
			Recibir daño libera una ráfaga de cthulabejas y aumenta un 12% el daño del apicultor durante un breve periodo
			'''
	}

	RottenHoneycombShard: {
		DisplayName: Fragmento de panal podrido
		Tooltip:
			'''
			Aumenta un 20% la probabilidad de fortalecer a las abejas aliadas
			Las abejas fortalecidas aplican una desventaja debilitante
			«Huele horrible»
			Solo se puede equipar un fragmento de panal a la vez

			'''
	}

	TESTWEAPON: {
		DisplayName: Panal de prueba
		Tooltip: PRUEBA, NO USAR
	}

	TheBeeBlade: {
		Tooltip:
			'''
			«Una espada casi perfecta que irradia la energía de la colmena»
			Crea un gran corte de miel al blandirla
			Golpear a un enemigo genera una ráfaga de aguijones detrás del jugador
			'''
		DisplayName: La espada de abeja
	}

	TheTraitorsSaxophone: {
		DisplayName: Saxofón del traidor
		Tooltip: "«¿Te gusta el jazz?»"
	}

	TrueNectarSlasher: {
		DisplayName: Cortanéctar verdadero
		Tooltip:
			'''
			Realiza un combo de cinco movimientos con golpes ligeros, golpes fuertes y lanzamientos
			Atraviesa a los enemigos al impactar
			Restaura vida al impactar
			'''
	}

	WoodenApiary: {
		DisplayName: Apiario de madera
		Tooltip:
			'''
			Mantén <izquierda> para disparar abejas rápidamente
			Mantén <derecha> para disparar más lentamente y controlar las abejas, haciendo que inflijan 3 de daño adicional
			'''
	}

	BeeSquireShield: {
		DisplayName: Escudo del escudero abeja
		Tooltip:
			'''
			«¡El más noble de los escuderos abeja te protegerá!»
			Invoca un escudero abeja que flota cerca de ti y dispara flechas a los enemigos cercanos
			'''
	}

	BeeEmblem: {
		DisplayName: Emblema del apicultor
		Tooltip: Daño del apicultor aumentado un 15%
	}

	HellcombShard: {
		DisplayName: Fragmento de panal infernal
		Tooltip:
			'''
			Aumenta un 40% la probabilidad de fortalecer a las abejas aliadas
			Las abejas fortalecidas pueden provocar explosiones volátiles
			Solo se puede equipar un fragmento de panal a la vez

			'''
	}

	HellfireBeemstick: {
		Tooltip:
			'''
			Dispara una dispersión infernal de perdigones de abeja y abejas que infligen Fuego infernal
			Pulsa <derecha> para disparar una bala de fuego infernal que explota al impactar
			'''
		DisplayName: Abejeta de fuego infernal
	}

	HoneyShot: {
		DisplayName: Disparamiel
		Tooltip: Dispara una descarga de flechas de miel
	}

	SyrupSickle: {
		DisplayName: Hoz de néctar
		Tooltip:
			'''
			Invoca una hoz de néctar resplandeciente frente al usuario
			Asestar un golpe crítico aumenta considerablemente la regeneración de vida durante un breve periodo
			'''
	}

	Ambrosia: {
		DisplayName: Lanzamiento ambrosial
		Tooltip:
			'''
			Lanza un yoyó de néctar puro
			Provoca explosiones de néctar al impactar que curan al usuario
			'''
	}

	Beemstick: {
	Tooltip:
		'''
		Dispara una dispersión de perdigones de abeja y abejas
		«Esta... es mi ABEJETA»
		'''
	DisplayName: Abejeta
}

