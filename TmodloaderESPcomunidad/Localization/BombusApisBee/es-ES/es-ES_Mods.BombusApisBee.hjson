	}

	HoneyphyteHeadgear: {
		DisplayName: Capucha del acaparador de miel
		Tooltip: Aumenta la miel máxima en 100
	}

	HoneyphyteMask: {
		Tooltip:
			'''
			Aumenta un 10% el daño y la probabilidad de golpe crítico del apicultor
			Aumenta la miel máxima en 75
			'''
		DisplayName: Máscara de mielofita
	}

	LihzardianHornetRelic: {
		Tooltip:
			'''
			Aumenta un 35% la velocidad de movimiento y el tiempo de vuelo de las alas
			modifyTooltips
			Mientras canalizas, el daño, la velocidad de ataque y la probabilidad de golpe crítico del apicultor aumentan un 12%
			Recibes un 10% más de daño y sufres daño continuo mientras canalizas
			Este efecto tiene un tiempo de recarga de 45 segundos
			'''
		DisplayName: Reliquia del avispón lihzardiano
	}

	MegaHornet: {
		DisplayName: Megaavispón
		Tooltip:
			'''
			Se carga cuanto más tiempo disparas, aumentando el daño infligido
			«La hermana mayor de Miniavispón»
			'''
	}

	MiniHornet: {
		DisplayName: Miniavispón
		Tooltip: "«Mitad avispón, mitad arma, completamente increíble»"
	}

	NectarBolt: {
		Tooltip:
			'''
			Lanza un rayo de néctar reluciente que rebota en los bloques
			Al rebotar genera néctar perseguidor con un ligero robo de vida
			'''
		DisplayName: Rayo de néctar
	}

	NectarVial: {
		Tooltip:
			'''
			Cubre los ataques del apicultor con néctar dulce, otorgándoles robo de vida con golpes críticos
			Aumenta la vida máxima en 20
			«Es un manjar en la mayoría de lugares del mundo»
			'''
		DisplayName: Frasco de néctar
	}

	Needleshot: {
		Tooltip: Dispara una ráfaga de aguijones de alta velocidad y bombas de colmena
		DisplayName: Disparo de agujas
	}

	TheQueensCharge: {
		Tooltip:
			'''
			Pulsa dos veces en cualquier dirección para embestir
			Genera abejas mientras embistes
			'''
		DisplayName: Embestida de la reina
	}

	RoyalJelly: {
		Tooltip:
			'''
			Aumenta permanentemente la miel máxima en 25
			«Un manjar muy codiciado por su sabor refinado y sus propiedades curativas»
			'''
		DisplayName: Jalea real
	}

	TheStingerSlinger: {
		Tooltip:
			'''
			Lanza un yoyó que dispara aguijones a los enemigos
			Dispara periódicamente una ráfaga de aguijones perseguidores
			'''
		DisplayName: El lanzaguijones
	}

	TheSting: {
		Tooltip:
			'''
			«Este sí que va a doler»
			Invoca una Abeja Reina en miniatura que ataca donde se encuentra el cursor
			Alterna entre 3 ataques:
			Rodear el cursor mientras dispara aguijones
			Embestir hacia el cursor
			Permanecer sobre el cursor y generar abejas
			Consume 2 de miel por cada segundo que permanece con vida
			'''
		DisplayName: El aguijón
	}

	TomeOfTheSun: {
		Tooltip: Crea un pulso de energía de néctar vibrante en el cursor que se divide en proyectiles perseguidores
		DisplayName: Tomo del sol
	}

	TriTipStinger: {
		DisplayName: Aguijón de tres puntas
		Tooltip:
			'''
			Otorga a los ataques del apicultor una probabilidad de aplicar un veneno mejorado al impactar
			El veneno mejorado inflige un porcentaje de la vida máxima del enemigo afectado y se propaga entre enemigos
			'''
	}

	Wasparang: {
		Tooltip:
			'''
			Pulsa <derecha> para cargar un avisparang retornante
			Suelta para lanzar el avisparang, generando avispas durante el vuelo y aguijones perseguidores al impactar
			'''
		DisplayName: Avisparang
	}

	WaspBreastplate: {
		Tooltip:
			'''
			Aumenta un 6% el daño y la probabilidad de golpe crítico del apicultor
			Aumenta en 1 el máximo de abejas leales
			'''
		DisplayName: Peto de avispa
	}

	WaspGreaves: {
	Tooltip: Velocidad de movimiento aumentada un 15%
	DisplayName: Grebas de avispa
}

	WaspHead: {
		Tooltip:
			'''
			Aumenta un 20% el tiempo de vuelo con alas y aumenta la velocidad de salto
			Aumenta la miel máxima en 35
			'''
		DisplayName: Cabeza de avispa
	}

	TheWaspNest: {
		Tooltip:
			'''
			Lanza un nido de avispas que genera avispas mientras está en el aire
			Consume 1 de miel cada vez que genera una avispa
			'''
		DisplayName: El nido de avispas
	}

	BeeBubbleBlaster: {
		DisplayName: Abejanopopper
		Tooltip: "«A los alienígenas les encantan las burbujas... que disparan balas»"
	}

	HoneyManipulator: {
		Tooltip:
			'''

			TP
			+20 de miel máxima
			Este efecto tiene un tiempo de recarga de 90 segundos
			No puedes regenerar miel durante 5 segundos después de activar la habilidad
			'''
		DisplayName: Manipulador de miel
	}

	LaserbeemBlaster: {
		Tooltip:
			'''
			Dispara concentraciones puras de energía de miel que rebotan entre enemigos
			Genera abejas de energía de miel pura al rebotar
			'''
		DisplayName: Cañón láserabeja
	}

	HoneycombCrusaderGreaves: {
		DisplayName: Grebas del cruzado del panal
		Tooltip: Daño del apicultor aumentado un 5%
	}

	HoneycombCrusaderHelmet: {
		Tooltip:
			'''
			Probabilidad de golpe crítico del apicultor aumentada un 5%
			Aumenta la miel máxima en 75
			'''
		DisplayName: Casco del cruzado del panal
	}

	HoneycombCrusaderPlatemail: {
		DisplayName: Armadura de placas del cruzado del panal
		Tooltip:
			'''
			Probabilidad de no consumir miel aumentada un 30%
			Aumenta en 4 el máximo de abejas leales
			'''
	}

	MetalPlatedHoneycomb: {
		Tooltip:
			'''
			Mantén <izquierda> para canalizar el poder del Panal Supremo
			«Inicializando proj.Ubersaw»
			«Inicializando proj.MetalBee»
			«Inicializando proj.DeathLaser»
			«Compilando Panal Supremo»
			'''
		DisplayName: Panal blindado de metal
	}

	OcularRemote: {
		Tooltip:
			'''
			Invoca al Retinapanal y al Espasmapanal para que luchen temporalmente por ti
			Solo puede haber una pareja de gemelos con vida a la vez
			Cada gemelo reserva 35 de miel mientras está con vida
			Pulsa <derecha> mientras sostienes el control para autodestruirlos; esta acción tiene tiempo de recarga
			«Menos mal que los Gemelos no guardan rencor»
			'''
		DisplayName: Control ocular
	}

	ProbeyComb: {
		Tooltip:
			'''
			Mantén <izquierda> para cargar una ráfaga de sondabejas
			Las sondabejas disparan láseres letales a los enemigos
			'''
		DisplayName: Sondapanal
	}

	HoneycombOfTheGalaxies: {
		DisplayName: Panal del cosmos
		Tooltip:
			'''
			«Un panal todopoderoso que, según se dice, nació en el centro del cosmos»
			Mantén pulsado el botón izquierdo para canalizar un panal que irradia energía universal
			El panal se carga y debilita el tejido del cosmos
			Al soltar el botón del ratón, el panal regresará canalizado hacia su dueño
			Esta acción rompe el tejido del cosmos y libera energías poderosas y abejas galácticas
			'''
	}

	PhotonFragment: {
		DisplayName: Partícula fotónica
		Tooltip: "«Se puede oír un zumbido incesante proveniente de esta partícula»"
	}

	BorealApiary: {
		DisplayName: Apiario boreal
		Tooltip:
			'''
			Mantén <izquierda> para disparar rápidamente abejas nevadas
			Mantén <derecha> para dispararlas más lentamente y tomar el control de ellas
			Las abejas controladas tienen un 10% más de probabilidad de golpe crítico y sus golpes críticos infligen Quemadura gélida
			'''
	}

	FrostedHoneycomb: {
		Tooltip:
			'''
			Lanza un panal congelante que se rompe en múltiples fragmentos de hielo
			Inflige Golpe glacial
			Asestar un golpe crítico a un enemigo afectado por Golpe glacial hace que explote en una ráfaga de abejas
			'''
		DisplayName: Panal escarchado
	}

	FrozenStinger: {
		Tooltip:
			'''
			Probabilidad de golpe crítico del apicultor aumentada un 8%
			Los golpes críticos del apicultor infligen Quebrado por la escarcha
			Los enemigos afectados por Quebrado por la escarcha pierden un 35% de defensa y se hacen añicos cuando tienen poca vida, dañando a los enemigos cercanos
			'''
		DisplayName: Aguijón congelado
	}

	ElectricHoneycomb: {
		Tooltip: Lanza un panal cargado de electricidad que electrocuta todo lo que se acerca y explota en electroabejas
		DisplayName: Panal eléctrico
	}

	TheStarStrap: {
		Tooltip:
			'''
			«Ve bien armado»
			Dispara una ráfaga de abejas estelares que hacen caer estrellas celestiales al impactar
			'''
		DisplayName: La correa estelar
	}

	AstralStarPickup: {
		DisplayName: Estrella astral
		Tooltip: No deberías ver esto...
	}

	TheStarSwarmer: {
		Tooltip:
			'''
			Dispara rápidamente abejas estelares
			Pulsa <derecha> para disparar una estrella que se divide
			Recoger la estrella restaura miel y aumenta el daño y la velocidad de ataque del usuario
			'''
		DisplayName: El enjambrador estelar
	}

	EnchantedCharm: {
		DisplayName: Colgante de disparo estelar
		Tooltip:
			'''
			Los apiarios invocan estrellas dañinas durante la noche
			«Estrellita, ¿dónde estás?»
			'''
	}

	EnergizerItem: {
		DisplayName: Energizador
		Tooltip:
			'''
			Aumenta un 25% la velocidad de las abejas aliadas
			Las abejas proporcionan una pequeña cantidad de luz
			Alterna este efecto con la visibilidad del accesorio
			'''
	}

	FlamingApiary: {
	DisplayName: Apiario llameante
	Tooltip:
		'''
		Mantén <izquierda> para disparar abejas rápidamente
		Mantén <derecha> para dispararlas más lentamente y tomar el control de ellas, prendiéndolas en llamas
		Las abejas controladas se mueven un 25% más rápido, tienen un 5% más de probabilidad de golpe crítico y sus golpes críticos infligen ¡En llamas!
		'''
}

	IronApiary: {
		DisplayName: Apiario de hierro
		Tooltip:
			'''
			Mantén <izquierda> para disparar abejas rápidamente
			Mantén <derecha> para dispararlas más lentamente y tomar el control de ellas
			Las abejas controladas se cubren de metal pesado, haciendo que se muevan un 25% más lento pero inflijan el doble de daño
			'''
	}

	TrueStingerScimitar: {
		DisplayName: Cimitarra de aguijón verdadera
		Tooltip: ""
	}

	LeadApiary: {
		DisplayName: Apiario de plomo
		Tooltip:
			'''
			Mantén <izquierda> para disparar abejas rápidamente
			Mantén <derecha> para dispararlas más lentamente y tomar el control de ellas
			Las abejas controladas infligen acumulaciones de Envenenamiento por plomo
			«Prohibido en Míchigan»
			'''
	}

	ShadesentHoneycombShard: {
		Tooltip:
			'''
			Aumenta un 35% la probabilidad de fortalecer a las abejas aliadas
			Las abejas fortalecidas pueden atravesar paredes, aumentando su probabilidad de golpe crítico
			'''
		DisplayName: Fragmento de panal umbrío
	}

	ChippedTailspike: {
		Tooltip:
			'''
			Hace que crezcan púas en tu espalda con el tiempo
			Recibir un golpe por detrás rompe las púas y refleja el daño al atacante
			Cuando las púas terminan de crecer, recibir un golpe refleja un 500% del daño al atacante y aumenta brevemente la probabilidad de golpe crítico del apicultor
			'''
		DisplayName: Pincho caudal astillado
	}

	MyocombShard: {
		DisplayName: Fragmento de micopanal
		Tooltip:
			'''
			Aumenta un 25% la probabilidad de fortalecer a las abejas aliadas
			Las abejas fortalecidas dejan nubes de esporas a su paso
			Solo se puede equipar un fragmento de panal a la vez

			'''
	}

	MolluscanHoneycombShard: {
		Tooltip:
			'''
			Aumenta un 30% la probabilidad de fortalecer a las abejas aliadas
			Las abejas fortalecidas ignoran 25 puntos de defensa
			'''
		DisplayName: Fragmento de panal de molusco
	}

	HydrophobicCoating: {
		Tooltip:
			'''
			Cubre los ataques del apicultor con un revestimiento hidrofóbico especial, haciendo que inflijan más daño cuando están mojados
			Evita que tus proyectiles de abeja desaparezcan en el agua
			Desactiva la visibilidad del accesorio para ocultar el aura acuática de los proyectiles mojados
			'''
		DisplayName: Revestimiento hidrofóbico
	}

	GlisteningGear: {
		Tooltip:
			'''
			Velocidad de ataque del apicultor aumentada un 7%
			Aumenta la miel máxima en 10
			«¡¿Cómo se supone que volver pegajoso un engranaje ayuda en algo?!»
			'''
		DisplayName: Engranaje reluciente
	}

	WulfrumHoneycombShard: {
		DisplayName: Fragmento de panal Wulfrum
		Tooltip:
			'''
			Aumenta un 25% la probabilidad de fortalecer a las abejas aliadas
			Las abejas fortalecidas aparecen con un escudo que les permite atacar una vez más
			Desactiva la visibilidad del accesorio para ocultar el escudo y sus efectos de ruptura en las abejas fortalecidas
			Solo se puede equipar un fragmento de panal a la vez

			'''
	}

	WulfrumHoneycomb: {
		Tooltip: Pulsa <derecha> para potenciar temporalmente la máquina a cambio de 20 de miel
		DisplayName: Panal Wulfrum
	}

	VictideNautihelm: {
		DisplayName: Nauticasco de victide
		Tooltip: Daño del apicultor aumentado un 5%
	}

	ShadestingerScepter: {
		DisplayName: Cetro de aguijón sombrío
		Tooltip:
			'''
			Lanza una descarga de aguijones sombríos inestables que impregnan a los enemigos con Energía oscura
			Golpea a los enemigos con suficiente Energía oscura para arrancarles abejas ensombrecidas

			'''
	}

	ShadestingerScythe: {
		DisplayName: Guadaña de aguijón sombrío
		Tooltip:
			'''
			Golpea rápidamente a los enemigos con una ráfaga de estocadas y lanzamientos, impregnándolos con Energía oscura
			Golpea a los enemigos con suficiente Energía oscura para arrancarles abejas ensombrecidas
			Pulsa <derecha> para extraer energía curativa de todos los enemigos y eliminar toda su Energía oscura
			La curación tiene un tiempo de recarga de 30 segundos
			'''
	}

	ScourgedHoneycomb: {
		Tooltip:
			'''
			Mantén <izquierda> para cargar un poderoso ataque de mandíbula
			Al cargarse por completo, dispara una ráfaga de agua letal
			«Imbuido con el poder del Azote»
			'''
		DisplayName: Panal del Azote
	}

	StormsentSceptre: {
		DisplayName: Cetro de la tormenta
		Tooltip:
			'''
			Lanza una descarga de abejas de tormenta
			Pulsa <derecha> para lanzar un rayo en cadena que inflige Embestida tormentosa
			Las abejas de tormenta infligen mucho más daño a los enemigos afectados por Embestida tormentosa
			'''
	}

	FungalApiary: {
		DisplayName: Apiario fúngico
		Tooltip:
			'''
			Mantén <izquierda> para disparar abejas fúngicas
			Mantén <derecha> para dispararlas más lentamente y tomar el control de ellas, haciendo que generen esporas perseguidoras al impactar
			Los golpes críticos generan esporas explosivas
			'''
	}

	MycelialHoneycomb: {
		Tooltip:
			'''
			Dispara abejas fúngicas
			Mantén <derecha> para hacer brotar esporas letales desde el bloque más cercano e infligir Micosis
			La Micosis hace que los enemigos afectados generen abejas fúngicas periódicamente
			'''
		DisplayName: Panal micelial
	}

	SulphuricApiary: {
		DisplayName: Apiario sulfúrico
		Tooltip:
			'''
			Mantén <izquierda> para disparar abejas sulfúricas
			Mantén <derecha> para dispararlas más lentamente y tomar el control de ellas, haciendo que inflijan Ionizado
			Ionizado se propaga entre enemigos y provoca explosiones
			Los enemigos ionizados reciben un 15% más de daño de apicultor proveniente de fuentes que no sean abejas
			'''
	}

	SulphuricStingerSpear: {
		DisplayName: Lanza de aguijón sulfúrico
		Tooltip:
			'''
			Empala a los enemigos y hace explotar a los afectados por Golpe de azufre
			Pulsa <derecha> para lanzar la lanza e infligir Golpe de azufre
			'''
	}

	SeashoneHoneycomb: {
	Tooltip:
		'''
		Pulsa <izquierda> para lanzar el panal
		Mantén <derecha> para materializar un poderoso cristal que se incrusta en los enemigos
		Golpea a los enemigos con cristales incrustados para hundirlos más profundamente hasta que estallen en proyectiles violentos
		Solo puede haber un cristal incrustado en cada enemigo a la vez
		'''
	DisplayName: Panal marino reluciente
}

	Coralcomb: {
		Tooltip:
			'''
			Lanza un panal dentado capaz de despedazar a los enemigos
			Los golpes críticos hacen sangrar a los enemigos
			El último golpe siempre es crítico e inflige un 50% más de daño
			'''
		DisplayName: Coralpanal
	}

	WulfrumStinger: {
		Tooltip:
			'''
			Lanza rápidamente aguijones Wulfrum
			Golpear a un enemigo puede hacer que suelte una celda de energía Wulfrum inestable
			Las celdas de energía pueden recogerse y lanzarse con <derecha>
			Las celdas de energía pueden golpearse en el aire para sobrecargarlas, haciendo que detonen con una explosión aún más violenta
			'''
		DisplayName: Aguijón Wulfrum
	}

	MoltenCharm: {
		DisplayName: Colgante de disparo ígneo
		Tooltip: Los apiarios invocan estrellas llameantes
	}

	EboncombShard: {
		DisplayName: Fragmento de crimopanal
		Tooltip:
			'''
			Aumenta un 30% la probabilidad de fortalecer a las abejas aliadas
			Aumenta en 3 el daño de las abejas fortalecidas
			Solo se puede equipar un fragmento de panal a la vez

			'''
	}

	CrimcombShard: {
		DisplayName: Fragmento de crimopanal
		Tooltip:
			'''
			Aumenta un 30% la probabilidad de fortalecer a las abejas aliadas
			Aumenta en 3 el daño de las abejas fortalecidas
			Solo se puede equipar un fragmento de panal a la vez

			'''
	}

	StarryApiary: {
		DisplayName: Lluvia de estrellas
		Tooltip:
			'''
			Mantén <izquierda> para disparar abejas rápidamente
			Mantén <derecha> para dispararlas más lentamente y tomar el control de ellas, haciendo llover estrellas sobre los enemigos cercanos
			Las estrellas se vuelven más poderosas durante la noche
			'''
	}

	TestAccessory: {
		DisplayName: Accesorio de prueba
		Tooltip: Para fines de depuración
	}
}

