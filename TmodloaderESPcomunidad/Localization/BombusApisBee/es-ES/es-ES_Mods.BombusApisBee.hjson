			Las cloroabejas se convierten en cloroenergía al morir
			'''
	}

	BandOfTheHive: {
		DisplayName: Banda tocada por la colmena
		Tooltip: Infligir una gran cantidad de daño en poco tiempo hace que tu siguiente golpe provoque una gran explosión de miel
	}

	HoneyedHeart: {
		DisplayName: Corazón de miel
		Tooltip: El 25% de la miel obtenida se convierte en vida
	}

	HoneyLocket: {
		DisplayName: Medallón de miel
