		DisplayName: Trofeo del Geliath estelar
		Tooltip: ""
	}

	PumpActionSwampgun: {
		DisplayName: Escopeta pantanosa de bombeo
		Tooltip: Dispara una descarga generalmente inofensiva de slime
	}

	Parasanguine: {
		DisplayName: Parasanguina
		Tooltip:
			'''
			Mantén <right> o golpea enemigos para acumular sangre en exceso
			<right> cuando el medidor esté alto para expulsar el exceso
			<left> después de hacer clic derecho para realizar un giro devastador
			'¿Qué obtienes si alimentas a un slime? Un slime más grande.'
			'''
	}

	Gobflogger: {
		DisplayName: Azotagoblins
		Tooltip:
			'''
			{$CommonItemTooltip.SummonTagDamage}
			{$CommonItemTooltip.Whips}
			Golpea enemigos para obtener una ligera mejora en la velocidad de ataque con látigos
			'Despacio pero seguro se gana la carrera'
			'''
	}

	CrystalGauntlets: {
		DisplayName: Guanteletes de cristal
		Tooltip:
			'''
			Mantén presionado <left> para cargar una potente ráfaga de rayos esféricos
			Cuando esté cargado, suelta <left> para liberar el rayo esférico contra tus enemigos
			<right> para aplaudir, detonando todos los rayos esféricos liberados
			'¡Poder ilimitado!'
			'''
	}

	SplendorJam: {
		DisplayName: Mermelada del esplendor
		Tooltip:
			'''
			Activa la Barra de Estrés
			El estrés se acumula pasivamente, aunque estar cerca de enemigos acelera su incremento
			Emites luz que escala con tu nivel de Estrés
			Otorga un Espectáculo al 0%, 25%, 50%, 75% y 100% de Estrés
			Al 25% de Estrés, tus armas producirán explosiones
			Al 75% de Estrés, las explosiones serán más grandes y harán más daño
			Pulsa dos veces ABAJO con más del 25% de Estrés para entrar en Modo Malicia
			El Modo Malicia aumenta significativamente tu daño, además de otorgar daño plano, penetración de armadura y golpe crítico
			Estas mejoras y su duración escalan con la cantidad de estrés que tengas
			'Algo horrible se aproxima...'
			'''
		StressBar: Stress: {0}
	}

	SludgeShaker: {
		DisplayName: Agitador de lodo
		Tooltip:
			'''
			Rocía una gran cantidad de baba pegajosa
			El slime se adhiere a las estructuras mientras se expulsa
			'Agitado, no revuelto'
			'''
	}

	SupremeRestorationPotion: {
		DisplayName: Poción de restauración Omega
		Tooltip: "{$ItemTooltip.RestorationPotion}"
	}

	ChromaticTorch: {
		DisplayName: Antorcha cromática
		Tooltip: ""
	}

	StickyHand: {
		DisplayName: Mano pegajosa
		Tooltip:
			'''
			Te suelta automáticamente cuando estás cerca del gancho
			Mantén presionado el botón del gancho para mantenerlo adherido a los bloques
			'No se romperá, lo prometo'
			{$}
			'''
		Stats:
			'''
			Reach: 56
			Launch Velocity: 25
			Reelback Velocity: 10
			Pull Velocity: 17
			'''
	}

	Trailblazer: {
		DisplayName: Pionero
		Tooltip:
			'''
			Usa gel como munición
			Ignora 15 puntos de Defensa del enemigo
			80% de probabilidad de no consumir munición
			'''
	}

	SlimeCane: {
		DisplayName: Bastón de slime
		Tooltip:
			'''
			Invoca un conjunto de 4 escuderos de slime para protegerte
			Usar el arma nuevamente consume una ranura de esbirro para mejorar los slimes
			Los slimes pueden mejorarse hasta un máximo de 4 veces
			Una vez completamente mejorados, aparecerá un Goozmoem que dispara rayos de fusión a los enemigos
			'Ojalá pudiera eliminar las impurezas y hacerlo tan hermoso como yo'
			'''
	}

	FissionFlyer: {
		DisplayName: Volador de fisión
		Tooltip:
			'''
			Lanza un chakram que se divide en una descarga de 3 Anillos Afilados
			Golpes sigilosos se dividen en más Anillos y dejan una hoja colosal
			'''
	}

	ScytheOfTheOldGod: {
		DisplayName: Guadaña del Dios antiguo
		Tooltip:
			'''
			Blande una guadaña colosal en un combo de tres tajos
			'No confundir con la Guadaña del Viejo Duque...
			...Y nada más.'
			'''
	}

	Goomoire: {
		DisplayName: Goomoire
		Tooltip:
			'''
			Lanza un hechizo de sellado que absorbe enemigos
			'¡No al pozo! ¡Quema!'
			'''
	}

	SlimeNinjaStatue: {
		DisplayName: Estatua del ninja slime
		Tooltip:
			'''
			Rodéala con 4 estatuas de slime e interactúa con un Catalizador Gelatinoso para iniciar una Lluvia de Slimes
			Acelera en gran medida la acumulación de slime cuando se activa
			'¿Quién es este tipo, de todos modos?'
			'''
	}

	GelatinousCatalyst: {
		DisplayName: Catalizador gelatinoso
		Tooltip: Úsalo en una Estatua del Ninja Slime con 4 Estatuas de Slime presentes para iniciar una Lluvia de Slimes
	}

	PluripotentSpawnEgg: {
		DisplayName: Huevo de invocación pluripotente
		Tooltip:
			'''
			Úsalo en una Estatua del Ninja Slime con 4 Estatuas de Slime para invocar a Goozma directamente
			No se consume
			'''
	}

	PaladinPalanquin: {
		DisplayName: Palanquín de paladín
		Tooltip:
			'''
			Invoca una montura de Burbuja Aceitosa montable
			'¡Como la realeza!'
			'''
	}

	ChromaticGooztick: {
		DisplayName: Bastón cromático de slime
		Tooltip: Ignora la gravedad y rebota en bloques
	}

	BadApple: {
		DisplayName: Manzana podrida
		Tooltip:
			'''
			'Una manzana de un árbol arrasado durante una de las devastaciones de Goozma.
			Parece haberse transformado en algo casi nuevo, y probablemente sabe horrible como resultado.
			Si el sabor no es extraño, el olor sin duda lo es.'
			'''
	}

	CometKunai: {
		DisplayName: Kunai cometa
		Tooltip:
			'''
			Lanza una andanada de kunais y estrellas que se duplican al acertar
