		Tooltip: ""
	}

	StellarMask: {
		DisplayName: Máscara estelar
		Tooltip: ""
	}

	Goozmaga: {
		DisplayName: Goozmaga
		Tooltip:
			'''
			Lanza planetas que orbitan a los enemigos golpeados
			Golpear a un enemigo con un planeta orbitando aumenta su velocidad
			Esto se acumula 8 veces
			Los golpes sigilosos hacen que dos planetoides pequeños adicionales orbiten al objetivo golpeado
			<right> para destruir todos los planetas y planetoides existentes
			'''
	}

	ShogunChestplate: {
		DisplayName: Coraza del Shogun resbaloso
		Tooltip:
			'''
			20% más de daño
			Reduce el daño recibido en 9% y aumenta en gran medida la regeneración de vida
			Aumenta la vida y maná máximos en 150
			'''
	}

	ShogunHelm: {
		DisplayName: Yelmo del Shogun resbaloso
		Tooltip:
			'''
			20% más de daño
			15% más de probabilidad de golpe crítico
			15% más de velocidad de ataque cuerpo a cuerpo
			'''
		SetBonus:
			'''
			17% increased damage and +5 max minions
			{$CommonItemTooltip.FlightAndSlowfall}
			Wearing any wings overrides this flight
			{$CommonItemTooltip.PressDownToHover}
			Allows the ability to dash and enhances other dashes
			Hold DOWN to fastfall
			Increases jump speed 
			Grants immunity to many endgame and movement-based debuffs
			'''
	}

	ShogunPants: {
		DisplayName: Pantalones del Shogun resbaloso
		Tooltip:
			'''
			20% más de daño
			50% más de velocidad de movimiento
			Gran mejora en aceleración y maniobrabilidad
			'''
	}

	AuricSole: {
		DisplayName: Suela áurica
		Tooltip:
			'''
			<right> para desactivarTe
			Permite deslizarte sobre cualquier superficie
			Advertencia: Puede resultar en velocidades extraordinariamente altas
			'Yharim te odiaría por esto'
			'''
	}

	DischargedAuricSole: {
		DisplayName: Suela áurica descargada
		Tooltip:
			'''
			<right> para activar
			Te permite deslizarte sobre cualquier superficie
			Advertencia: Puede resultar en velocidades extraordinariamente altas
			'Yharim te odiaría por esto'
			'''
