Items: {
	BandofCratons: {
		DisplayName: "{$Mods.ThoriumRework.Items.BandofCratonsCosmetic.DisplayName}"
		Tooltip:
			'''
			Otorga inmunidad a Desbordamiento y hace que tus ataques la provoquen
			Otorga un escudo pasivo de 40
			Restaura los recursos del jugador en función de la cantidad de escudo perdido
			Si se pierden más de 20 de escudo, se produce una descarga eléctrica que destruye 3 proyectiles cercanos
			{$Mods.ThoriumRework.Items.BandofCratonsCosmetic.Tooltip}
			'''
	}

	BandofCratonsCosmetic: {
		DisplayName: Cinturón de cratones
		Tooltip: '''"Lo suficientemente resistente como para soportar la deriva continental"'''
	}

	BannerofWar: {
		DisplayName: "{$Mods.ThoriumRework.Items.BannerofWarCosmetic.DisplayName}"
		Tooltip:
			'''
			El daño y la curación adicional aumentan lentamente con el tiempo mientras estás en combate
			Estas bonificaciones se van disipando gradualmente cuando sales del combate
			Mientras estás en combate, emites periódicamente un pulso curativo que cura a los aliados en una cantidad igual a la curación adicional
			La frecuencia de los pulsos aumenta cuanto más tiempo permanezcas en combate
			El alcance del potenciador de los bardos afecta al alcance del pulso curativo
			'''
	}

	BannerofWarCosmetic: {
		DisplayName: Estandarte de la guerra
		Tooltip: ""
	}

	BeholderBlade: {
		DisplayName: Testamento de Coznix
		Tooltip:
			'''
			El tercer y cuarto ataque lanzan un rayo del vacío devastador
			Los golpes críticos crean una burbuja del vacío en la ubicación del objetivo alcanzado
			La burbuja del vacío invoca unos ojos que atacan a los enemigos infligiendo un 50% de daño
			Solo puede haber una burbuja del vacío activa a la vez
			'''
	}

	BeholderHeart: {
		DisplayName: Corazón del observador
		Tooltip:
			'''
			Aumenta la vida máxima en 10 y la curación adicional en 1
			Cada 30 puntos de vida curados a un aliado, se lanza un rayo de energía radiante que inflige daño
			Además, recuperas una cantidad de vida igual a la curación adicional
			'''
	}

	BeholderTentacles: {
		DisplayName: "{$Mods.ThoriumRework.Items.BeholderTentaclesCosmetic.DisplayName}"
		Tooltip:
			'''
			Los ataques infligen Quemadura; el daño contra objetivos con Quemadura aumenta un 20%
			{$Mods.ThoriumRework.Items.BeholderTentaclesCosmetic.Tooltip}
			'''
	}

	BeholderTentaclesCosmetic: {
		DisplayName: Beholder's Tentacles
		Tooltip:
			'''
			Provoca los efectos {$ItemName.FrogLeg} y {$ItemName.LavaWaders}, pero sin la inmunidad a la lava
			"Debe de ser de Will"
			'''
	}

	BiterofSouls: {
		DisplayName: Devorador de almas
		Tooltip:
			'''
			Lanza pequeños devoradores de almas que se enfurecen tras recorrer cierta distancia
			Mientras están enfurecidos, atraviesan al objetivo de forma indefinida y pueden golpear al mismo objetivo varias veces
			'''
	}

	ChampionWarHorn: {
		DisplayName: Cuerno de guerra del campeón
		Tooltip:
			'''
			Lanza un eco de guerra autoguiado
			"¡A LA CARGA!"
			'''
	}

	ChironsCure: {
		DisplayName: La cura de Quirón
		Tooltip: Intercambia la vida por un rayo reparador que cura algunos efectos negativos básicos
	}

	ConcussiveInstrument: {
		DisplayName: Instrumento de impacto
		Tooltip:
			'''
			Los golpes en los instrumentos de percusión impulsan los martillos hacia arriba, para luego caer
			"¿Es... solo un martillo?"
			'''
	}

	CrystallizedFinality: {
		DisplayName: Crystallized Finality
		Tooltip:
			'''
			Aplica los efectos [i:ThoriumRework/BeholderTentacles]{$ItemName.FrogLeg}, [i:ThoriumRework/BeholderTentacles]{$ItemName.LavaWaders} (pero sin la inmunidad a la lava) y [i:ThoriumRework/StriderMouthguard]{$ItemName.HandWarmer}
			[i:ThoriumRework/BeholderTentacles][i:ThoriumRework/StriderMouthguard] Los ataques infligen Congelación y Fuego infernal, infligen más daño a los objetivos afectados por cualquiera de estas desventajas y otorgan un escudo gracias a ellas
			[i:ThoriumRework/StriderMouthguard][i:ThoriumRework/UndyingGaze] Mantén pulsado atacar para generar hasta tres Mitos de la escarcha;  si dejas de atacar, lo liberarás y aplicarás Esencia del alma al impactar
			[i:ThoriumRework/UndyingGaze] Los golpes críticos otorgan Esencia del alma; los ataques que consumen vida o que ya otorgan Esencia del alma proporcionan una cantidad mayor
			[i:ThoriumRework/DeepDarkShellShield] Otorga un escudo pasivo de 20, inmunidad al empuje y duplica la mejora de salud del escudo, al tiempo que aumenta las estadísticas defensivas
            "UN ÚLTIMO ACTO DE ENTROPÍA"
			'''
	}

	DeathsingerPotion: {
		DisplayName: Poción del Cantante de la nuerte
		Tooltip: Aumenta un 7% el daño sinfónico y la velocidad al tocar
	}

	DeepDarkShellShield: {
		DisplayName: "{$Mods.ThoriumRework.Items.DeepDarkShellShieldCosmetic.DisplayName}"
		Tooltip:
			'''
			{$Mods.ThoriumRework.Items.DeepDarkShellShieldCosmetic.Tooltip}
			Duplica el aumento de salud que proporciona el escudo
			Además, el escudo aumenta la defensa y la reducción de daño
			'''
	}

	DeepDarkShellShieldCosmetic: {
		DisplayName: Escudo de caparazón oscuro y profundo
		Tooltip:
			'''
			Otorga un escudo pasivo de 20
			Otorga inmunidad al empuje
			'''
	}

	DukeFish: {
		DisplayName: Pez ducal
		Tooltip:
			'''
			Mantén pulsado <left> para hacer una burbuja que va creciendo, y suéltalo para lanzarla
			La burbuja curará a los aliados y los envolverá en un escudo protector
			"Por cierto, se llama Ron".
			'''
	}

	EaterPiper: {
		DisplayName: Devorador de gaitas
		Tooltip:
			'''
			Invoca gusanos retorcidos que pican a los enemigos
			Ignora 15 puntos de la defensa del enemigo
			"Dale un tarro de pimientos en escabeche"
			'''
	}

	ExecutionersContract: {
		DisplayName: El contrato del verdugo
		Tooltip:
			'''
			Al obtener esencia de alma con las guadañas radiantes, se obtiene una acumulación de carga agregada
			El daño radiante de los proyectiles de las guadañas o de las armas que no sean guadañas consume carga agregada para otorgar esencia de alma
			"Tráeme sus almas..."
			'''
	}

	FanDonations: {
		DisplayName: Donaciones de los fans
		Tooltip:
			'''
			Todos los ataques con instrumentos explotan al impactar; el tamaño de la explosión varía e inflige un 50% menos de daño crítico
			Los ataques penetrantes con instrumentos de cuerda aumentan de velocidad con cada impacto y ya no pierden daño
			Ciertos ataques con instrumentos de cuerda que activan efectos al chocar contra una casilla también se activan al impactar
			Los ataques con instrumentos de percusión lanzan martillos hacia arriba que, finalmente, caen
			Los proyectiles de los instrumentos electrónicos son considerablemente más rápidos
			Aumenta la inspiración máxima en 5.
			"Por desgracia, no se vende mucho. Al menos alguien tiene la amabilidad de proporcionarlos..."
			'''
	}

	FlyingFlute: {
		DisplayName: Flauta voladora
		Tooltip:
			'''
			Invoca una flauta alada que disparará a los enemigos
			Otorga Tiempo de vuelo II y Regeneración de recursos I cada vez que ataca
			"¿Te parece que da una flauta voladora?"
			'''
	}

	GildedFlyingFlute: {
		DisplayName: Flauta voladora dorada
		Tooltip:
			'''
			Aumenta un {0}% el daño sinfónico
			Aumenta un {1}% la velocidad de interpretación sinfónica
			Aumenta la velocidad de seguimiento de los instrumentos de viento en un {2}%
			Ahora tus ataques con instrumentos de viento intentan dirigirse rápidamente hacia los enemigos
			Si el ataque ya se dirige hacia los enemigos, lo hace mucho más rápido
			Invoca una flauta alada que disparará a los enemigos
			Otorga Tiempo de vuelo II y Regeneración de recursos I cada vez que ataca
			'''
	}

	HandheldRocket: {
		DisplayName: Cohete de mano
		Tooltip:
			'''
			Lanza un cohete de mano que explotará cuatro veces a una distancia determinada
			"¡Cohete de bolsillo!"
			'''
	}

	HeadHunter: {
		DisplayName: Cazatalentos
		Tooltip:
			'''
			Esta guadaña se blande en una dirección determinada y gira dos veces cada dos golpes
			Al obtener esencia de alma, asestar golpes críticos o estar en combate, se generan fragmentos de hielo que te siguen
			Cada fragmento de hielo otorga al usuario +10 de defensa, pero solo pueden haber 4 a la vez
			Pulsa <right> o cambia de arma para lanzar todos los fragmentos de hielo al enemigo más cercano al cursor
			"Pertenece a cierto demonio que, según se dice, regenta una cafetería..."
			'''
	}

	HelheimSoul: {
		DisplayName: Soul of Helheim
		Tooltip:
			'''
			Otorga inmunidad a [i:ThoriumRework/QueenJellyPin]Burbulas, [i:ThoriumRework/VampireCape]Sangrado, [i:ThoriumRework/VampireCape]Maldición del vampiro y [i:ThoriumRework/DeepDarkShellShield]retroceso
			Aplica los efectos [i:ThoriumRework/BeholderTentacles]{$ItemName.FrogLeg}, [i:ThoriumRework/BeholderTentacles]{$ItemName.LavaWaders}, y [i:ThoriumRework/StriderMouthguard]{$ItemName.HandWarmer}
			[i:ThoriumRework/BeholderTentacles][i:ThoriumRework/StriderMouthguard] Los ataques infligen Congelación y Fuego infernal, infligen más daño a los objetivos afectados por cualquiera de estas desventajas y otorgan un escudo frente a ellos
			[i:ThoriumRework/StriderMouthguard][i:ThoriumRework/UndyingGaze] Mantén pulsado atacar para generar hasta tres Mitos de la escarcha; deja de atacar para lanzarlos, lo que otorga Esencia del alma al impactar
			[i:ThoriumRework/DeepDarkShellShield][i:ThoriumRework/BandofCratons] Otorga un escudo pasivo de 40, inmunidad a Desbordamiento y hace que tus ataques lo inflijan, además de duplicar la mejora de salud del escudo y aumentar las estadísticas defensivas
			[i:ThoriumRework/BandofCratons] Restaura las estadísticas del jugador en función de la cantidad de escudo perdida; perder más de 20 de escudo provoca una descarga eléctrica que destruye 3 proyectiles
			[i:ThoriumRework/UndyingGaze] Los golpes críticos otorgan Esencia del alma; los ataques que consumen vida o que ya otorgan Esencia del alma proporcionan una cantidad mayor
			[i:ThoriumRework/QueenJellyPin] Invoca tentáculos a tu alrededor que se aferran a los enemigos y potencian la regeneración de vida y estadísticas al impactar; el daño de los tentáculos aumenta en función de la defensa
			[i:ThoriumRework/VampireCape] Recibes mucho menos daño y es mucho menos probable que los enemigos te elijan como objetivo mientras Enjambre de murciélagos esté activo
			[i:ThoriumRework/ZephyrWings] Agarrarte en el aire con la cría de Agarre de céfiro prolonga el tiempo de vuelo
			[i:ThoriumRework/ZephyrWings] La cría de Agarre de céfiro se puede invocar de nuevo tras planear un rato; infligir daño la recarga más rápido.
			[i:ThoriumRework/StarScoutReticle] Permite respirar en el espacio y otorga visión nocturna.
			[i:ThoriumRework/StarScoutReticle] Al realizar un dash, te teletransporta unas cuantos bloques hacia delante y te otorga una dash si aún no tienes ninguno
			[i:ThoriumRework/BannerofWar] El daño y la curación adicional aumentan con el tiempo mientras estás en combate, pero se van atenuando gradualmente al salir de combate
			[i:ThoriumRework/BannerofWar] Mientras estás en combate, emites periódicamente un pulso que cura a los aliados en una cantidad igual a la curación adicional; el alcance del potenciador del bardo afecta al alcance, y la frecuencia aumenta con el tiempo
			'''
	}

	ImpulseAmplifier: {
		DisplayName: Amplificador de impulsos
		Tooltip: Los proyectiles de instrumentos electrónicos son considerablemente más rápidos
	}

	InspirationRegenerationPotion: {
		DisplayName: Poción de regeneración de inspiración
		Tooltip: Aumenta la regeneración de la inspiración
	}

	FluteofCurses: {
		DisplayName: La flauta de las maldiciones
		Tooltip: Lanza calaveras malditas que se adhieren a los enemigos y les infligen daño continuo
	}

	JellyfishJam: {
		DisplayName: Mermelada de medusa
		Tooltip: Lanza medusas danzantes que perforan a los enemigos
	}

	KingTrumpet: {
		DisplayName: Trompeta real
		Tooltip:
			'''
			Lanza una ráfaga de esporas que infectan a los objetivos alcanzados
			Ignora 10 puntos de la defensa del enemigo
			'''
	}

	Kusarigama: {
		DisplayName: Kusarigama
		Tooltip:
			'''
			Esta maza se considera una guadaña
			Al golpear a los enemigos con la hoja, se genera esencia de alma
			Al golpear a los enemigos con la empuñadura, se genera energía curativa persistente
			Puede haber hasta 2 unidades de energía curativa a la vez
			'''
	}

	LichWhip: {
		DisplayName: Instrumento de tortura
		Tooltip:
			'''
			Lanza un triple látigo potenciado por el fuego del alma
			Los enemigos alcanzados desangrarán sus almas y curarán a sus objetivos
			"Una herramienta utilizada para atormentar a las almas en el más allá"
			'''
	}

	LodeStoneMagnetMace: {
		DisplayName: Maza magnética de magnetita
		Tooltip:
			'''
			Blande una maza magnética que libera energía curativa persistente con su primer golpe
			Puede haber hasta 4 energías curativas a la vez
			El daño desmorona a los enemigos, lo que aumenta el daño que reciben en un 10% y atrae la maza hacia ellos
			'''
	}

	Loudener: {
		DisplayName: Amplificador
		Tooltip:
			'''
			Los ataques con instrumentos de viento y de metal explotan al impactar
			El tamaño de la explosión varía en función del instrumento que se toque
			Las explosiones infligen un 50% menos de daño por golpe crítico
			"¡Tú tienes un silenciador, yo tengo un amplificador!"
			'''
	}

	LunateCharm: {
		DisplayName: Colgante en forma de semiluna
		Tooltip: Al obtener esencia del alma, se obtiene un escudo cuando la salud está al máximo
	}

	RedCresent: {
		DisplayName: Media luna roja
		Tooltip:
			'''
			Lanza murciélagos que regresan al impactar, proporcionando sangre
			Pulsa <right> para consumir sangre y liberar murciélagos que curan a los aliados en <healAmount> de vida
			<legendaryModeOnly>Su uso cuesta vida en el modo Legendario
			Sifón de sangre: <bloodSiphon>
			"Una maravillosa balada de los murciélagos"
			'''
	}

	MagicalHarp: {
		DisplayName: "{$ItemName.MagicalHarp}"
		Tooltip: ""
	}

	Oneirophobia: {
		DisplayName: Oneirofobia
		Tooltip:
			'''
			Crea una aparición lúcida que funciona como armas aleatorias
			En los dos primeros ataques, el arma se transforma en una espada
			El primer golpe genera una feroz onda de choque; el segundo, tres
			En el tercer ataque, la hoja del arma se desprende y sale disparada hacia delante
			A continuación, el arma se transforma en una guadaña
			En el cuarto ataque, el arma gira sobre sí misma y lanza proyectiles autoguiados
			En el quinto ataque, el arma se transforma en un bastón mágico
			A continuación, dispara una bola de energía volátil que explota poco después
			En el sexto ataque, el arma se transforma en una pistola láser con sistema de puntería automática
			Cuando se guarda, se convierte en un esbirro sintetizador consciente que ataca a los enemigos
			"La manifestación del miedo irracional a los sueños y las pesadillas"
			'''
	}

	QueenJellyPin: {
		DisplayName: "{$Mods.ThoriumRework.Items.QueenJellyPinCosmetic.DisplayName}"
		Tooltip:
			'''
			Otorga inmunidad a Burbujas
			Convoca tentáculos a tu alrededor que se aferran a los enemigos
			El daño de los tentáculos aumenta en función de la defensa
			Los tentáculos potencian la regeneración de vida y las estadísticas al impactar
			{$Mods.ThoriumRework.Items.QueenJellyPinCosmetic.Tooltip}
			'''
	}

	QueenJellyPinCosmetic: {
		DisplayName: Pin de jalea real
		Tooltip: '''"¡Arriba y junto a la cabeza!"'''
	}

	PickShapedPebble: {
		DisplayName: Guijarro con forma de pica
		Tooltip:
			'''
			Algunos ataques de instrumentos de cuerda que activan efectos al chocar contra un bloque también se activan al impactar
			"¡Es para la música rock!"
			'''
	}

	PocketEnergyStorm: {
		DisplayName: Tormenta de energía de bolsillo
		Tooltip:
			'''
			Lanza hasta 20 esferas de energía inestables que desbordan a los objetivos
			Los enemigos desbordados reciben un 5% más de daño.
			Puedes soltar con <left> para lanzar todas esas esferas a la vez
			No te agota.
            "Le da un nuevo significado a lo de “tener las pelotas azules”.
			'''
	}

	RepurposedStarCaller: {
		DisplayName: Llamador del explorador estelar
		Tooltip:
			'''
			Invoca los núcleos elementales del Explorador estelar para que luchen a tu lado
			Los núcleos Pyro queman a los objetivos, los núcleos Bio envenenan y los núcleos Crio infligen quemaduras por frío
			"Hemos recibido tu llamada, ¿y ahora qué?"
			'''
	}

	SealedContract: {
		DisplayName: Contrato sellado
		Tooltip:
			'''
			La vida máxima aumenta en 60
			Los hechizos de curación otorgan 5 puntos de vida adicionales
			Al obtener esencia de alma con las guadañas radiantes, se obtiene una acumulación de carga agregada y un escudo cuando la salud está al máximo
			El daño radiante de los proyectiles de las guadañas o de las armas que no sean guadañas consume carga agregada para otorgar esencia de alma
            "¡Cierra el trato!"
			'''
	}

	Shellxophone: {
		DisplayName: Odisea en las profundidades marinas
		Tooltip:
			'''
			Lanza ondas rebotantes acompañadas de ataques abisales autoguiados
			Pulsa <right> para lanzar gotas autoguiadas que curan a los aliados a cambio de 10 puntos de inspiración
			La curación aumenta por cada potenciador único que tengan los aliados, según su nivel
			"Convocando a los acechadores de las profundidades acuáticas para que interpreten la mejor sinfonía"
			'''
	}

	ShoulderBlade: {
		DisplayName: Omóplato
		Tooltip:
			'''
			Lanza un hacha de carne que se detiene a una cierta distancia
			Mientras está inmóvil, el arma tiene un breve punto óptimo en el que, al impactar, invoca dardos de sanguijuela autoguiados
			'''
	}

	SierraChimera: {
		DisplayName: Sierra quimera
		Tooltip:
			'''
			Otorga inmunidad a [i:ThoriumRework/QueenJellyPin]Burbujas, [i:ThoriumRework/VampireCape]Hemorragia y [i:ThoriumRework/VampireCape]Maldición del vampiro
			[i:ThoriumRework/QueenJellyPin] Invoca tentáculos a tu alrededor que se aferran a los enemigos y aumentan la regeneración de vida y las estadísticas al impactar
			[i:ThoriumRework/QueenJellyPin] El daño de los tentáculos aumenta en función de la defensa
			[i:ThoriumRework/VampireCape] Recibes mucho menos daño y es mucho menos probable que los enemigos te elijan como objetivo mientras Enjambre de murciélagos esté activo
			[i:ThoriumRework/ZephyrWings] Agarrarte en el aire con la cría de Agarre céfiro prolonga el tiempo de vuelo
			[i:ThoriumRework/ZephyrWings] La cría de Agarre céfiro puede invocarse de nuevo tras planear un rato; infligir daño la recarga más rápido
			'''
	}

	SoulSnatcher: {
		DisplayName: El ladrón de almas
		Tooltip:
			'''
			Esta maza cuenta como una guadaña
			Al golpear a los enemigos con la hoja, se genera esencia del alma
			Al golpear a los enemigos con la empuñadura, se genera energía curativa persistente
			Puede haber hasta 5 unidades de energía curativa a la vez
			"¡Tu alma pertenece al Ladrón de Almas!"
			'''
	}

	SpittingShroomStaff: {
		DisplayName: Bastón de seta escupidora
		Tooltip:
			'''
			Convoca a una seta que escupe esporas y ataca a los enemigos
			Se esconde cuando los enemigos se acercan, provocando una explosión mortal
			'''
	}

	StarScoutReticle: {
		DisplayName: "{$Mods.ThoriumRework.Items.StarScoutReticleCosmetic.DisplayName}"
		Tooltip:
			'''
			Te permite respirar en el espacio y te otorga visión nocturna
			El dash te teletransporta unos cuantos bloques más adelante
			No funciona con dash especiales
			Te proporciona un dash si aún no tienes ninguno
			{$Mods.ThoriumRework.Items.StarScoutReticleCosmetic.Tooltip}
			'''
	}

	StarScoutReticleCosmetic: {
		DisplayName: Retícula del explotador estelar
		Tooltip: '''"¿Te da miedo la oscuridad? ¡No te preocupes, me tienes a mí!"'''
	}

	StellarTune: {
		DisplayName: "{$ItemName.SparkleGuitar}"
		Tooltip: "{$ItemTooltip.SparkleGuitar}"
	}

	StriderMouthguard: {
		DisplayName: "{$Mods.ThoriumRework.Items.StriderMouthguardCosmetic.DisplayName}"
		Tooltip:
			'''
			Los ataques infligen Quemadura de hielo y otorgan un escudo al causar daño a objetivos afectados por Quemadura de hielo.
			Mantén pulsado el botón de atacar para generar hasta tres Mitos de escarcha; deja de atacar para lanzarlos.
			{$Mods.ThoriumRework.Items.StriderMouthguardCosmetic.Tooltip}
			'''
	}

	StriderMouthguardCosmetic: {
		DisplayName: Protector bucal de batalla
		Tooltip: Aplica el efecto {$ItemName.HandWarmer}
	}

	TerrariumSoulScourge: {
		DisplayName: Azote de las almas de terrario
		Tooltip:
			'''
			Blande una maza prismática que libera energía curativa persistente con su primer golpe
			Puede haber hasta 10 unidades de energía curativa a la vez
			Invoca copias arcoíris de sí mismo al generar orbes curativos
			'''
	}

	TitanHat: {
		DisplayName: Sombrero de titán
		Tooltip:
			'''
			"Imbuido de energía primordial"
			Aumenta la velocidad de interpretación sinfónica y la tasa de regeneración de inspiración en un 15%
			Aumenta la duración del potenciador en 3 segundos
			Aumenta considerablemente el alcance del potenciador
			'''
	}

	TitanHood: {
		DisplayName: Capucha de titán
		Tooltip:
			'''
			"Imbuido de energía primordial"
			Aumenta la velocidad de ataque de arrojador en un 15%
			Aumenta los puntos de técnica máximos en 3
			Las armas de arrojador no consumibles tardan un 40 % más en agotarte
			'''
	}

	TitanVisage: {
		DisplayName: Rostro de titán
		Tooltip:
			'''
			"Imbuido de energía primordial"
			Aumenta el daño radiante y la velocidad de ataque de arrojador en un 15%
			Los hechizos de curación curarán 6 puntos de vida adicionales
			Tus hechizos de curación pueden provocar un golpe crítico, lo que duplica su efecto curativo
			'''
	}

	TitanVisor: {
		DisplayName: Visera de titan
		Tooltip:
			'''
			'Infused with primordial energy'
			Aumenta el número máximo de súbditos en 3 y el de centinelas en 1
			Aumenta el alcance del látigo en un 15%
			Aumenta la probabilidad de golpe crítico de las invocaciones en un 6%
			Los súbditos y los centinelas pueden asestar golpes críticos
			'''
	}

	ThoriumBludgeon: {
		DisplayName: Maza de torio
		Tooltip:
			'''
			Blande una maza radiactiva que libera energía curativa persistente con su primer golpe
			Puede haber hasta 2 unidades de energía curativa a la vez
			'''
	}

	ThoriumHeavyScythe: {
		DisplayName: Guadaña pesada de torio
		Tooltip: Esta guadaña se maneja con las teclas direccionales en lugar de girarla
	}

	ThoriumWhistle: {
		DisplayName: Silbato de torio
		Tooltip: Lanza una ráfaga de rayos de corto alcance
	}

	UndyingGaze: {
		DisplayName: "{$Mods.ThoriumRework.Items.UndyingGazeCosmetic.DisplayName}"
		Tooltip:
			'''
			Ahora, cualquier golpe crítico otorga esencia del alma
			Los ataques que consumen vida otorgarán esencia del alma con cada impacto
			Los ataques que ya otorgan esencia del alma otorgarán una carga adicional
			'''
	}

	UndyingGazeCosmetic: {
		DisplayName: Mirada eterna
		Tooltip: Tus ojos desprenden un tenue resplandor
	}

	ValadiumHeavyScythe: {
		DisplayName: Guada pesada de valadio
		Tooltip:
			'''
			Esta guadaña se blande en una dirección concreta en lugar de girarse
			Lanza una onda de energía oscura de corto alcance que atraviesa todo
			El daño golpeará a los enemigos con energía interdimensional
			'''
	}

	ValkyrienSkyStone: {
		DisplayName: Piedra del cielo de valquiria
		Tooltip:
			'''
			[i:ThoriumRework/StarScoutReticle] Permite respirar en el espacio y otorga visión nocturna
			[i:ThoriumRework/StarScoutReticle] Al usar un dash, te teletransporta unas cuantos bloques hacia delante y te otorga un dash si aún no lo tienes
			[i:ThoriumRework/BannerofWar] El daño y la curación adicional aumentan con el tiempo mientras estás en combate, pero se van atenuando gradualmente cuando sales de combate
			[i:ThoriumRework/BannerofWar] Mientras estás en combate, emites periódicamente un pulso curativo que cura a los aliados en una cantidad igual a la curación adicional; el alcance del potenciador de los bardos afecta al alcance del pulso
			[i:ThoriumRework/BannerofWar] La frecuencia de los pulsos aumenta cuanto más tiempo permanezcas en combate
			[i:ThoriumRework/BandofCratons] Otorga un escudo pasivo de 40, inmunidad a Desbordamiento y hace que tus ataques lo inflijan
			[i:ThoriumRework/BandofCratons] Restaura las estadísticas del jugador en función de la cantidad de escudo perdido; perder más de 20 de escudo provoca una descarga eléctrica que destruye 3 proyectiles
			'''
	}

	VampireCape: {
		DisplayName: "{$Mods.ThoriumRework.Items.VampireCapeCosmetic.DisplayName}"
		Tooltip: Otorga inmunidad a hemorragia y a la maldición del vampiro
	}

	VampireCapeCosmetic: {
		DisplayName: Capa de murciélago vampiro
		Tooltip: ""
	}

	ZephyrsRuin: {
		DisplayName: Ruina de céfiro
		Tooltip:
			'''
			Se clava en los enemigos alcanzados o en el suelo si falla el golpe
			Convoca un rayo que golpea a los enemigos alcanzados tras un tiempo
			Los golpes críticos golpean a los enemigos en el impacto inicial
			No te agota
			"Dicen que un rayo nunca cae dos veces en el mismo sitio"
			'''
	}

	ZephyrWings: {
		DisplayName: "{$Mods.ThoriumRework.Items.ZephyrWingsCosmetic.DisplayName}"
		Tooltip:
			'''
			{$Mods.ThoriumRework.Items.ZephyrWingsCosmetic.Tooltip}
			Luchar en el aire con la cría de Agarre de céfiro prolonga la duración del vuelo
			La cría de Agarre de céfiro se puede volver a invocar tras planear durante un rato
			Infligir daño permite volver a invocar a la cría mucho antes
			'''
	}

	ZephyrWingsCosmetic: {
		DisplayName: Alas de céfiro
		Tooltip:
			'''
			Permite volar y caer lentamente
			Tiene las mismas estadísticas que {$ItemName.CreativeWings}
			'''
	}
}

Buffs: {
	BubblyShield: {
		DisplayName: Escudo burbujeante
		Description: Da +10 de defensa, escudo adicional y reducción de daño especial
	}

	Deathsinger: {
		DisplayName: Cantante de la muerte
		Description: Aumenta un 7% en el daño sinfónico y la velocidad al tocar
	}

	Inspired: {
		DisplayName: Inspirado
		Description: Tienes mayor regeneración de inspiración
	}

	SoulBleed: {
		DisplayName: Hemorragia del alma
		Description: Tu alma se está desvaneciendo...
	}

	StarCalled: {
		DisplayName: Llamador estelar
		Description: Han recibido tu señal
	}

	TerminalLucidity: {
		DisplayName: Lucidez terminal
		Description:
			'''
			-Mecánica del jefe-
			No se le puede infligir daño al Devorador de sueños mientras este efecto negativo esté activo
			Te matará cuando se agote el temporizador
			Toca una grieta de realidad estable para iniciar la fase de DPS y reiniciar el temporizador
			Las grietas de realidad estables son los portales de color morado brillante
			"El destino te espera..."
			'''
	}

	LucidRetaliation: {
		DisplayName: Represalia lúcida
		Description:
			'''
			-Mecánica del jefe
			Se puede infligir daño al Devorador de sueños mientras este beneficio esté activo
			Si te golpea una grieta de realidad inestable, este beneficio se elimina antes de tiempo
			Las grietas de realidad inestables son los ataques de grietas negras
			Otorga vuelo infinito
			"Llega el destino..."
			'''
	}

	VampireCape: {
		DisplayName: Enjambre de murciélagos vampiros
		Description: Eres un enjambre de murciélagos vampíricos
	}
}

Prefixes: {
	Careless: {
		DisplayName: Descuidado
		Description: +2 de coste de vida
	}

	Complicated: {
		DisplayName: Complicado
		Description: +25% de velocidad del temporizador
	}

	Favored: {
		DisplayName: Favorito
		Description: -25% de velocidad del temporizador
	}

	Risky: {
		DisplayName: Arriesgado
		Description: +1 de coste de vida
	}

	Simplified: {
		DisplayName: Simplificado
		Description: -25% de velocidad del temporizador
	}

	Suicidal: {
		DisplayName: Suicida
		Description: +3 de coste de vida
	}
}

Configs: {
	ReworkConfig: {
		DisplayName: Ajustes visuales

		flash: {
			Label: Intensidad de las luces intermitentes
			Tooltip: Ddetermina el grado de intensidad o de atenuación de los destellos
		}

		overlay: {
			Label: Intensidad de la superposición
			Tooltip: Determina qué grado de transparencia tienen las superposiciones en pantalla
		}

		seizures: {
			Label: Alerta sobre fotosensibilidad
			Tooltip: Muestra una alerta sobre fotosensibilidad al entrar en un mundo
		}

		bossRenames: {
			Label: Cambios de nombre de jefes
			Tooltip: Habilita los nuevos nombres de jefes añadidos por este mod
		}

		starScouterEnrageText: {
			Label: "[i:ThoriumMod/StarScouterMask]Texto de enfurecimiento del Explorador estelar"
			Tooltip:
				'''
				Determina si el Explorador estelar muestra o no una ventana emergente con un mensaje que indique que el enemigo se ha enfurecido
				Solo funciona en la versión mejorada del Explorador estelar; la versión original no se ve afectada por esta configuración, ya que no puede enfurecerse
				'''
		}

		starScouterEnrageVisuals: {
			Label: "[i:ThoriumMod/StarScouterMask]Imágenes de enfurecimiento del Explorador estelar "
			Tooltip:
				'''
				Determina si el Explorador estelar se vuelve rojo o no cuando se enfurece
				Solo funciona con la versión rediseñada del Explorador estelar; la versión original no se ve afectada por esta configuración, ya que no puede enfurecerse
				'''
		}

		lichOutline: {
			Label: "[i:ThoriumMod/LichMask]Intensidad del aura del lich"
			Tooltip:
				'''
				Controla la intensidad del tenue resplandor rojo que rodea al Lich
				Solo funciona en la versión rediseñada del Lich; la versión original no se ve afectada por este ajuste
				Utiliza esta opción si quieres que el aspecto sea idéntico al del diseño original o si te cuesta verlo
				'''
		}
	}

	CompatConfig: {
		DisplayName: Configuración de compatibilidad entre mods

		healthScale: {
			Label: Multiplicador de salud
			Tooltip: Multiplica la salud de los jefes de Thorium por este valor
		}

		damageScale: {
			Label: Multiplicador de daño
			Tooltip: Multiplica el daño de ataque de los jefes de Thorium por esta valor
		}

		speedScale: {
			Label: Multiplicador de velocidad
			Tooltip:
				'''
				Multiplica la velocidad de movimiento de los jefes de Thorium por este valor
				Se ha limitado a 2 veces la velocidad, ya que un valor superior hace que los jefes dejen de funcionar
				Se recomienda 1,35 veces para Infernum
				'''
		}

		terraItemsFix: {
			Label: Recetas de paridad de los objetos terra de Thorium
			Tooltip:
				'''
				(¡Recomendado!)
				Cambia todas las armas terra de Thorium para que utilicen recetas similares a las de la Espada terra original
				Se desactiva automáticamente si tienes instalado "Unofficial Calamity Bard & Healer", ya que ese mod ya realiza esta función
				'''
		}

		extraItems: {
			Label: Objetos adicionales
			Tooltip:
				'''
				(Opcional)
				Añade algunos objetos no relacionados que proceden de este mod
				'''
		}

		extraPotions: {
			Label: Pociones adicionales
			Tooltip:
				'''
				(Opcional)
				Añade algunas pociones de mejora relacionadas con la clase de Thorium y que proceden de este mod
				'''
		}

		extraPrefixes: {
			Label: Reforjas adicionales
			Tooltip:
				'''
				(Opcional)
				Añade algunas reforjas relacionadas con los objetos de clase de Thorium y que proceden de este mod
				'''
		}

		masterDrops: {
			Label: Recompensas del modo Maestro
			Tooltip:
				'''
				(¡Recomendado!)
				Los jefes de Thorium soltarán armas exclusivas en los modos Maestro, Venganza o Eternidad
				'''
		}

		masterDropsAreNonExclusive: {
			Label: Las recompensas de armas de Maestro son botines de experto
			Tooltip:
				'''
				Las armas exclusivas del modo Maestro aparecen en el modo Experto
				Recomendado si no te gusta jugar en el modo Maestro  o si otros mods alteran las recompensas de este modo
				(por ejemplo, que el modo Eternidad se convierta en el modo Masoquista» o que el modo Infernum no se pueda usar en el modo Maestro)
				'''
		}

		itemReworks: {
			Label: Rediseño algunos de los objetos de Thorium
			Tooltip:
				'''
				(¡Recomendado!)
				Mejora considerablemente algunos objetos del mod Thorium.
				'''
		}

		postDoGRag: {
			Label: Reasignar niveles a los Primordiales en Calamity o Fargo's Souls
			Tooltip:
				'''
				(¡Recomendado!)
				Hace que los Primordiales aparezcan después de Devorador de dioses en la progresión,
				antes de Eridanus en Fargo's Souls o
				entre ambos si se tienen activados esos dos mods
				'''
		}

		vanillaBard: {
			Label: La Melodía estelar y el Arpa mágica son de Bardo
			Tooltip: La Melodía estelar y el Arpa mágica ahora son instrumentos de cuerda y otorgan potenciadores
		}

		DoD: {
			Label: Devorador de sueños (configuración de broma)
			Tooltip:
				'''
				Esta configuración es una broma en toda regla: le da al Devorador de dioses los ataques originales del Devorador de sueños.
				Puede que sea justo y equilibrado, o puede que no
				'''
		}

		thorlamityBR: {
			Label: Jefes de Thorium en el Boss Rush de Calamity
			Tooltip: Los jefes de Thorium aparecen en el Boss Rush de Calamity, ordenados según el nivel correspondiente de progresión
		}

		defenseDamage: {
			Label: Defensa, Daño y Apoyo
			Tooltip: Permite que algunos de los ataques de los jefes de Thorium inflijan daño a la defensa si el mod Calamity está activado
		}

		eternityModeOnly: {
			Label: Solo modo Eternidad
			Tooltip:
				'''
				Las modificaciones de los jefes de este mod solo se aplican cuando el modo Eternidad está activo
				Además, cambia las recomensas de armas maestras (si están habilitados) por botines de armas del modo Eternidad
				Asimismo, los jefes de Thorium ahora pueden soltar accesorios del modo Eternidad
				Esta configuración no tiene ningún efecto si no se ha instalado Fargo's Souls.
				'''
		}

		infernumModeOnly: {
			Label: Solo modo Infernum
			Tooltip:
				'''
				Las modificaciones de los jefes de este mod solo se aplican cuando el modo Infernum está activo
				Esta configuración no tiene ningún efecto si Infernum no está instalado
				'''
		}
	}

