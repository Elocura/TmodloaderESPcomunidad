			Tooltip: Rework del Lich
		}

		abyssion: {
			Label: "[i:ThoriumMod/ForgottenOneMask]Abyssion"
			Tooltip: Rework del Olvidado
		}

		requireAbyssion: {
			Label: "[i:ThoriumMod/ForgottenOneMask]Requisito: Abisón en la progresión
			Tooltip:
				'''
				Ahora es necesario matar al Olvidado junto con el Golem para que aparezcan los cultistas.
				Se desactiva automáticamente en los mundos en los que no se hayan generado las Profundidades acuáticas
				'''
