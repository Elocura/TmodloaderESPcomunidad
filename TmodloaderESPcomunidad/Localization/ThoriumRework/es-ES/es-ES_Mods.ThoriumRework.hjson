		rag: {
			Label: "[i:ThoriumMod/TheOmegaCore]Ragnarök"
			Tooltip: Rework de los Primordiales y el Devorador de sueños
		}

		terminalLucidity: {
			Label: "[i:ThoriumMod/TheOmegaCore] Lucidez terminal - Dificultad mínima"
			Tooltip:
				'''
				Lucidez terminal puede aparecer en el nivel de dificultad mostrado abajo:
				0 - Solo en el Boss Rush
				1 - Disponible para todo
				2 - Maestro o Venganza
				3 - Legendario, Muerte o Eternidad
				4 - GFB, Infernum, Masoquista o Eternidad-Muerte
				'''
		}
	}

